{% comment %}
  购物车抽屉组件 - 添加到 sections/cart-drawer.liquid
  然后在 theme.liquid 的 </body> 前引入 {% section 'cart-drawer' %}
{% endcomment %}

<style>
/* ========== 购物车抽屉样式 ========== */
@import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

.cart-drawer-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(4px);
    z-index: 9998;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
}

.cart-drawer-overlay.active {
    opacity: 1;
    visibility: visible;
}

.cart-drawer {
    position: fixed;
    top: 0;
    right: 0;
    width: 100%;
    max-width: 480px;
    height: 100vh;
    background: #1a1a2e;
    border-left: 5px solid #FFE600;
    z-index: 9999;
    transform: translateX(100%);
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    box-shadow: -10px 0 40px rgba(0, 0, 0, 0.5);
}

.cart-drawer.active {
    transform: translateX(0);
}

/* 头部 */
.cart-drawer-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px;
    border-bottom: 4px solid rgba(255, 230, 0, 0.2);
    background: linear-gradient(135deg, #1a1a2e 0%, #252542 100%);
}

.cart-drawer-title {
    font-family: 'Press Start 2P', cursive;
    font-size: 14px;
    color: #FFE600;
    display: flex;
    align-items: center;
    gap: 12px;
    text-shadow: 2px 2px 0 rgba(0, 0, 0, 0.5);
}

.cart-drawer-title::before {
    content: '🛒';
    font-size: 20px;
}

.cart-item-count {
    font-size: 10px;
    color: rgba(255, 255, 255, 0.6);
    background: rgba(255, 45, 125, 0.2);
    padding: 4px 8px;
    border-radius: 4px;
    border: 2px solid #FF2D7D;
}

.cart-drawer-close {
    width: 44px;
    height: 44px;
    background: #FF2D7D;
    border: 4px solid #000;
    border-radius: 12px;
    font-family: 'Press Start 2P', cursive;
    font-size: 16px;
    color: white;
    cursor: pointer;
    box-shadow: 4px 4px 0 #000;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
}

.cart-drawer-close:hover {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 #000;
    background: #ff4d8f;
}

/* 内容区 */
.cart-drawer-content {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
}

/* 空购物车状态 */
.cart-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    text-align: center;
    padding: 40px;
}

.cart-empty-icon {
    font-size: 80px;
    margin-bottom: 24px;
    opacity: 0.5;
    animation: float 3s ease-in-out infinite;
}

@keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
}

.cart-empty-text {
    font-family: 'Press Start 2P', cursive;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 32px;
    line-height: 1.8;
}

.cart-empty-btn {
    font-family: 'Press Start 2P', cursive;
    font-size: 10px;
    padding: 20px 32px;
    background: #FFE600;
    border: 4px solid #000;
    border-radius: 12px;
    color: #000;
    cursor: pointer;
    box-shadow: 6px 6px 0 #000;
    transition: all 0.2s;
    text-decoration: none;
    display: inline-block;
}

.cart-empty-btn:hover {
    transform: translate(3px, 3px);
    box-shadow: 3px 3px 0 #000;
    background: #00D9FF;
}

/* 购物车商品列表 */
.cart-items {
    display: flex;
    flex-direction: column;
    gap: 16px;
}

.cart-item {
    display: flex;
    gap: 16px;
    padding: 16px;
    background: rgba(255, 255, 255, 0.03);
    border: 3px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
}

.cart-item:hover {
    border-color: #FFE600;
    background: rgba(255, 230, 0, 0.05);
    transform: translateX(-4px);
}

.cart-item-image {
    width: 80px;
    height: 80px;
    border-radius: 12px;
    overflow: hidden;
    border: 3px solid #000;
    flex-shrink: 0;
    background: linear-gradient(135deg, #FFE600, #FF6B9D);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 40px;
}

.cart-item-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.cart-item-details {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}

.cart-item-title {
    font-family: 'Press Start 2P', cursive;
    font-size: 10px;
    color: #fff;
    line-height: 1.6;
    margin-bottom: 8px;
}

.cart-item-variant {
    font-size: 11px;
    color: rgba(255, 255, 255, 0.5);
    margin-bottom: 12px;
}

.cart-item-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
}

/* 数量控制 */
.quantity-selector {
    display: flex;
    align-items: center;
    gap: 0;
    border: 3px solid #000;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 3px 3px 0 #000;
}

.quantity-btn {
    width: 32px;
    height: 32px;
    background: #FFE600;
    border: none;
    font-family: 'Press Start 2P', cursive;
    font-size: 12px;
    color: #000;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    justify-content: center;
}

.quantity-btn:hover {
    background: #FF2D7D;
    color: white;
}

.quantity-btn.minus {
    border-right: 3px solid #000;
}

.quantity-btn.plus {
    border-left: 3px solid #000;
}

.quantity-input {
    width: 40px;
    height: 32px;
    background: #fff;
    border: none;
    font-family: 'Press Start 2P', cursive;
    font-size: 10px;
    color: #000;
    text-align: center;
    outline: none;
    -moz-appearance: textfield;
}

.quantity-input::-webkit-outer-spin-button,
.quantity-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
}

.cart-item-price {
    font-family: 'Press Start 2P', cursive;
    font-size: 12px;
    color: #FF2D7D;
}

.cart-item-remove {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 28px;
    height: 28px;
    background: rgba(255, 45, 125, 0.2);
    border: 2px solid rgba(255, 45, 125, 0.5);
    border-radius: 6px;
    color: #FF2D7D;
    cursor: pointer;
    font-size: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
    opacity: 0;
}

.cart-item:hover .cart-item-remove {
    opacity: 1;
}

.cart-item-remove:hover {
    background: #FF2D7D;
    color: white;
    border-color: #FF2D7D;
}

/* 底部结算区 */
.cart-drawer-footer {
    padding: 24px;
    border-top: 4px solid rgba(255, 230, 0, 0.2);
    background: linear-gradient(135deg, #252542 0%, #1a1a2e 100%);
}

.cart-subtotal {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
}

.cart-subtotal-label {
    font-family: 'Press Start 2P', cursive;
    font-size: 10px;
    color: rgba(255, 255, 255, 0.6);
}

.cart-subtotal-price {
    font-family: 'Press Start 2P', cursive;
    font-size: 14px;
    color: #FFE600;
}

.cart-shipping {
    font-size: 11px;
    color: rgba(255, 255, 255, 0.4);
    text-align: center;
    margin-bottom: 20px;
    padding-bottom: 20px;
    border-bottom: 2px solid rgba(255, 255, 255, 0.1);
}

.cart-checkout-btn {
    width: 100%;
    padding: 24px;
    background: #00D9FF;
    border: 5px solid #000;
    border-radius: 16px;
    font-family: 'Press Start 2P', cursive;
    font-size: 14px;
    color: #000;
    cursor: pointer;
    box-shadow: 8px 8px 0 #000;
    transition: all 0.2s;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
}

.cart-checkout-btn:hover {
    transform: translate(4px, 4px);
    box-shadow: 4px 4px 0 #000;
    background: #FFE600;
}

.cart-continue-btn {
    width: 100%;
    padding: 16px;
    background: transparent;
    border: 3px solid rgba(255, 255, 255, 0.3);
    border-radius: 12px;
    font-family: 'Press Start 2P', cursive;
    font-size: 10px;
    color: rgba(255, 255, 255, 0.6);
    cursor: pointer;
    transition: all 0.2s;
}

.cart-continue-btn:hover {
    border-color: #FFE600;
    color: #FFE600;
    background: rgba(255, 230, 0, 0.1);
}

/* 免费进度条 */
.cart-free-shipping {
    margin-bottom: 20px;
}

.free-shipping-text {
    font-family: 'Press Start 2P', cursive;
    font-size: 9px;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 12px;
    text-align: center;
}

.free-shipping-bar {
    height: 16px;
    background: rgba(255, 255, 255, 0.1);
    border: 3px solid #000;
    border-radius: 8px;
    overflow: hidden;
    position: relative;
    box-shadow: 3px 3px 0 #000;
}

.free-shipping-progress {
    height: 100%;
    background: linear-gradient(90deg, #FFE600, #FF2D7D);
    border-radius: 4px;
    transition: width 0.5s ease;
    position: relative;
}

.free-shipping-progress::after {
    content: '★';
    position: absolute;
    right: 4px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 10px;
    color: #000;
}

/* 滚动条美化 */
.cart-drawer-content::-webkit-scrollbar {
    width: 8px;
}

.cart-drawer-content::-webkit-scrollbar-track {
    background: rgba(255, 255, 255, 0.05);
    border-radius: 4px;
}

.cart-drawer-content::-webkit-scrollbar-thumb {
    background: #FFE600;
    border-radius: 4px;
    border: 2px solid #1a1a2e;
}

/* 响应式 */
@media (max-width: 480px) {
    .cart-drawer {
        max-width: 100%;
        border-left: none;
        border-top: 5px solid #FFE600;
    }
    
    .cart-item {
        padding: 12px;
    }
    
    .cart-item-image {
        width: 64px;
        height: 64px;
    }
}
</style>

<!-- 购物车抽屉 -->
<div class="cart-drawer-overlay" id="cartOverlay" onclick="closeCartDrawer()"></div>

<div class="cart-drawer" id="cartDrawer">
    <!-- 头部 -->
    <div class="cart-drawer-header">
        <div class="cart-drawer-title">
            YOUR CART
            <span class="cart-item-count" id="cartItemCount">3 ITEMS</span>
        </div>
        <button class="cart-drawer-close" onclick="closeCartDrawer()">×</button>
    </div>

    <!-- 内容区 -->
    <div class="cart-drawer-content" id="cartContent">
        
        <!-- 空购物车状态（默认隐藏，有商品时移除这个class） -->
        <div class="cart-empty" id="emptyCart" style="display: none;">
            <div class="cart-empty-icon">📦</div>
            <div class="cart-empty-text">
                YOUR LOOT BOX<br>IS EMPTY!
            </div>
            <a href="/pages/shop" class="cart-empty-btn" onclick="closeCartDrawer()">
                🎮 START SHOPPING
            </a>
        </div>

        <!-- 商品列表 -->
        <div class="cart-items" id="cartItems">
            
            <!-- 商品1 -->
            <div class="cart-item" data-id="1">
                <div class="cart-item-image">
                    <!-- 替换真实图片: <img src="product-image.jpg" alt=""> -->
                    🍄
                </div>
                <div class="cart-item-details">
                    <div>
                        <div class="cart-item-title">Mario Mushroom Keychain</div>
                        <div class="cart-item-variant">Color: Red / Size: Small</div>
                    </div>
                    <div class="cart-item-bottom">
                        <div class="quantity-selector">
                            <button class="quantity-btn minus" onclick="updateQuantity(1, -1)">−</button>
                            <input type="number" class="quantity-input" value="2" min="1" id="qty-1" readonly>
                            <button class="quantity-btn plus" onclick="updateQuantity(1, 1)">+</button>
                        </div>
                        <div class="cart-item-price" id="price-1">$36.00</div>
                    </div>
                </div>
                <button class="cart-item-remove" onclick="removeItem(1)">×</button>
            </div>

            <!-- 商品2 -->
            <div class="cart-item" data-id="2">
                <div class="cart-item-image" style="background: linear-gradient(135deg, #FF6B9D, #C44569);">
                    ⚡
                </div>
                <div class="cart-item-details">
                    <div>
                        <div class="cart-item-title">Pikachu Sprite Keychain</div>
                        <div class="cart-item-variant">Color: Yellow</div>
                    </div>
                    <div class="cart-item-bottom">
                        <div class="quantity-selector">
                            <button class="quantity-btn minus" onclick="updateQuantity(2, -1)">−</button>
                            <input type="number" class="quantity-input" value="1" min="1" id="qty-2" readonly>
                            <button class="quantity-btn plus" onclick="updateQuantity(2, 1)">+</button>
                        </div>
                        <div class="cart-item-price" id="price-2">$22.00</div>
                    </div>
                </div>
                <button class="cart-item-remove" onclick="removeItem(2)">×</button>
            </div>

        </div>

    </div>

    <!-- 底部结算 -->
    <div class="cart-drawer-footer" id="cartFooter">
        <!-- 免运费进度 -->
        <div class="cart-free-shipping" id="freeShipping">
            <div class="free-shipping-text">
                🚚 Add $14.00 more for FREE shipping!
            </div>
            <div class="free-shipping-bar">
                <div class="free-shipping-progress" style="width: 65%;"></div>
            </div>
        </div>

        <div class="cart-subtotal">
            <span class="cart-subtotal-label">SUBTOTAL</span>
            <span class="cart-subtotal-price" id="cartSubtotal">$58.00</span>
        </div>
        
        <div class="cart-shipping">
            Shipping & taxes calculated at checkout
        </div>

        <button class="cart-checkout-btn" onclick="checkout()">
            💳 CHECKOUT
        </button>
        
        <button class="cart-continue-btn" onclick="closeCartDrawer()">
            ← CONTINUE SHOPPING
        </button>
    </div>
</div>

<script>
// ========== 购物车功能 ==========

// 打开购物车
function openCartDrawer() {
    document.getElementById('cartOverlay').classList.add('active');
    document.getElementById('cartDrawer').classList.add('active');
    document.body.style.overflow = 'hidden';
    
    // 添加像素粒子效果
    createCartParticles();
}

// 关闭购物车
function closeCartDrawer() {
    document.getElementById('cartOverlay').classList.remove('active');
    document.getElementById('cartDrawer').classList.remove('active');
    document.body.style.overflow = '';
}

// 更新数量
function updateQuantity(id, change) {
    const input = document.getElementById(`qty-${id}`);
    let newVal = parseInt(input.value) + change;
    
    if (newVal < 1) newVal = 1;
    if (newVal > 99) newVal = 99;
    
    input.value = newVal;
    
    // 更新价格（示例：单价18，实际应从data获取）
    const unitPrice = id === 1 ? 18 : 22;
    const newPrice = (unitPrice * newVal).toFixed(2);
    document.getElementById(`price-${id}`).textContent = `$${newPrice}`;
    
    updateCartTotal();
    
    // 按钮动画
    event.target.style.transform = 'scale(0.9)';
    setTimeout(() => event.target.style.transform = '', 100);
}

// 删除商品
function removeItem(id) {
    const item = document.querySelector(`.cart-item[data-id="${id}"]`);
    
    // 滑出动画
    item.style.transform = 'translateX(100%)';
    item.style.opacity = '0';
    
    setTimeout(() => {
        item.remove();
        updateCartTotal();
        checkEmptyCart();
    }, 300);
}

// 检查空购物车
function checkEmptyCart() {
    const items = document.querySelectorAll('.cart-item');
    const emptyCart = document.getElementById('emptyCart');
    const cartFooter = document.getElementById('cartFooter');
    const cartContent = document.getElementById('cartContent');
    
    if (items.length === 0) {
        emptyCart.style.display = 'flex';
        cartFooter.style.display = 'none';
        cartContent.style.overflow = 'hidden';
        document.getElementById('cartItemCount').textContent = '0 ITEMS';
    }
}

// 更新总价
function updateCartTotal() {
    const prices = document.querySelectorAll('.cart-item-price');
    let total = 0;
    let itemCount = 0;
    
    prices.forEach((price, index) => {
        const val = parseFloat(price.textContent.replace('$', ''));
        total += val;
        
        const qty = document.getElementById(`qty-${index + 1}`);
        if (qty) itemCount += parseInt(qty.value);
    });
    
    document.getElementById('cartSubtotal').textContent = `$${total.toFixed(2)}`;
    document.getElementById('cartItemCount').textContent = `${itemCount} ITEM${itemCount !== 1 ? 'S' : ''}`;
    
    // 更新免运费进度
    updateFreeShipping(total);
}

// 更新免运费进度
function updateFreeShipping(total) {
    const threshold = 72; // 免运费门槛
    const remaining = threshold - total;
    const progress = Math.min((total / threshold) * 100, 100);
    
    const freeShippingEl = document.getElementById('freeShipping');
    
    if (remaining <= 0) {
        freeShippingEl.innerHTML = `
            <div class="free-shipping-text" style="color: #00D9FF;">
                🎉 Congratulations! You got FREE shipping!
            </div>
            <div class="free-shipping-bar">
                <div class="free-shipping-progress" style="width: 100%; background: linear-gradient(90deg, #00D9FF, #00FF00);"></div>
            </div>
        `;
    } else {
        freeShippingEl.innerHTML = `
            <div class="free-shipping-text">
                🚚 Add $${remaining.toFixed(2)} more for FREE shipping!
            </div>
            <div class="free-shipping-bar">
                <div class="free-shipping-progress" style="width: ${progress}%;"></div>
            </div>
        `;
    }
}

// 结算
function checkout() {
    const btn = event.target;
    btn.innerHTML = '⏳ PROCESSING...';
    btn.style.background = '#FFE600';
    
    setTimeout(() => {
        window.location.href = '/checkout';
    }, 800);
}

// 像素粒子效果
function createCartParticles() {
    const colors = ['#FFE600', '#FF2D7D', '#00D9FF', '#9D4EDD'];
    const drawer = document.getElementById('cartDrawer');
    
    for (let i = 0; i < 12; i++) {
        setTimeout(() => {
            const particle = document.createElement('div');
            particle.style.cssText = `
                position: absolute;
                width: 8px;
                height: 8px;
                background: ${colors[Math.floor(Math.random() * colors.length)]};
                left: ${Math.random() * 100}%;
                top: 100px;
                pointer-events: none;
                z-index: 10000;
                border-radius: 2px;
            `;
            
            drawer.appendChild(particle);
            
            particle.animate([
                { transform: 'translateY(0) scale(1)', opacity: 1 },
                { transform: 'translateY(-100px) scale(0)', opacity: 0 }
            ], {
                duration: 800 + Math.random() * 400,
                easing: 'ease-out'
            }).onfinish = () => particle.remove();
        }, i * 50);
    }
}

// ESC关闭
document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeCartDrawer();
});

// 初始化
document.addEventListener('DOMContentLoaded', () => {
    // 绑定导航栏购物车按钮
    const navCart = document.querySelector('.navbar-cart');
    if (navCart) {
        navCart.onclick = (e) => {
            e.preventDefault();
            openCartDrawer();
        };
    }
});
</script>
