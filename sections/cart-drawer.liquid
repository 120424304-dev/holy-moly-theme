{% comment %}
  Holy Moly Cart Drawer - 像素风格购物车抽屉
  用法: {% section 'cart-drawer' %}
{% endcomment %}

<style>
@import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

.cart-drawer-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.85); backdrop-filter: blur(4px); z-index: 9998; opacity: 0; visibility: hidden; transition: all 0.3s; }
.cart-drawer-overlay.active { opacity: 1; visibility: visible; }

.cart-drawer { position: fixed; top: 0; right: 0; width: 100%; max-width: 480px; height: 100vh; background: #1a1a2e; border-left: 5px solid #FFE600; z-index: 9999; transform: translateX(100%); transition: transform 0.4s cubic-bezier(0.4,0,0.2,1); display: flex; flex-direction: column; }
.cart-drawer.active { transform: translateX(0); }

.cart-drawer-header { display: flex; align-items: center; justify-content: space-between; padding: 24px; border-bottom: 4px solid rgba(255,230,0,0.2); background: linear-gradient(135deg, #1a1a2e, #252542); }
.cart-drawer-title { font-family: 'Press Start 2P', cursive; font-size: 14px; color: #FFE600; display: flex; align-items: center; gap: 12px; }
.cart-item-count { font-size: 10px; color: rgba(255,255,255,0.6); background: rgba(255,45,125,0.2); padding: 4px 8px; border-radius: 4px; border: 2px solid #FF2D7D; }
.cart-drawer-close { width: 44px; height: 44px; background: #FF2D7D; border: 4px solid #000; border-radius: 12px; font-family: 'Press Start 2P'; font-size: 16px; color: white; cursor: pointer; box-shadow: 4px 4px 0 #000; display: flex; align-items: center; justify-content: center; }
.cart-drawer-close:hover { transform: translate(2px,2px); box-shadow: 2px 2px 0 #000; }

.cart-drawer-content { flex: 1; overflow-y: auto; padding: 20px; }
.cart-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; text-align: center; padding: 40px; }
.cart-empty-icon { font-size: 80px; margin-bottom: 24px; opacity: 0.5; animation: float 3s ease-in-out infinite; }
@keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
.cart-empty-text { font-family: 'Press Start 2P'; font-size: 12px; color: rgba(255,255,255,0.5); margin-bottom: 32px; line-height: 1.8; }
.cart-empty-btn { font-family: 'Press Start 2P'; font-size: 10px; padding: 20px 32px; background: #FFE600; border: 4px solid #000; border-radius: 12px; color: #000; cursor: pointer; box-shadow: 6px 6px 0 #000; text-decoration: none; display: inline-block; }
.cart-empty-btn:hover { transform: translate(3px,3px); box-shadow: 3px 3px 0 #000; background: #00D9FF; }

.cart-items { display: flex; flex-direction: column; gap: 16px; }
.cart-item { display: flex; gap: 16px; padding: 16px; background: rgba(255,255,255,0.03); border: 3px solid rgba(255,255,255,0.1); border-radius: 16px; position: relative; }
.cart-item-image { width: 80px; height: 80px; border-radius: 12px; border: 3px solid #000; flex-shrink: 0; background: linear-gradient(135deg, #FFE600, #FF6B9D); display: flex; align-items: center; justify-content: center; overflow: hidden; }
.cart-item-image img { width: 100%; height: 100%; object-fit: cover; }
.cart-item-image .item-emoji { font-size: 40px; }
.cart-item-details { flex: 1; display: flex; flex-direction: column; justify-content: space-between; }
.cart-item-title { font-family: 'Press Start 2P'; font-size: 10px; color: #fff; line-height: 1.6; margin-bottom: 4px; }
.cart-item-variant { font-size: 11px; color: rgba(255,255,255,0.5); margin-bottom: 8px; }
.cart-item-bottom { display: flex; align-items: center; justify-content: space-between; }
.quantity-selector { display: flex; border: 3px solid #000; border-radius: 8px; overflow: hidden; box-shadow: 3px 3px 0 #000; }
.quantity-btn { width: 32px; height: 32px; background: #FFE600; border: none; font-family: 'Press Start 2P'; font-size: 12px; cursor: pointer; }
.quantity-btn:hover { background: #FF2D7D; color: white; }
.quantity-btn:disabled { background: #666; cursor: not-allowed; }
.quantity-input { width: 40px; height: 32px; background: #fff; border: none; font-family: 'Press Start 2P'; font-size: 10px; text-align: center; }
.cart-item-price { font-family: 'Press Start 2P'; font-size: 12px; color: #FF2D7D; }
.cart-item-remove { position: absolute; top: 8px; right: 8px; width: 28px; height: 28px; background: rgba(255,45,125,0.2); border: 2px solid rgba(255,45,125,0.5); border-radius: 6px; color: #FF2D7D; cursor: pointer; font-size: 14px; display: flex; align-items: center; justify-content: center; opacity: 0; transition: 0.2s; }
.cart-item:hover .cart-item-remove { opacity: 1; }
.cart-item-remove:hover { background: #FF2D7D; color: white; }

.cart-loading { display: none; text-align: center; padding: 40px; }
.cart-loading.active { display: block; }
.cart-loading-spinner { width: 40px; height: 40px; border: 4px solid rgba(255,230,0,0.2); border-top-color: #FFE600; border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto 16px; }
@keyframes spin { to { transform: rotate(360deg); } }
.cart-loading-text { font-family: 'Press Start 2P'; font-size: 10px; color: rgba(255,255,255,0.6); }

.cart-error { display: none; background: rgba(255,45,125,0.2); border: 2px solid #FF2D7D; border-radius: 8px; padding: 12px; margin-bottom: 16px; font-family: 'Press Start 2P'; font-size: 9px; color: #FF2D7D; text-align: center; }
.cart-error.active { display: block; }

.cart-drawer-footer { padding: 24px; border-top: 4px solid rgba(255,230,0,0.2); background: linear-gradient(135deg, #252542, #1a1a2e); }
.cart-free-shipping { margin-bottom: 20px; }
.free-shipping-text { font-family: 'Press Start 2P'; font-size: 9px; color: rgba(255,255,255,0.6); margin-bottom: 12px; text-align: center; }
.free-shipping-bar { height: 16px; background: rgba(255,255,255,0.1); border: 3px solid #000; border-radius: 8px; overflow: hidden; box-shadow: 3px 3px 0 #000; }
.free-shipping-progress { height: 100%; background: linear-gradient(90deg, #FFE600, #FF2D7D); border-radius: 4px; transition: width 0.5s; }
.cart-subtotal { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
.cart-subtotal-label { font-family: 'Press Start 2P'; font-size: 10px; color: rgba(255,255,255,0.6); }
.cart-subtotal-price { font-family: 'Press Start 2P'; font-size: 14px; color: #FFE600; }
.cart-shipping { font-size: 11px; color: rgba(255,255,255,0.4); text-align: center; margin-bottom: 20px; padding-bottom: 20px; border-bottom: 2px solid rgba(255,255,255,0.1); }
.cart-checkout-btn { width: 100%; padding: 24px; background: #00D9FF; border: 5px solid #000; border-radius: 16px; font-family: 'Press Start 2P'; font-size: 14px; color: #000; cursor: pointer; box-shadow: 8px 8px 0 #000; margin-bottom: 16px; text-decoration: none; display: block; text-align: center; }
.cart-checkout-btn:hover { transform: translate(4px,4px); box-shadow: 4px 4px 0 #000; background: #FFE600; }
.cart-checkout-btn:disabled { background: #666; cursor: not-allowed; transform: none; box-shadow: 8px 8px 0 #000; }
.cart-continue-btn { width: 100%; padding: 16px; background: transparent; border: 3px solid rgba(255,255,255,0.3); border-radius: 12px; font-family: 'Press Start 2P'; font-size: 10px; color: rgba(255,255,255,0.6); cursor: pointer; }
.cart-continue-btn:hover { border-color: #FFE600; color: #FFE600; background: rgba(255,230,0,0.1); }

@media (max-width: 480px) { .cart-drawer { max-width: 100%; } .cart-item-image { width: 64px; height: 64px; } }
</style>

<div class="cart-drawer-overlay" id="cartOverlay" onclick="closeCartDrawer()"></div>
<div class="cart-drawer" id="cartDrawer">
  <div class="cart-drawer-header">
    <div class="cart-drawer-title">{{ 'cart.drawer_title' | t }} <span class="cart-item-count" id="cartItemCount">{{ 'cart.item_count' | t }}</span></div>
    <button class="cart-drawer-close" onclick="closeCartDrawer()">×</button>
  </div>
  
  <div class="cart-drawer-content" id="cartContent">
    <div class="cart-loading" id="cartLoading">
      <div class="cart-loading-spinner"></div>
      <div class="cart-loading-text">{{ 'general.loading' | t }}</div>
    </div>
    
    <div class="cart-error" id="cartError"></div>
    
    <div class="cart-empty" id="emptyCart">
      <div class="cart-empty-icon">{{ 'cart.drawer_empty_icon' | t }}</div>
      <div class="cart-empty-text">{{ 'cart.drawer_empty_title' | t }}</div>
      <button class="cart-empty-btn" onclick="closeCartDrawer()">{{ 'cart.drawer_empty_button' | t }}</button>
    </div>
    
    <div class="cart-items" id="cartItems" style="display:none"></div>
  </div>
  
  <div class="cart-drawer-footer" id="cartFooter" style="display:none">
    <div class="cart-free-shipping">
      <div class="free-shipping-text" id="freeShippingText">{{ 'cart.free_shipping_progress' | t: amount: '72.00' }}</div>
      <div class="free-shipping-bar"><div class="free-shipping-progress" id="freeShippingProgress" style="width:0%"></div></div>
    </div>
    <div class="cart-subtotal">
      <span class="cart-subtotal-label">{{ 'cart.drawer_subtotal' | t }}</span>
      <span class="cart-subtotal-price" id="cartSubtotal">$0.00</span>
    </div>
    <div class="cart-shipping">{{ 'cart.drawer_shipping_note' | t }}</div>
    <a href="/checkout" class="cart-checkout-btn" id="checkoutBtn">{{ 'cart.drawer_checkout' | t }}</a>
    <button class="cart-continue-btn" onclick="closeCartDrawer()">{{ 'cart.drawer_continue' | t }}</button>
  </div>
</div>

<script>
// Shopify AJAX Cart API 实现
const HOLY_CART = {
  async fetchCart() {
    try {
      const response = await fetch('/cart.js');
      if (!response.ok) throw new Error('Failed to fetch cart');
      return await response.json();
    } catch (error) {
      console.error('Cart fetch error:', error);
      throw error;
    }
  },

  async addItem(variantId, quantity = 1, properties = {}) {
    try {
      const data = {
        id: variantId,
        quantity: quantity,
        properties: properties
      };
      
      const response = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });
      
      if (!response.ok) {
        const error = await response.json();
        throw new Error(error.description || 'Failed to add item');
      }
      
      return await response.json();
    } catch (error) {
      console.error('Add to cart error:', error);
      throw error;
    }
  },

  async updateItem(line, quantity) {
    try {
      const response = await fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ line: line, quantity: quantity })
      });
      
      if (!response.ok) throw new Error('Failed to update item');
      return await response.json();
    } catch (error) {
      console.error('Update item error:', error);
      throw error;
    }
  },

  async removeItem(line) {
    return this.updateItem(line, 0);
  },

  async clear() {
    try {
      const response = await fetch('/cart/clear.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      });
      
      if (!response.ok) throw new Error('Failed to clear cart');
      return await response.json();
    } catch (error) {
      console.error('Clear cart error:', error);
      throw error;
    }
  }
};

let cartData = { items: [], item_count: 0, total_price: 0 };

function openCartDrawer() {
  document.getElementById('cartOverlay').classList.add('active');
  document.getElementById('cartDrawer').classList.add('active');
  document.body.style.overflow = 'hidden';
  loadCart();
}

function closeCartDrawer() {
  document.getElementById('cartOverlay').classList.remove('active');
  document.getElementById('cartDrawer').classList.remove('active');
  document.body.style.overflow = '';
}

function showLoading() {
  document.getElementById('cartLoading').classList.add('active');
  document.getElementById('emptyCart').style.display = 'none';
  document.getElementById('cartItems').style.display = 'none';
  document.getElementById('cartFooter').style.display = 'none';
}

function hideLoading() {
  document.getElementById('cartLoading').classList.remove('active');
}

function showError(message) {
  const errorEl = document.getElementById('cartError');
  errorEl.textContent = message;
  errorEl.classList.add('active');
  setTimeout(() => errorEl.classList.remove('active'), 5000);
}

async function loadCart() {
  showLoading();
  try {
    cartData = await HOLY_CART.fetchCart();
    updateCartUI();
  } catch (error) {
    showError("{{ 'errors.cart_load_failed' | t }}");
  } finally {
    hideLoading();
  }
}

function updateCartUI() {
  const itemsContainer = document.getElementById('cartItems');
  const emptyCart = document.getElementById('emptyCart');
  const footer = document.getElementById('cartFooter');
  const countEl = document.getElementById('cartItemCount');
  const subtotalEl = document.getElementById('cartSubtotal');
  
  const totalItems = cartData.item_count;
  const totalPrice = cartData.total_price / 100;
  
  let itemCountText;
  if (totalItems === 0) {
    itemCountText = "{{ 'cart.item_count' | t }}";
  } else if (totalItems === 1) {
    itemCountText = "{{ 'cart.item_count_one' | t }}";
  } else {
    itemCountText = "{{ 'cart.item_count_other' | t }}".replace('{{ count }}', totalItems);
  }
  countEl.textContent = itemCountText;
  subtotalEl.textContent = formatMoney(cartData.total_price);
  
  updateAllCartBadges(totalItems);
  
  const threshold = 7200;
  const progress = Math.min((cartData.total_price / threshold) * 100, 100);
  const remaining = (threshold - cartData.total_price) / 100;
  document.getElementById('freeShippingProgress').style.width = progress + '%';
  
  if (remaining > 0) {
    document.getElementById('freeShippingText').textContent = "{{ 'cart.free_shipping_progress' | t }}".replace('{{ amount }}', remaining.toFixed(2));
  } else {
    document.getElementById('freeShippingText').textContent = "{{ 'cart.free_shipping_achieved' | t }}";
  }
  
  if (cartData.items.length === 0) {
    emptyCart.style.display = 'flex';
    itemsContainer.style.display = 'none';
    footer.style.display = 'none';
  } else {
    emptyCart.style.display = 'none';
    itemsContainer.style.display = 'flex';
    footer.style.display = 'block';
    
    itemsContainer.innerHTML = cartData.items.map((item, index) => {
      const itemPrice = item.final_line_price / 100;
      const variantTitle = item.variant_title ? `Color: ${item.variant_title}` : '';
      const imageUrl = item.image || '';
      const emoji = getProductEmoji(item.product_type, item.title);
      
      return `
        <div class="cart-item" data-line="${index + 1}">
          <div class="cart-item-image">
            ${imageUrl ? `<img src="${imageUrl}" alt="${escapeHtml(item.title)}">` : `<div class="item-emoji">${emoji}</div>`}
          </div>
          <div class="cart-item-details">
            <div>
              <div class="cart-item-title">${escapeHtml(item.title)}</div>
              <div class="cart-item-variant">${escapeHtml(variantTitle)}</div>
            </div>
            <div class="cart-item-bottom">
              <div class="quantity-selector">
                <button class="quantity-btn" onclick="updateCartQty(${index + 1}, ${item.quantity - 1})" ${item.quantity <= 1 ? 'disabled' : ''}>−</button>
                <input type="text" class="quantity-input" value="${item.quantity}" readonly>
                <button class="quantity-btn" onclick="updateCartQty(${index + 1}, ${item.quantity + 1})">+</button>
              </div>
              <div class="cart-item-price">${formatMoney(item.final_line_price)}</div>
            </div>
          </div>
          <button class="cart-item-remove" onclick="removeCartItem(${index + 1})">×</button>
        </div>
      `;
    }).join('');
  }
}

async function addToCart(product) {
  try {
    if (product.variantId) {
      await HOLY_CART.addItem(product.variantId, product.quantity || 1);
    } else if (product.id) {
      await HOLY_CART.addItem(product.id, product.quantity || 1);
    }
    
    animateCartIcon();
    
    if (document.getElementById('cartDrawer').classList.contains('active')) {
      await loadCart();
    }
    
    const cart = await HOLY_CART.fetchCart();
    updateAllCartBadges(cart.item_count);
    
    return true;
  } catch (error) {
    showError("{{ 'errors.cart_add_failed' | t }}");
    return false;
  }
}

async function updateCartQty(line, quantity) {
  if (quantity < 1) return;
  
  try {
    cartData = await HOLY_CART.updateItem(line, quantity);
    updateCartUI();
  } catch (error) {
    showError("{{ 'errors.cart_update_failed' | t }}");
  }
}

async function removeCartItem(line) {
  try {
    cartData = await HOLY_CART.removeItem(line);
    updateCartUI();
  } catch (error) {
    showError("{{ 'errors.cart_remove_failed' | t }}");
  }
}

function formatMoney(cents) {
  const amount = cents / 100;
  return '$' + amount.toFixed(2);
}

function getProductEmoji(type, title) {
  const typeEmojis = {
    'keychain': '🔑',
    'magnet': '🧲',
    'diy': '🎨'
  };
  
  const titleEmojis = {
    'mario': '🍄',
    'mushroom': '🍄',
    'pikachu': '⚡',
    'pokemon': '⚡',
    'controller': '🎮',
    'star': '⭐',
    'ghost': '👻',
    'pacman': '👻',
    'pokeball': '🔴',
    'space': '👾',
    'tetris': '🧱',
    'sonic': '💍',
    'heart': '❤️',
    'diamond': '⛏️',
    'minecraft': '⛏️',
    'food': '🍕',
    'yoshi': '🥚',
    'cartridge': '🎲',
    'coin': '🪙',
    'pet': '🐱'
  };
  
  const lowerTitle = title.toLowerCase();
  for (const [key, emoji] of Object.entries(titleEmojis)) {
    if (lowerTitle.includes(key)) return emoji;
  }
  
  return typeEmojis[type?.toLowerCase()] || '🎮';
}

function escapeHtml(text) {
  if (!text) return '';
  const div = document.createElement('div');
  div.textContent = text;
  return div.innerHTML;
}

function updateAllCartBadges(count) {
  const badges = document.querySelectorAll('.cart-badge, #cartBadge, #cartBadgeMobile');
  badges.forEach(badge => {
    badge.textContent = count;
    if (count > 0) {
      badge.classList.remove('hidden');
    } else {
      badge.classList.add('hidden');
    }
  });
}

function animateCartIcon() {
  const cartIcons = document.querySelectorAll('.navbar-cart');
  cartIcons.forEach(icon => {
    icon.style.animation = 'none';
    icon.offsetHeight;
    icon.style.animation = 'cartShake 0.5s ease';
  });
}

function checkout() {
  if (cartData.items.length === 0) {
    showError("{{ 'errors.cart_empty' | t }}");
    return;
  }
  window.location.href = '/checkout';
}

function openCart() {
  openCartDrawer();
}

window.openCartDrawer = openCartDrawer;
window.closeCartDrawer = closeCartDrawer;
window.openCart = openCart;
window.addToCart = addToCart;
window.updateAllCartBadges = updateAllCartBadges;
window.checkout = checkout;

document.addEventListener('DOMContentLoaded', async () => {
  try {
    const cart = await HOLY_CART.fetchCart();
    updateAllCartBadges(cart.item_count);
  } catch (error) {
    console.error('Failed to initialize cart:', error);
  }
});

document.addEventListener('cart:updated', async () => {
  if (document.getElementById('cartDrawer').classList.contains('active')) {
    await loadCart();
  } else {
    const cart = await HOLY_CART.fetchCart();
    updateAllCartBadges(cart.item_count);
  }
});
</script>
