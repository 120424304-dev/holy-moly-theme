<style>
/* ===== 导航栏样式（已包含 HOMESTEAD） ===== */
.navbar-menu {
  display: flex;
  gap: 8px;
  list-style: none;
  margin: 0;
  padding: 0;
}

.navbar-link {
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  color: rgba(255,255,255,0.8);
  text-decoration: none;
  padding: 12px 14px;
  position: relative;
  transition: all 0.3s;
  white-space: nowrap;
}

.navbar-link:hover,
.navbar-link.active {
  color: #FFE600;
}

/* 响应式：小屏幕缩小字体 */
@media (max-width: 1100px) {
  .navbar-link {
    font-size: 9px;
    padding: 12px 10px;
  }
}

@media (max-width: 900px) {
  .navbar-menu {
    display: none;
  }
  .hamburger {
    display: flex;
  }
}

/* ===== 无限循环滑动区域样式 ===== */
.carousel-container {
  position: relative;
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 20px;
  display: flex;
  align-items: center;
  gap: 16px;
}

.carousel-viewport {
  flex: 1;
  overflow: hidden;
  position: relative;
  cursor: grab;
  user-select: none;
  border-radius: 20px;
}

.carousel-viewport:active {
  cursor: grabbing;
}

.carousel-track {
  display: flex;
  gap: 20px;
  transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  will-change: transform;
}

.carousel-card {
  flex: 0 0 calc(25% - 15px);
  min-width: 280px;
  max-width: 320px;
  background: #1a1a2e;
  border: 4px solid rgba(255,255,255,0.1);
  border-radius: 20px;
  overflow: hidden;
  position: relative;
  transition: all 0.3s;
}

.carousel-card:hover {
  border-color: #FFE600;
  transform: translateY(-10px);
  box-shadow: 0 20px 40px rgba(255, 230, 0, 0.2);
}

.carousel-card-inner {
  position: relative;
  cursor: pointer;
}

.carousel-badge {
  position: absolute;
  top: 12px; left: 12px;
  font-family: 'Press Start 2P', monospace;
  font-size: 8px;
  padding: 6px 12px;
  background: #FF2D7D;
  border: 3px solid #000;
  border-radius: 6px;
  color: white;
  box-shadow: 3px 3px 0 rgba(0,0,0,0.3);
  z-index: 5;
  animation: badgePulse 2s infinite;
}

@keyframes badgePulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.carousel-image {
  height: 200px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.carousel-emoji {
  font-size: 90px;
  animation: floatEmoji 3s ease-in-out infinite;
  filter: drop-shadow(0 10px 20px rgba(0,0,0,0.3));
}

@keyframes floatEmoji {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-15px) rotate(5deg); }
}

.carousel-card:hover .carousel-emoji {
  animation: shake 0.5s ease;
}

@keyframes shake {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(-10deg); }
  75% { transform: rotate(10deg); }
}

.carousel-info {
  padding: 20px;
  background: white;
}

.carousel-meta {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10px;
  align-items: center;
}

.carousel-type {
  font-family: 'Press Start 2P', monospace;
  font-size: 8px;
  color: #9D4EDD;
  background: rgba(157,78,221,0.1);
  padding: 4px 8px;
  border-radius: 4px;
}

.carousel-price {
  font-family: 'Press Start 2P', monospace;
  font-size: 14px;
  color: #FF2D7D;
}

.carousel-name {
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  color: #000;
  line-height: 1.6;
  margin-bottom: 12px;
  min-height: 32px;
}

.carousel-add-btn {
  width: calc(100% - 40px);
  margin: 0 20px 20px;
  padding: 14px;
  background: #FFE600;
  border: 4px solid #000;
  border-radius: 12px;
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  color: #000;
  cursor: pointer;
  box-shadow: 4px 4px 0 #000;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

.carousel-add-btn:hover {
  transform: translate(2px, 2px);
  box-shadow: 2px 2px 0 #000;
  background: #00D9FF;
}

.carousel-nav {
  width: 50px;
  height: 50px;
  background: #FFE600;
  border: 4px solid #000;
  border-radius: 50%;
  font-family: 'Press Start 2P', monospace;
  font-size: 16px;
  color: #000;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 4px 4px 0 #000;
  transition: all 0.2s;
  flex-shrink: 0;
  z-index: 10;
}

.carousel-nav:hover {
  transform: scale(1.1);
  background: #FF2D7D;
  color: white;
}

.carousel-nav:active {
  transform: scale(0.95);
  box-shadow: 2px 2px 0 #000;
}

.go-to-shop-container {
  text-align: center;
  margin-top: 50px;
}

.go-to-shop-btn {
  display: inline-flex;
  align-items: center;
  gap: 16px;
  font-family: 'Press Start 2P', monospace;
  font-size: 14px;
  padding: 28px 48px;
  background: linear-gradient(135deg, #FFE600, #FFD000);
  border: 6px solid #000;
  border-radius: 20px;
  color: #000;
  text-decoration: none;
  box-shadow: 8px 8px 0 #000, 0 0 40px rgba(255, 230, 0, 0.3);
  transition: all 0.3s;
}

.go-to-shop-btn:hover {
  transform: translate(4px, 4px);
  box-shadow: 4px 4px 0 #000;
  background: linear-gradient(135deg, #FF2D7D, #FF6B9D);
  color: white;
}

.go-to-shop-btn span:first-child { font-size: 24px; }
.go-to-shop-btn span:last-child { font-size: 20px; transition: transform 0.3s; }
.go-to-shop-btn:hover span:last-child { transform: translateX(8px); }

@media (max-width: 1200px) {
  .carousel-card { flex: 0 0 calc(33.333% - 14px); min-width: 260px; }
}

@media (max-width: 900px) {
  .carousel-card { flex: 0 0 calc(50% - 10px); min-width: 220px; }
  .carousel-image { height: 170px; }
  .carousel-emoji { font-size: 70px; }
}

@media (max-width: 600px) {
  .carousel-container { padding: 0 10px; gap: 10px; }
  .carousel-card { flex: 0 0 calc(50% - 8px); min-width: 160px; }
  .carousel-nav { width: 40px; height: 40px; font-size: 12px; }
  .carousel-image { height: 140px; }
  .carousel-emoji { font-size: 50px; }
  .carousel-name { font-size: 8px; min-height: 26px; }
  .carousel-add-btn { font-size: 8px; padding: 10px; margin: 0 10px 10px; width: calc(100% - 20px); }
  .carousel-info { padding: 12px; }
  .go-to-shop-btn { font-size: 11px; padding: 20px 28px; }
}
</style>

<script>
var pixelGrid = document.getElementById('pixelGrid');
var activePixels = [0,1,2,3, 8,9,10,11, 16,17,18,19, 24,25,26,27, 33,34, 41,42, 49,50, 56,57,58,59];
if (pixelGrid) {
  for (var i = 0; i < 64; i++) {
    var pixel = document.createElement('div');
    pixel.className = 'pixel-dot';
    if (activePixels.indexOf(i) !== -1) pixel.classList.add('active');
    pixel.style.animationDelay = (Math.random() * 1.5) + 's';
    pixelGrid.appendChild(pixel);
  }
}

setTimeout(function() {
  var loader = document.getElementById('loader');
  var intro = document.getElementById('intro');
  var mainSite = document.getElementById('main-site');
  if (loader) loader.classList.add('hidden');
  setTimeout(function() {
    if (intro) intro.classList.add('active');
    setTimeout(function() {
      if (intro) intro.classList.remove('active');
      if (mainSite) mainSite.classList.add('active');
      initInfiniteCarousel();
    }, 800);
  }, 500);
}, 2500);

function toggleMobileMenu() {
  var menu = document.getElementById('mobileMenu');
  var hamburger = document.getElementById('hamburger');
  if (menu && hamburger) {
    menu.classList.toggle('active');
    hamburger.classList.toggle('active');
  }
}

var cursor = document.getElementById('cursor');
var cursorDot = document.getElementById('cursorDot');
if (cursor && cursorDot) {
  document.addEventListener('mousemove', function(e) {
    cursor.style.left = (e.clientX - 20) + 'px';
    cursor.style.top = (e.clientY - 20) + 'px';
    cursorDot.style.left = (e.clientX - 4) + 'px';
    cursorDot.style.top = (e.clientY - 4) + 'px';
  });
  var hoverElements = document.querySelectorAll('a, button, .carousel-card, .feature-card, .social-icon');
  hoverElements.forEach(function(el) {
    el.addEventListener('mouseenter', function() { cursor.classList.add('hover'); });
    el.addEventListener('mouseleave', function() { cursor.classList.remove('hover'); });
  });
}

document.addEventListener('click', function(e) {
  var ripple = document.createElement('div');
  ripple.className = 'click-ripple';
  ripple.style.left = (e.clientX - 10) + 'px';
  ripple.style.top = (e.clientY - 10) + 'px';
  document.body.appendChild(ripple);
  setTimeout(function() { ripple.remove(); }, 600);
});

var mascot = document.getElementById('mascot');
var mascotContainer = document.getElementById('mascotContainer');
if (mascot && mascotContainer) {
  mascotContainer.addEventListener('mousemove', function(e) {
    var rect = mascotContainer.getBoundingClientRect();
    var x = e.clientX - rect.left;
    var y = e.clientY - rect.top;
    var centerX = rect.width / 2;
    var centerY = rect.height / 2;
    var rotateX = (y - centerY) / 10;
    var rotateY = (centerX - x) / 10;
    mascot.style.transform = 'rotateX(' + rotateX + 'deg) rotateY(' + rotateY + 'deg)';
  });
  mascotContainer.addEventListener('mouseleave', function() { mascot.style.transform = ''; });
}

function explodeBeads(e) {
  for (var i = 0; i < 8; i++) {
    setTimeout(function() {
      var x = e.clientX + (Math.random() - 0.5) * 100;
      var y = e.clientY + (Math.random() - 0.5) * 100;
      var ripple = document.createElement('div');
      ripple.className = 'click-ripple';
      ripple.style.left = (x - 10) + 'px';
      ripple.style.top = (y - 10) + 'px';
      document.body.appendChild(ripple);
      setTimeout(function() { ripple.remove(); }, 600);
    }, i * 50);
  }
}

function cardClick(card) {
  card.style.transform = 'scale(0.95)';
  setTimeout(function() { card.style.transform = ''; }, 200);
}

var cartCount = 0;
function addCarouselToCart(id, name, price, emoji) {
  var btn = event.target;
  var original = btn.innerHTML;
  
  btn.innerHTML = '✓ ADDED!';
  btn.style.background = '#00FF00';
  
  cartCount++;
  var badge = document.getElementById('cartBadge');
  var badgeMobile = document.getElementById('cartBadgeMobile');
  if (badge) { badge.textContent = cartCount; badge.classList.remove('hidden'); }
  if (badgeMobile) { badgeMobile.textContent = cartCount; badgeMobile.classList.remove('hidden'); }
  
  if (typeof window.addToCart === 'function') {
    window.addToCart({ id: id, name: name, price: price, emoji: emoji, variant: 'Color: Default' });
  }
  
  setTimeout(function() {
    btn.innerHTML = original;
    btn.style.background = '';
  }, 1500);
}

function socialClick(icon) {
  icon.style.transform = 'rotate(360deg) scale(1.2)';
  setTimeout(function() { icon.style.transform = ''; }, 500);
}

function scrollToSection(id) {
  var element = document.getElementById(id);
  if (element) element.scrollIntoView({ behavior: 'smooth' });
}

function smoothScroll(e, id) {
  e.preventDefault();
  scrollToSection(id);
}

function scrollToTop(e) {
  e.preventDefault();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function openCart() {
  if (typeof window.openCartDrawer === 'function') {
    window.openCartDrawer();
  } else {
    alert('🛒 购物车里有 ' + cartCount + ' 件商品');
  }
}

var currentIndex = 0;
var totalItems = 6;
var visibleItems = 4;
var autoPlayInterval;

function initInfiniteCarousel() {
  updateVisibleItems();
  setupCarouselEvents();
  startAutoPlay();
  
  window.addEventListener('resize', function() {
    var newVisible = window.innerWidth <= 600 ? 2 : window.innerWidth <= 900 ? 2 : window.innerWidth <= 1200 ? 3 : 4;
    if (newVisible !== visibleItems) {
      visibleItems = newVisible;
      goToSlide(currentIndex, false);
    }
  });
}

function updateVisibleItems() {
  visibleItems = window.innerWidth <= 600 ? 2 : window.innerWidth <= 900 ? 2 : window.innerWidth <= 1200 ? 3 : 4;
}

function setupCarouselEvents() {
  var viewport = document.querySelector('.carousel-viewport');
  var track = document.getElementById('carouselTrack');
  if (!viewport || !track) return;
  
  var isDragging = false;
  var startPos = 0;
  
  viewport.addEventListener('mousedown', function(e) {
    isDragging = true;
    startPos = e.pageX;
    viewport.style.cursor = 'grabbing';
    track.style.transition = 'none';
    stopAutoPlay();
  });
  
  viewport.addEventListener('mousemove', function(e) {
    if (!isDragging) return;
    var diff = e.pageX - startPos;
    var itemWidth = track.children[0].offsetWidth + 20;
    var offset = -(currentIndex * itemWidth) + diff;
    track.style.transform = 'translateX(' + offset + 'px)';
  });
  
  viewport.addEventListener('mouseup', function(e) {
    if (!isDragging) return;
    isDragging = false;
    viewport.style.cursor = 'grab';
    track.style.transition = 'transform 0.5s cubic-bezier(0.4, 0, 0.2, 1)';
    
    var diff = e.pageX - startPos;
    if (diff < -50) moveCarousel(1);
    else if (diff > 50) moveCarousel(-1);
    else goToSlide(currentIndex);
    
    startAutoPlay();
  });
  
  viewport.addEventListener('mouseleave', function() {
    if (isDragging) {
      isDragging = false;
      viewport.style.cursor = 'grab';
      track.style.transition = 'transform 0.5s cubic-bezier(0.4, 0, 0.2, 1)';
      goToSlide(currentIndex);
      startAutoPlay();
    }
  });
  
  viewport.addEventListener('touchstart', function(e) {
    startPos = e.touches[0].clientX;
    track.style.transition = 'none';
    stopAutoPlay();
  }, {passive: true});
  
  viewport.addEventListener('touchmove', function(e) {
    var diff = e.touches[0].clientX - startPos;
    var itemWidth = track.children[0].offsetWidth + 20;
    var offset = -(currentIndex * itemWidth) + diff;
    track.style.transform = 'translateX(' + offset + 'px)';
  }, {passive: true});
  
  viewport.addEventListener('touchend', function(e) {
    var diff = e.changedTouches[0].clientX - startPos;
    track.style.transition = 'transform 0.5s cubic-bezier(0.4, 0, 0.2, 1)';
    if (diff < -50) moveCarousel(1);
    else if (diff > 50) moveCarousel(-1);
    else goToSlide(currentIndex);
    startAutoPlay();
  });
  
  viewport.addEventListener('selectstart', function(e) { e.preventDefault(); });
  viewport.addEventListener('mouseenter', stopAutoPlay);
  viewport.addEventListener('mouseleave', startAutoPlay);
}

function moveCarousel(direction) {
  currentIndex += direction;
  
  if (currentIndex >= totalItems) currentIndex = 0;
  if (currentIndex < 0) currentIndex = totalItems - 1;
  
  goToSlide(currentIndex);
}

function goToSlide(index, animate) {
  if (animate === undefined) animate = true;
  
  var track = document.getElementById('carouselTrack');
  if (!track) return;
  
  var itemWidth = track.children[0].offsetWidth + 20;
  var offset = -(index * itemWidth);
  
  if (animate) {
    track.style.transition = 'transform 0.5s cubic-bezier(0.4, 0, 0.2, 1)';
  } else {
    track.style.transition = 'none';
  }
  
  track.style.transform = 'translateX(' + offset + 'px)';
}

function startAutoPlay() {
  stopAutoPlay();
  autoPlayInterval = setInterval(function() {
    moveCarousel(1);
  }, 4000);
}

function stopAutoPlay() {
  if (autoPlayInterval) clearInterval(autoPlayInterval);
}

var observerOptions = { threshold: 0.1, rootMargin: '0px 0px -50px 0px' };
var observer = new IntersectionObserver(function(entries) {
  entries.forEach(function(entry) {
    if (entry.isIntersecting) {
      entry.target.style.opacity = '1';
      entry.target.style.transform = 'translateY(0)';
    }
  });
}, observerOptions);

document.querySelectorAll('.feature-card').forEach(function(el) {
  el.style.opacity = '0';
  el.style.transform = 'translateY(30px)';
  el.style.transition = 'opacity 0.6s, transform 0.6s';
  observer.observe(el);
});

var navbar = document.getElementById('navbar');
if (navbar) {
  window.addEventListener('scroll', function() {
    navbar.classList.toggle('scrolled', window.scrollY > 50);
  });
}

var sections = ['products', 'features', 'custom', 'contact'];
var navLinks = document.querySelectorAll('.navbar-link');
window.addEventListener('scroll', function() {
  var current = '';
  var navbarHeight = navbar ? navbar.offsetHeight : 0;
  sections.forEach(function(sectionId) {
    var section = document.getElementById(sectionId);
    if (section) {
      var sectionTop = section.offsetTop - navbarHeight - 100;
      if (window.scrollY >= sectionTop) current = sectionId;
    }
  });
  navLinks.forEach(function(link) {
    link.classList.remove('active');
    if (link.getAttribute('href') === '#' + current) link.classList.add('active');
  });
});

if ('ontouchstart' in window) {
  if (cursor) cursor.style.display = 'none';
  if (cursorDot) cursorDot.style.display = 'none';
}
</script>
