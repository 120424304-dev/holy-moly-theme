<style>
/* ===== 滑动展示区域样式 ===== */
.carousel-container {
  position: relative;
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 80px;
  display: flex;
  align-items: center;
  gap: 20px;
}

.carousel-wrapper {
  flex: 1;
  overflow: hidden;
  position: relative;
}

.carousel-track {
  display: flex;
  gap: 24px;
  transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

/* 滑动卡片 */
.carousel-card {
  flex: 0 0 calc(25% - 18px);
  min-width: 260px;
  background: #1a1a2e;
  border: 4px solid rgba(255,255,255,0.1);
  border-radius: 20px;
  overflow: hidden;
  position: relative;
  transition: all 0.3s;
  cursor: pointer;
}

.carousel-card:hover {
  border-color: #FFE600;
  transform: translateY(-10px);
  box-shadow: 0 20px 40px rgba(255, 230, 0, 0.2);
}

.carousel-card-inner { position: relative; }

.carousel-badge {
  position: absolute;
  top: 16px; left: 16px;
  font-family: 'Press Start 2P', monospace;
  font-size: 9px;
  padding: 8px 14px;
  background: #FF2D7D;
  border: 3px solid #000;
  border-radius: 6px;
  color: white;
  box-shadow: 3px 3px 0 rgba(0,0,0,0.3);
  z-index: 5;
  animation: badgePulse 2s infinite;
}

@keyframes badgePulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.carousel-image {
  height: 180px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.carousel-emoji {
  font-size: 80px;
  animation: floatEmoji 3s ease-in-out infinite;
  filter: drop-shadow(0 10px 20px rgba(0,0,0,0.3));
}

@keyframes floatEmoji {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  50% { transform: translateY(-15px) rotate(5deg); }
}

.carousel-card:hover .carousel-emoji {
  animation: shake 0.5s ease;
}

@keyframes shake {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(-10deg); }
  75% { transform: rotate(10deg); }
}

.carousel-info {
  padding: 20px;
  background: white;
}

.carousel-meta {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10px;
  align-items: center;
}

.carousel-type {
  font-family: 'Press Start 2P', monospace;
  font-size: 8px;
  color: #9D4EDD;
  background: rgba(157,78,221,0.1);
  padding: 4px 8px;
  border-radius: 4px;
}

.carousel-price {
  font-family: 'Press Start 2P', monospace;
  font-size: 14px;
  color: #FF2D7D;
}

.carousel-name {
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  color: #000;
  line-height: 1.6;
  margin-bottom: 16px;
  min-height: 32px;
}

.carousel-add-btn {
  width: 100%;
  padding: 14px;
  background: #FFE600;
  border: 4px solid #000;
  border-radius: 12px;
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  color: #000;
  cursor: pointer;
  box-shadow: 4px 4px 0 #000;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

.carousel-add-btn:hover {
  transform: translate(2px, 2px);
  box-shadow: 2px 2px 0 #000;
  background: #00D9FF;
}

/* 导航箭头 */
.carousel-nav {
  width: 56px;
  height: 56px;
  background: #FFE600;
  border: 4px solid #000;
  border-radius: 50%;
  font-family: 'Press Start 2P', monospace;
  font-size: 18px;
  color: #000;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 4px 4px 0 #000;
  transition: all 0.2s;
  flex-shrink: 0;
}

.carousel-nav:hover {
  transform: scale(1.1);
  background: #FF2D7D;
  color: white;
}

.carousel-nav:active {
  transform: scale(0.95);
  box-shadow: 2px 2px 0 #000;
}

/* 指示点 */
.carousel-dots {
  display: flex;
  justify-content: center;
  gap: 12px;
  margin-top: 30px;
}

.carousel-dot {
  width: 14px;
  height: 14px;
  background: rgba(255,255,255,0.2);
  border: 3px solid rgba(255,255,255,0.3);
  border-radius: 50%;
  cursor: pointer;
  transition: all 0.3s;
}

.carousel-dot.active {
  background: #FFE600;
  border-color: #000;
  box-shadow: 0 0 15px #FFE600;
  transform: scale(1.3);
}

/* CTA 按钮 */
.go-to-shop-container {
  text-align: center;
  margin-top: 50px;
}

.go-to-shop-btn {
  display: inline-flex;
  align-items: center;
  gap: 16px;
  font-family: 'Press Start 2P', monospace;
  font-size: 14px;
  padding: 28px 48px;
  background: linear-gradient(135deg, #FFE600, #FFD000);
  border: 6px solid #000;
  border-radius: 20px;
  color: #000;
  text-decoration: none;
  box-shadow: 8px 8px 0 #000, 0 0 40px rgba(255, 230, 0, 0.3);
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.go-to-shop-btn:hover {
  transform: translate(4px, 4px);
  box-shadow: 4px 4px 0 #000;
  background: linear-gradient(135deg, #FF2D7D, #FF6B9D);
  color: white;
}

.go-to-shop-btn span:first-child {
  font-size: 24px;
}

.go-to-shop-btn span:last-child {
  font-size: 20px;
  transition: transform 0.3s;
}

.go-to-shop-btn:hover span:last-child {
  transform: translateX(8px);
}

/* 响应式 */
@media (max-width: 1024px) {
  .carousel-card { flex: 0 0 calc(33.333% - 16px); }
  .carousel-container { padding: 0 60px; }
}

@media (max-width: 768px) {
  .carousel-card { flex: 0 0 calc(50% - 12px); min-width: 160px; }
  .carousel-container { padding: 0 20px; }
  .carousel-nav { width: 44px; height: 44px; font-size: 14px; }
  .carousel-image { height: 140px; }
  .carousel-emoji { font-size: 50px; }
  .carousel-name { font-size: 8px; min-height: 26px; }
  .carousel-add-btn { font-size: 8px; padding: 10px; }
  .go-to-shop-btn { font-size: 11px; padding: 20px 32px; }
}

@media (max-width: 480px) {
  .carousel-card { flex: 0 0 calc(50% - 8px); }
}
</style>

<script>
// Loading Animation
var pixelGrid = document.getElementById('pixelGrid');
var activePixels = [0,1,2,3, 8,9,10,11, 16,17,18,19, 24,25,26,27, 33,34, 41,42, 49,50, 56,57,58,59];
if (pixelGrid) {
  for (var i = 0; i < 64; i++) {
    var pixel = document.createElement('div');
    pixel.className = 'pixel-dot';
    if (activePixels.indexOf(i) !== -1) {
      pixel.classList.add('active');
    }
    pixel.style.animationDelay = (Math.random() * 1.5) + 's';
    pixelGrid.appendChild(pixel);
  }
}

setTimeout(function() {
  var loader = document.getElementById('loader');
  var intro = document.getElementById('intro');
  var mainSite = document.getElementById('main-site');
  if (loader) loader.classList.add('hidden');
  setTimeout(function() {
    if (intro) intro.classList.add('active');
    setTimeout(function() {
      if (intro) intro.classList.remove('active');
      if (mainSite) mainSite.classList.add('active');
      // 初始化滑动组件
      initCarousel();
    }, 800);
  }, 500);
}, 2500);

// Mobile Menu
function toggleMobileMenu() {
  var menu = document.getElementById('mobileMenu');
  var hamburger = document.getElementById('hamburger');
  if (menu && hamburger) {
    menu.classList.toggle('active');
    hamburger.classList.toggle('active');
  }
}

// Custom Cursor
var cursor = document.getElementById('cursor');
var cursorDot = document.getElementById('cursorDot');
if (cursor && cursorDot) {
  document.addEventListener('mousemove', function(e) {
    cursor.style.left = (e.clientX - 20) + 'px';
    cursor.style.top = (e.clientY - 20) + 'px';
    cursorDot.style.left = (e.clientX - 4) + 'px';
    cursorDot.style.top = (e.clientY - 4) + 'px';
  });
  var hoverElements = document.querySelectorAll('a, button, .carousel-card, .feature-card, .social-icon');
  hoverElements.forEach(function(el) {
    el.addEventListener('mouseenter', function() {
      cursor.classList.add('hover');
    });
    el.addEventListener('mouseleave', function() {
      cursor.classList.remove('hover');
    });
  });
}

// Click Ripple
document.addEventListener('click', function(e) {
  var ripple = document.createElement('div');
  ripple.className = 'click-ripple';
  ripple.style.left = (e.clientX - 10) + 'px';
  ripple.style.top = (e.clientY - 10) + 'px';
  document.body.appendChild(ripple);
  setTimeout(function() {
    ripple.remove();
  }, 600);
});

// Mascot Tilt
var mascot = document.getElementById('mascot');
var mascotContainer = document.getElementById('mascotContainer');
if (mascot && mascotContainer) {
  mascotContainer.addEventListener('mousemove', function(e) {
    var rect = mascotContainer.getBoundingClientRect();
    var x = e.clientX - rect.left;
    var y = e.clientY - rect.top;
    var centerX = rect.width / 2;
    var centerY = rect.height / 2;
    var rotateX = (y - centerY) / 10;
    var rotateY = (centerX - x) / 10;
    mascot.style.transform = 'rotateX(' + rotateX + 'deg) rotateY(' + rotateY + 'deg)';
  });
  mascotContainer.addEventListener('mouseleave', function() {
    mascot.style.transform = '';
  });
}

// Interactions
function explodeBeads(e) {
  for (var i = 0; i < 8; i++) {
    setTimeout(function() {
      var x = e.clientX + (Math.random() - 0.5) * 100;
      var y = e.clientY + (Math.random() - 0.5) * 100;
      var ripple = document.createElement('div');
      ripple.className = 'click-ripple';
      ripple.style.left = (x - 10) + 'px';
      ripple.style.top = (y - 10) + 'px';
      document.body.appendChild(ripple);
      setTimeout(function() {
        ripple.remove();
      }, 600);
    }, i * 50);
  }
}

function cardClick(card) {
  card.style.transform = 'scale(0.95)';
  setTimeout(function() {
    card.style.transform = '';
  }, 200);
}

var cartCount = 0;
