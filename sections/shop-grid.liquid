<!-- 快速预览模态框 -->
<div class="quick-view-modal" id="quickViewModal">
    <div class="modal-overlay" onclick="closeQuickView()"></div>
    <div class="modal-content">
        <button class="modal-close" onclick="closeQuickView()">×</button>
        <div class="modal-body">
            <div class="modal-image" id="modalImage">🎮</div>
            <h2 class="modal-title" id="modalTitle">Product Name</h2>
            <div class="modal-price" id="modalPrice">$00.00</div>
            <p class="modal-desc">Handcrafted pixel art made with 1000+ beads. Each piece is unique and made with love. Perfect for gamers, collectors, and pixel art enthusiasts!</p>
            <button class="modal-add-btn" onclick="addToCartFromModal()">🛒 ADD TO CART</button>
        </div>
    </div>
</div>

<script>
// ========== 修复后的JavaScript ==========
let cartCount = 0;
let currentModalProduct = {};

// 移动端菜单
function toggleMobileMenu() {
    document.getElementById('mobileMenu').classList.toggle('active');
}

// 下拉菜单
function toggleDropdown() {
    const dropdown = document.getElementById('sortDropdown');
    dropdown.classList.toggle('open');
    
    if (dropdown.classList.contains('open')) {
        setTimeout(() => document.addEventListener('click', closeDropdownOutside), 10);
    }
}

function closeDropdownOutside(e) {
    const dropdown = document.getElementById('sortDropdown');
    if (!dropdown.contains(e.target)) {
        dropdown.classList.remove('open');
        document.removeEventListener('click', closeDropdownOutside);
    }
}

function selectSort(value, icon, text) {
    document.getElementById('sortText').textContent = text;
    document.querySelector('.dropdown-icon').textContent = icon;
    
    document.querySelectorAll('.dropdown-item').forEach(item => item.classList.remove('active'));
    event.currentTarget.classList.add('active');
    
    document.getElementById('sortDropdown').classList.remove('open');
    document.removeEventListener('click', closeDropdownOutside);
    
    // 排序动画
    const container = document.getElementById('productsContainer');
    const cards = Array.from(container.children);
    
    cards.sort((a, b) => {
        const priceA = parseFloat(a.dataset.price);
        const priceB = parseFloat(b.dataset.price);
        if (value === 'price-low') return priceA - priceB;
        if (value === 'price-high') return priceB - priceA;
        return 0;
    });
    
    cards.forEach((card, index) => {
        card.style.opacity = '0';
        card.style.transform = 'translateY(20px)';
        setTimeout(() => {
            container.appendChild(card);
            card.style.transition = 'all 0.4s ease';
            card.style.opacity = '1';
            card.style.transform = 'translateY(0)';
        }, index * 50);
    });
    
    createPixelBurst(event.currentTarget);
}

// 像素粒子爆炸
function createPixelBurst(element) {
    const rect = element.getBoundingClientRect();
    const colors = ['#FFE600', '#FF2D7D', '#00D9FF', '#9D4EDD'];
    
    for (let i = 0; i < 8; i++) {
        const particle = document.createElement('div');
        particle.style.cssText = `
            position: fixed;
            width: 10px;
            height: 10px;
            background: ${colors[Math.floor(Math.random() * colors.length)]};
            left: ${rect.left + rect.width / 2}px;
            top: ${rect.top + rect.height / 2}px;
            pointer-events: none;
            z-index: 9999;
            border-radius: 2px;
        `;
        const angle = (i * 45) * Math.PI / 180;
        const tx = Math.cos(angle) * 60;
        const ty = Math.sin(angle) * 60;
        
        particle.animate([
            { transform: 'translate(-50%, -50%) scale(1)', opacity: 1 },
            { transform: `translate(calc(-50% + ${tx}px), calc(-50% + ${ty}px)) scale(0)`, opacity: 0 }
        ], { duration: 500, easing: 'ease-out' }).onfinish = () => particle.remove();
        
        document.body.appendChild(particle);
    }
}

// 筛选
function filterProducts(category, btn) {
    document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
    btn.classList.add('active');
    
    document.querySelectorAll('.product-pixel-card').forEach((card, index) => {
        if (category === 'all' || card.dataset.category === category) {
            card.style.display = 'block';
            setTimeout(() => {
                card.style.opacity = '1';
                card.style.transform = 'translateY(0)';
            }, index * 30);
        } else {
            card.style.opacity = '0';
            card.style.transform = 'translateY(20px)';
            setTimeout(() => card.style.display = 'none', 300);
        }
    });
}

// 搜索
function searchProducts() {
    const term = document.getElementById('searchInput').value.toLowerCase();
    document.querySelectorAll('.product-pixel-card').forEach(card => {
        if (card.dataset.name.includes(term)) {
            card.style.display = 'block';
            card.style.opacity = '1';
        } else {
            card.style.display = 'none';
        }
    });
}

// 收藏 - 修复：移除e参数，直接传this
function toggleWishlist(btn) {
    btn.classList.toggle('active');
    btn.innerHTML = btn.classList.contains('active') ? '♥' : '♡';
    
    if (btn.classList.contains('active')) {
        btn.style.animation = 'heartBeat 0.4s ease';
        createPixelBurst(btn);
    }
}

// 快速预览 - 修复：移除event参数
function quickView(title, emoji, price) {
    currentModalProduct = { title, emoji, price };
    
    document.getElementById('modalTitle').textContent = title;
    document.getElementById('modalPrice').textContent = price;
    document.getElementById('modalImage').textContent = emoji;
    
    document.getElementById('quickViewModal').classList.add('active');
    document.body.style.overflow = 'hidden';
}

function closeQuickView() {
    document.getElementById('quickViewModal').classList.remove('active');
    document.body.style.overflow = '';
}

// 新增：从产品卡片添加到购物车
function addToCartFromProduct(btn) {
    // 阻止事件冒泡
    event.stopPropagation();
    
    const originalText = btn.innerHTML;
    
    // 按钮动画
    btn.innerHTML = '✓ ADDED!';
    btn.style.background = '#00FF00';
    btn.style.transform = 'scale(1.05)';
    
    // 更新购物车
    cartCount++;
    updateCartBadge();
    
    // 粒子效果
    createPixelBurst(btn);
    
    // 恢复按钮
    setTimeout(() => {
        btn.innerHTML = originalText;
        btn.style.background = '';
        btn.style.transform = '';
    }, 1500);
}

// 新增：从模态框添加到购物车
function addToCartFromModal() {
    const btn = document.querySelector('.modal-add-btn');
    const originalText = btn.innerHTML;
    
    btn.innerHTML = '✓ ADDED!';
    btn.style.background = '#00FF00';
    btn.style.transform = 'scale(1.05)';
    
    cartCount++;
    updateCartBadge();
    createPixelBurst(btn);
    
    setTimeout(() => {
        btn.innerHTML = originalText;
        btn.style.background = '';
        btn.style.transform = '';
        
        // 关闭模态框
        closeQuickView();
    }, 1200);
}

// 更新购物车徽章
function updateCartBadge() {
    document.querySelectorAll('.cart-badge').forEach(badge => {
        badge.textContent = cartCount;
        badge.classList.remove('hidden');
        badge.style.animation = 'badgeBounce 0.5s ease';
    });
    
    // 同时更新 localStorage 用于跨页面同步
    localStorage.setItem('holyMolyCartCount', cartCount);
}

// 修复：购物车点击打开抽屉或提示
function openCart() {
    // 检查是否存在购物车抽屉组件
    const cartDrawer = document.getElementById('cartDrawer');
    
    if (cartDrawer && typeof window.openCartDrawer === 'function') {
        window.openCartDrawer();
    } else {
        // 简单的提示，如果有商品则显示数量
        if (cartCount === 0) {
            alert('🛒 购物车是空的！快去选购吧 👾');
        } else {
            alert(`🛒 购物车里有 ${cartCount} 个宝贝！总计 $${(cartCount * 20).toFixed(2)}`);
        }
    }
}

function loadMore(btn) {
    btn.innerHTML = '📦 NO MORE LOOT';
    btn.disabled = true;
}

// 3D 倾斜效果 + 滚动动画
document.querySelectorAll('.product-pixel-card').forEach(card => {
    card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        const centerX = rect.width / 2;
        const centerY = rect.height / 2;
        const rotateX = (y - centerY) / 15;
        const rotateY = (centerX - x) / 15;
        card.style.transform = `perspective(1000px) rotateX(${-rotateX}deg) rotateY(${-rotateY}deg) translateZ(10px)`;
    });
    
    card.addEventListener('mouseleave', () => {
        card.style.transform = '';
    });
});

// 滚动入场动画
const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
        if (entry.isIntersecting) {
            entry.target.classList.add('visible');
        }
    });
}, { threshold: 0.1 });

document.querySelectorAll('.product-pixel-card').forEach(card => observer.observe(card));

// ESC关闭模态框
document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeQuickView();
});

// 页面加载时恢复购物车数量
document.addEventListener('DOMContentLoaded', () => {
    const savedCount = localStorage.getItem('holyMolyCartCount');
    if (savedCount) {
        cartCount = parseInt(savedCount);
        if (cartCount > 0) {
            updateCartBadge();
        }
    }
});
</script>
