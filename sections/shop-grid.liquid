// ========== 核心功能 ==========
let currentModalProduct = {};
let cartCount = 0;

function toggleMobileMenu() {
    document.getElementById('mobileMenu').classList.toggle('active');
}

function toggleDropdown() {
    const d = document.getElementById('sortDropdown');
    d.classList.toggle('open');
    if (d.classList.contains('open')) {
        setTimeout(() => document.addEventListener('click', function close(e) {
            if (!d.contains(e.target)) { d.classList.remove('open'); document.removeEventListener('click', close); }
        }), 10);
    }
}

function selectSort(val, icon, txt) {
    document.getElementById('sortText').textContent = txt;
    document.querySelectorAll('.dropdown-item').forEach(i => i.classList.remove('active'));
    event.target.classList.add('active');
    document.getElementById('sortDropdown').classList.remove('open');
}

function filterProducts(cat, btn) {
    document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('.product-pixel-card').forEach(card => {
        card.style.display = (cat === 'all' || card.dataset.category === cat) ? 'block' : 'none';
    });
}

function searchProducts() {
    const term = document.getElementById('searchInput').value.toLowerCase();
    document.querySelectorAll('.product-pixel-card').forEach(c => {
        c.style.display = c.dataset.name.includes(term) ? 'block' : 'none';
    });
}

function toggleWishlist(btn) {
    btn.classList.toggle('active');
    btn.innerHTML = btn.classList.contains('active') ? '♥' : '♡';
}

function quickView(title, emoji, price) {
    currentModalProduct = { id: Date.now(), name: title, price: parseFloat(price.replace('$','')), emoji: emoji };
    document.getElementById('modalTitle').textContent = title;
    document.getElementById('modalPrice').textContent = price;
    document.getElementById('modalImage').textContent = emoji;
    document.getElementById('quickViewModal').classList.add('active');
    document.body.style.overflow = 'hidden';
}

function closeQuickView() {
    document.getElementById('quickViewModal').classList.remove('active');
    document.body.style.overflow = '';
}

// ========== 修复：添加到购物车功能（不弹出抽屉，只抖动图标） ==========
function addProductToCart(id, name, price, emoji) {
    event.stopPropagation();
    const btn = event.target;
    const original = btn.innerHTML;
    
    btn.innerHTML = '✓ ADDED!';
    btn.style.background = '#00FF00';
    btn.style.transform = 'scale(1.05)';
    
    // 调用购物车功能，但不自动打开抽屉
    if (typeof window.addToCart === 'function') {
        window.addToCart({ id: id, name: name, price: price, emoji: emoji, variant: 'Color: Default' });
    } else {
        // 备用逻辑
        cartCount++;
        updateCartBadge();
        animateCartIcon();
    }
    
    setTimeout(() => {
        btn.innerHTML = original;
        btn.style.background = '';
        btn.style.transform = '';
    }, 1500);
}

function addToCartFromModal() {
    if (typeof window.addToCart === 'function') {
        window.addToCart({...currentModalProduct, variant: 'Color: Default'});
    }
    closeQuickView();
}

// ========== 修复：打开购物车 ==========
function openCart() {
    if (typeof window.openCartDrawer === 'function') {
        window.openCartDrawer();
    } else {
        alert(cartCount === 0 ? '🛒 购物车是空的！' : `🛒 购物车里有 ${cartCount} 个宝贝！`);
    }
}

function updateCartBadge() {
    const badges = document.querySelectorAll('.cart-badge, #cartBadge, #cartBadgeMobile');
    badges.forEach(badge => {
        badge.textContent = cartCount;
        badge.classList.remove('hidden');
    });
}

// 购物车图标抖动动画
function animateCartIcon() {
    const cartIcons = document.querySelectorAll('.navbar-cart');
    cartIcons.forEach(icon => {
        icon.style.animation = 'none';
        icon.offsetHeight; // 触发重绘
        icon.style.animation = 'cartShake 0.5s ease';
    });
}

// 3D效果
document.querySelectorAll('.product-pixel-card').forEach(card => {
    card.addEventListener('mousemove', e => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        const rotateX = (y - rect.height/2) / 15;
        const rotateY = (rect.width/2 - x) / 15;
        card.style.transform = `perspective(1000px) rotateX(${-rotateX}deg) rotateY(${-rotateY}deg) translateZ(10px)`;
    });
    card.addEventListener('mouseleave', () => card.style.transform = '');
});

// 滚动动画
const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.1 });
document.querySelectorAll('.product-pixel-card').forEach(c => observer.observe(c));

document.addEventListener('keydown', e => { if (e.key === 'Escape') closeQuickView(); });
</script>
