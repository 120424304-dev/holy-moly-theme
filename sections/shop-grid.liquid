{% comment %}
  Holy Moly Shop Grid - 动态 Shopify 产品列表
{% endcomment %}

<style>
@import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

* { box-sizing: border-box; }

.shop-page { background: #0a0a0f; min-height: 100vh; padding: 120px 20px 80px; font-family: 'Inter', sans-serif; }

.shop-navbar { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; padding: 16px 40px; background: rgba(10,10,15,0.95); backdrop-filter: blur(10px); border-bottom: 4px solid #FFE600; box-shadow: 0 10px 40px rgba(0,0,0,0.5); }
.navbar-container { max-width: 1400px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; }
.navbar-logo { font-family: 'Press Start 2P'; font-size: 18px; color: #FFE600; text-decoration: none; display: flex; align-items: center; gap: 10px; }
.navbar-logo-icon { font-size: 24px; animation: logoBounce 2s ease-in-out infinite; }
@keyframes logoBounce { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-5px); } }
.navbar-menu { display: flex; gap: 8px; list-style: none; margin: 0; padding: 0; }
.navbar-link { font-family: 'Press Start 2P'; font-size: 10px; color: rgba(255,255,255,0.8); text-decoration: none; padding: 12px 16px; position: relative; transition: all 0.3s; }
.navbar-link:hover, .navbar-link.active { color: #FFE600; }
.navbar-cart { position: relative; width: 50px; height: 50px; background: #FFE600; border: 4px solid #000; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; cursor: pointer; box-shadow: 4px 4px 0 #000; }
.navbar-cart:hover { transform: translate(2px,2px); box-shadow: 2px 2px 0 #000; background: #FF2D7D; }
.cart-badge { position: absolute; top: -10px; right: -10px; width: 26px; height: 26px; background: #FF2D7D; border: 3px solid #000; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: 'Press Start 2P'; font-size: 10px; color: white; }
.cart-badge.hidden { display: none; }
.hamburger { display: none; flex-direction: column; gap: 6px; padding: 10px; cursor: pointer; background: transparent; border: none; }
.hamburger-line { width: 30px; height: 4px; background: #FFE600; border-radius: 2px; box-shadow: 2px 2px 0 rgba(0,0,0,0.5); }
.mobile-menu { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(10,10,15,0.98); z-index: 999; flex-direction: column; align-items: center; justify-content: center; gap: 30px; opacity: 0; pointer-events: none; }
.mobile-menu.active { opacity: 1; pointer-events: all; display: flex; }

.shop-header { text-align: center; margin-bottom: 60px; margin-top: 40px; }
.shop-title { font-family: 'Press Start 2P'; font-size: clamp(28px, 5vw, 48px); color: #FFE600; text-shadow: 4px 4px 0 #FF2D7D, 8px 8px 0 #00D9FF; margin-bottom: 16px; animation: titleFloat 3s ease-in-out infinite; }
@keyframes titleFloat { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
.shop-subtitle { font-family: 'Press Start 2P'; font-size: 12px; color: rgba(255,255,255,0.5); }

.control-panel { display: flex; flex-wrap: wrap; gap: 20px; justify-content: center; align-items: center; margin-bottom: 40px; padding: 30px; background: rgba(255,255,255,0.03); border: 3px solid rgba(255,230,0,0.2); border-radius: 20px; max-width: 1400px; margin-left: auto; margin-right: auto; }

.pixel-search { position: relative; display: flex; align-items: center; background: #1a1a2e; border: 4px solid #FFE600; border-radius: 12px; padding: 12px 16px; min-width: 280px; }
.pixel-search .search-icon { font-size: 18px; margin-right: 12px; }
.pixel-search input { background: transparent; border: none; color: #FFE600; font-family: 'Press Start 2P'; font-size: 10px; outline: none; width: 100%; text-transform: uppercase; }

.filter-chips { display: flex; flex-wrap: wrap; gap: 10px; }
.chip { font-family: 'Press Start 2P'; font-size: 9px; padding: 12px 20px; background: transparent; border: 3px solid rgba(255,255,255,0.2); border-radius: 8px; color: rgba(255,255,255,0.6); cursor: pointer; transition: all 0.3s; }
.chip:hover, .chip.active { background: #FFE600; border-color: #000; color: #000; box-shadow: 4px 4px 0 #000; transform: translate(-2px,-2px); }

.pixel-dropdown { position: relative; z-index: 100; }
.pixel-dropdown-btn { font-family: 'Press Start 2P'; font-size: 9px; padding: 14px 20px; background: #FF2D7D; border: 4px solid #000; border-radius: 8px; color: white; cursor: pointer; box-shadow: 4px 4px 0 #000; display: flex; align-items: center; gap: 10px; min-width: 220px; }
.dropdown-arrow { margin-left: auto; transition: transform 0.3s; }
.pixel-dropdown.open .dropdown-arrow { transform: rotate(180deg); }
.pixel-dropdown-menu { position: absolute; top: calc(100% + 12px); left: 0; right: 0; background: #1a1a2e; border: 4px solid #FFE600; border-radius: 12px; box-shadow: 6px 6px 0 #000; opacity: 0; visibility: hidden; transform: translateY(-10px) scale(0.95); transition: all 0.3s; }
.pixel-dropdown.open .pixel-dropdown-menu { opacity: 1; visibility: visible; transform: translateY(0) scale(1); }
.dropdown-item { display: flex; align-items: center; gap: 12px; padding: 16px 20px; font-family: 'Press Start 2P'; font-size: 9px; color: rgba(255,255,255,0.8); cursor: pointer; transition: all 0.2s; }
.dropdown-item:hover { background: #FFE600; color: #000; padding-left: 28px; }
.dropdown-item.active { background: rgba(255,230,0,0.2); color: #FFE600; }

.products-container { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 30px; max-width: 1400px; margin: 0 auto; perspective: 1000px; }

.product-pixel-card { position: relative; cursor: pointer; transform-style: preserve-3d; transition: transform 0.3s; opacity: 0; transform: translateY(30px); }
.product-pixel-card.visible { opacity: 1; transform: translateY(0); transition: opacity 0.6s, transform 0.6s; }
.card-inner { background: #1a1a2e; border: 4px solid rgba(255,255,255,0.1); border-radius: 20px; overflow: hidden; position: relative; transition: all 0.3s; }
.product-pixel-card:hover .card-inner { border-color: #FFE600; box-shadow: 0 20px 60px rgba(255,230,0,0.2); transform: translateY(-5px); }

.pixel-corners .corner { position: absolute; width: 12px; height: 12px; border: 3px solid #FFE600; opacity: 0; transition: opacity 0.3s; z-index: 10; }
.corner.tl { top: -2px; left: -2px; border-right: none; border-bottom: none; }
.corner.tr { top: -2px; right: -2px; border-left: none; border-bottom: none; }
.corner.bl { bottom: -2px; left: -2px; border-right: none; border-top: none; }
.corner.br { bottom: -2px; right: -2px; border-left: none; border-top: none; }
.product-pixel-card:hover .corner { opacity: 1; }

.wishlist-btn { position: absolute; top: 16px; right: 16px; z-index: 10; width: 44px; height: 44px; background: rgba(0,0,0,0.5); border: 3px solid rgba(255,255,255,0.3); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; cursor: pointer; transition: all 0.3s; }
.wishlist-btn:hover, .wishlist-btn.active { background: #FF2D7D; border-color: #000; box-shadow: 3px 3px 0 #000; transform: scale(1.1); }

.quick-actions { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); display: flex; flex-direction: column; gap: 12px; opacity: 0; z-index: 5; transition: opacity 0.3s; pointer-events: none; }
.product-pixel-card:hover .quick-actions { opacity: 1; pointer-events: all; }
.quick-btn { font-family: 'Press Start 2P'; font-size: 9px; padding: 14px 24px; border: 3px solid #000; border-radius: 8px; cursor: pointer; transition: all 0.2s; white-space: nowrap; box-shadow: 4px 4px 0 #000; }
.quick-btn:hover { transform: translate(2px, 2px); box-shadow: 2px 2px 0 #000; }
.quick-view { background: #FFE600; color: #000; }
.add-cart { background: #00D9FF; color: #000; }
.quick-btn:disabled { background: #666; cursor: not-allowed; box-shadow: 2px 2px 0 #000; }

.card-image-wrapper { position: relative; height: 260px; overflow: hidden; }
.card-image { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; position: relative; transition: transform 0.4s; }
.product-pixel-card:hover .card-image { transform: scale(1.05); }
.product-img-placeholder { font-size: 100px; animation: placeholderFloat 3s ease-in-out infinite; filter: drop-shadow(0 10px 20px rgba(0,0,0,0.3)); }
@keyframes placeholderFloat { 0%,100% { transform: translateY(0) rotate(0deg); } 50% { transform: translateY(-10px) rotate(5deg); } }
.product-pixel-card:hover .product-img-placeholder { animation: shake 0.5s ease; }
@keyframes shake { 0%,100% { transform: rotate(0deg); } 25% { transform: rotate(-10deg); } 75% { transform: rotate(10deg); } }
.product-img { width: 80%; height: 80%; object-fit: contain; transition: transform 0.4s; }
.product-pixel-card:hover .product-img { transform: scale(1.1); }

.card-badge { position: absolute; top: 16px; left: 16px; font-family: 'Press Start 2P'; font-size: 9px; padding: 8px 14px; border: 3px solid #000; border-radius: 6px; box-shadow: 3px 3px 0 rgba(0,0,0,0.3); animation: badgeGlow 2s infinite; z-index: 5; }
@keyframes badgeGlow { 0%,100% { box-shadow: 3px 3px 0 rgba(0,0,0,0.3); } 50% { box-shadow: 3px 3px 0 rgba(0,0,0,0.3), 0 0 15px currentColor; } }
.card-badge.sale { background: #FF2D7D; color: white; }
.card-badge.new { background: #00D9FF; color: #000; }
.card-badge.hot { background: #FFE600; color: #000; }

.card-info { padding: 24px; background: white; }
.card-meta { display: flex; justify-content: space-between; margin-bottom: 12px; align-items: center; }
.card-type { font-family: 'Press Start 2P'; font-size: 8px; color: #9D4EDD; background: rgba(157,78,221,0.1); padding: 4px 8px; border-radius: 4px; }
.card-stock { font-family: 'Press Start 2P'; font-size: 8px; }
.card-stock.in { color: #00D9FF; }
.card-stock.out { color: #FF2D7D; }
.card-title { font-family: 'Press Start 2P'; font-size: 11px; color: #000; line-height: 1.6; margin-bottom: 16px; min-height: 36px; }
.card-footer { display: flex; justify-content: space-between; align-items: center; }
.current-price { font-size: 22px; font-weight: 800; color: #FF2D7D; }
.old-price { font-size: 14px; color: #999; text-decoration: line-through; margin-right: 8px; }
.card-rating { font-size: 14px; color: #FFB800; background: rgba(255,184,0,0.1); padding: 4px 8px; border-radius: 4px; }

.load-more-container { text-align: center; margin-top: 60px; }
.load-more-btn { background: #FFE600; color: #000; border: 5px solid #000; padding: 24px 48px; font-family: 'Press Start 2P'; font-size: 14px; cursor: pointer; box-shadow: 8px 8px 0 #000; }
.load-more-btn:hover { transform: translate(4px,4px); box-shadow: 4px 4px 0 #000; }

.empty-shop { text-align: center; padding: 80px 20px; }
.empty-shop-icon { font-size: 80px; margin-bottom: 24px; }
.empty-shop-text { font-family: 'Press Start 2P'; font-size: 16px; color: rgba(255,255,255,0.6); margin-bottom: 32px; }

.quick-view-modal { position: fixed; inset: 0; z-index: 10000; display: flex; align-items: center; justify-content: center; opacity: 0; pointer-events: none; transition: opacity 0.3s; }
.quick-view-modal.active { opacity: 1; pointer-events: all; }
.modal-overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.9); }
.modal-content { position: relative; background: #1a1a2e; border: 5px solid #FFE600; border-radius: 24px; max-width: 500px; width: 90%; box-shadow: 0 0 60px rgba(255,230,0,0.3); transform: scale(0.9); transition: transform 0.3s; overflow: hidden; }
.quick-view-modal.active .modal-content { transform: scale(1); }
.modal-close { position: absolute; top: 16px; right: 16px; width: 48px; height: 48px; background: #FF2D7D; border: 4px solid #000; border-radius: 12px; font-size: 24px; color: white; cursor: pointer; z-index: 10; box-shadow: 3px 3px 0 #000; font-family: 'Press Start 2P'; display: flex; align-items: center; justify-content: center; }
.modal-body { padding: 40px; text-align: center; }
.modal-image { font-size: 120px; margin-bottom: 20px; animation: modalFloat 3s ease-in-out infinite; }
@keyframes modalFloat { 0%,100% { transform: translateY(0) rotate(0deg); } 50% { transform: translateY(-15px) rotate(5deg); } }
.modal-title { font-family: 'Press Start 2P'; font-size: 16px; color: #FFE600; margin-bottom: 16px; line-height: 1.5; }
.modal-price { font-family: 'Press Start 2P'; font-size: 28px; color: #FF2D7D; margin-bottom: 20px; }
.modal-desc { color: rgba(255,255,255,0.7); font-size: 14px; line-height: 1.8; margin-bottom: 30px; }
.modal-add-btn { font-family: 'Press Start 2P'; font-size: 14px; padding: 20px 40px; background: #FFE600; border: 4px solid #000; border-radius: 12px; cursor: pointer; box-shadow: 6px 6px 0 #000; }
.modal-add-btn:hover { transform: translate(3px,3px); box-shadow: 3px 3px 0 #000; background: #00D9FF; }
@keyframes cartShake {
    0%, 100% { transform: translateX(0) rotate(0deg); }
    20% { transform: translateX(-5px) rotate(-10deg); }
    40% { transform: translateX(5px) rotate(10deg); }
    60% { transform: translateX(-3px) rotate(-5deg); }
    80% { transform: translateX(3px) rotate(5deg); }
}

/* ========== 移动端优化 ========== */
@media (max-width: 768px) {
    .shop-page { padding: 90px 16px 60px !important; }
    .shop-header { margin-bottom: 30px; margin-top: 20px; }
    .shop-title { font-size: clamp(20px, 7vw, 32px) !important; text-shadow: 2px 2px 0 #FF2D7D, 4px 4px 0 #00D9FF !important; line-height: 1.4; }
    .shop-subtitle { font-size: 9px !important; opacity: 0.7; }
    
    .control-panel { padding: 16px !important; gap: 12px !important; margin-bottom: 24px !important; flex-direction: column !important; }
    .pixel-search { min-width: 100% !important; padding: 10px 14px !important; }
    .pixel-search input { font-size: 11px !important; }
    
    .filter-chips { flex-wrap: nowrap !important; overflow-x: auto !important; -webkit-overflow-scrolling: touch !important; scrollbar-width: none !important; padding-bottom: 4px; width: 100%; gap: 8px !important; }
    .filter-chips::-webkit-scrollbar { display: none; }
    .chip { flex-shrink: 0 !important; padding: 10px 16px !important; font-size: 9px !important; }
    
    .products-container { grid-template-columns: repeat(2, 1fr) !important; gap: 12px !important; }
    .product-pixel-card { touch-action: manipulation; -webkit-tap-highlight-color: transparent; }
    .card-inner { border-width: 3px !important; border-radius: 16px !important; }
    .card-image-wrapper { height: 160px !important; }
    .product-img-placeholder { font-size: 60px !important; }
    .card-info { padding: 16px !important; }
    .card-title { font-size: 10px !important; min-height: 32px !important; line-height: 1.5 !important; }
    .card-type, .card-stock { font-size: 7px !important; }
    .current-price { font-size: 16px !important; }
    .card-rating { font-size: 12px !important; }
    
    .quick-actions { 
        display: flex !important; 
        opacity: 1 !important; 
        position: absolute !important; 
        bottom: 16px !important; 
        top: auto !important; 
        left: 50% !important; 
        transform: translateX(-50%) !important; 
        flex-direction: row !important; 
        gap: 8px !important; 
        pointer-events: auto !important;
    }
    .quick-btn { padding: 10px 14px !important; font-size: 8px !important; box-shadow: 3px 3px 0 #000 !important; border-width: 2px !important; }
    
    .card-badge { font-size: 8px !important; padding: 6px 10px !important; border-width: 2px !important; top: 10px !important; left: 10px !important; }
    
    .wishlist-btn { width: 36px !important; height: 36px !important; font-size: 16px !important; opacity: 1 !important; background: rgba(0,0,0,0.6) !important; top: 10px !important; right: 10px !important; }
    
    .shop-navbar { padding: 12px 16px !important; }
    .navbar-logo { font-size: 14px !important; gap: 6px !important; }
    .navbar-logo-icon { font-size: 18px !important; }
    .navbar-cart { width: 42px !important; height: 42px !important; font-size: 16px !important; border-width: 3px !important; box-shadow: 3px 3px 0 #000 !important; }
    
    .modal-content { max-width: 95% !important; margin: 20px !important; border-width: 3px !important; }
    .modal-body { padding: 20px !important; }
    .modal-image { font-size: 80px !important; }
    .modal-title { font-size: 12px !important; }
    .modal-price { font-size: 20px !important; }
    .modal-add-btn { padding: 14px 28px !important; font-size: 11px !important; }
    
    .pixel-dropdown { width: 100% !important; }
    .pixel-dropdown-btn { min-width: 100% !important; padding: 12px 16px !important; font-size: 9px !important; justify-content: center !important; }
    .pixel-dropdown-menu { position: fixed !important; left: 16px !important; right: 16px !important; top: auto !important; bottom: 20px !important; }
}

@media (max-width: 480px) {
    .products-container { grid-template-columns: 1fr !important; gap: 16px !important; }
    .card-image-wrapper { height: 200px !important; }
    .quick-actions { bottom: 20px !important; }
    .quick-btn { padding: 12px 20px !important; font-size: 9px !important; }
}

/* 禁用文本选择 */
.product-pixel-card, .chip, .quick-btn, .wishlist-btn, .navbar-cart { user-select: none !important; -webkit-user-select: none !important; }
</style>

<nav class="shop-navbar">
    <div class="navbar-container">
        <a href="/" class="navbar-logo"><span class="navbar-logo-icon">👾</span><span>HOLY MOLY</span></a>
        <ul class="navbar-menu">
            <li><a href="/" class="navbar-link">🏠 HOME</a></li>
            <li><a href="/pages/shop" class="navbar-link active">🛒 SHOP</a></li>
            <li><a href="/#custom" class="navbar-link">🎨 CUSTOM</a></li>
            <li><a href="/#features" class="navbar-link">✨ FEATURES</a></li>
        </ul>
        <div class="navbar-cart" onclick="openCart()">🛒<span class="cart-badge hidden" id="cartBadge">0</span></div>
        <button class="hamburger" onclick="toggleMobileMenu()"><span class="hamburger-line"></span><span class="hamburger-line"></span><span class="hamburger-line"></span></button>
    </div>
</nav>

<div class="mobile-menu" id="mobileMenu">
    <a href="/" class="navbar-link">🏠 HOME</a>
    <a href="/pages/shop" class="navbar-link active">🛒 SHOP</a>
    <a href="/#custom" class="navbar-link">🎨 CUSTOM</a>
    <a href="/#features" class="navbar-link">✨ FEATURES</a>
    <div class="navbar-cart" onclick="openCart(); toggleMobileMenu();">🛒<span class="cart-badge hidden" id="cartBadgeMobile">0</span></div>
</div>

<div class="shop-page">
    <div class="shop-header">
        <div class="shop-title">THE LOOT BOX</div>
        <div class="shop-subtitle">← Scroll to explore →</div>
    </div>

    <div class="control-panel">
        <div class="pixel-search"><span class="search-icon">🔍</span><input type="text" id="searchInput" placeholder="SEARCH ITEMS..." onkeyup="searchProducts()"></div>
        <div class="filter-chips">
            <button class="chip active" onclick="filterProducts('all', this)">ALL</button>
            <button class="chip" onclick="filterProducts('keychain', this)">KEYCHAINS</button>
            <button class="chip" onclick="filterProducts('magnet', this)">MAGNETS</button>
            <button class="chip" onclick="filterProducts('diy', this)">DIY KITS</button>
        </div>
        <div class="pixel-dropdown" id="sortDropdown">
            <button class="pixel-dropdown-btn" onclick="toggleDropdown()"><span>🆕</span><span id="sortText">NEWEST</span><span class="dropdown-arrow">▼</span></button>
            <div class="pixel-dropdown-menu">
                <div class="dropdown-item active" onclick="selectSort('newest', '🆕', 'NEWEST')"><span>🆕</span><span>NEWEST</span></div>
                <div class="dropdown-item" onclick="selectSort('price-low', '💰', 'PRICE: LOW TO HIGH')"><span>💰</span><span>PRICE: LOW TO HIGH</span></div>
                <div class="dropdown-item" onclick="selectSort('price-high', '💎', 'PRICE: HIGH TO LOW')"><span>💎</span><span>PRICE: HIGH TO LOW</span></div>
                <div class="dropdown-item" onclick="selectSort('popular', '🔥', 'MOST POPULAR')"><span>🔥</span><span>MOST POPULAR</span></div>
            </div>
        </div>
    </div>

    <div class="products-container" id="productsContainer">
        {%- paginate collections.all.products by 20 -%}
            {%- if collections.all.products.size > 0 -%}
                {%- for product in collections.all.products -%}
                    {%- render 'product-card', product: product, show_quick_add: true -%}
                {%- endfor -%}
            {%- else -%}
                <div class="empty-shop">
                    <div class="empty-shop-icon">📦</div>
                    <div class="empty-shop-text">NO PRODUCTS YET</div>
                    <p style="color: rgba(255,255,255,0.5); font-family: 'Press Start 2P'; font-size: 10px;">Add products in your Shopify admin!</p>
                </div>
            {%- endif -%}
        {%- endpaginate -%}
    </div>

    {%- if collections.all.products.size > 0 -%}
    <div class="load-more-container"><button class="load-more-btn" onclick="loadMoreProducts()">📦 LOAD MORE LOOT</button></div>
    {%- endif -%}
</div>

<div class="quick-view-modal" id="quickViewModal">
    <div class="modal-overlay" onclick="closeQuickView()"></div>
    <div class="modal-content">
        <button class="modal-close" onclick="closeQuickView()">×</button>
        <div class="modal-body">
            <div class="modal-image" id="modalImage">🎮</div>
            <h2 class="modal-title" id="modalTitle">Product Name</h2>
            <div class="modal-price" id="modalPrice">$00.00</div>
            <p class="modal-desc">Handcrafted pixel art made with 1000+ beads. Each piece is unique!</p>
            <button class="modal-add-btn" id="modalAddBtn" onclick="addToCartFromModal()">🛒 ADD TO CART</button>
        </div>
    </div>
</div>

<script>
let currentModalProduct = { variantId: null, name: '', price: 0 };
let currentSort = 'newest';
let loadedCount = 20;

document.addEventListener('DOMContentLoaded', function() {
    const cards = document.querySelectorAll('.product-pixel-card');
    cards.forEach((card, index) => {
        setTimeout(() => {
            card.classList.add('visible');
        }, index * 50);
    });
});

function toggleMobileMenu() {
    document.getElementById('mobileMenu').classList.toggle('active');
}

document.addEventListener('click', function(e) {
    const dropdown = document.getElementById('sortDropdown');
    if (!dropdown.contains(e.target)) {
        dropdown.classList.remove('open');
    }
});

function toggleDropdown() {
    document.getElementById('sortDropdown').classList.toggle('open');
}

function selectSort(value, icon, text) {
    document.querySelectorAll('.dropdown-item').forEach(item => item.classList.remove('active'));
    event.target.closest('.dropdown-item').classList.add('active');
    document.getElementById('sortText').textContent = text;
    document.querySelector('.pixel-dropdown-btn span:first-child').textContent = icon;
    document.getElementById('sortDropdown').classList.remove('open');
    currentSort = value;
    sortProducts(value);
}

function searchProducts() {
    const query = document.getElementById('searchInput').value.toLowerCase();
    const cards = document.querySelectorAll('.product-pixel-card');
    
    cards.forEach(card => {
        const name = card.getAttribute('data-name');
        if (name && name.includes(query)) {
            card.style.display = 'block';
        } else {
            card.style.display = 'none';
        }
    });
}

function filterProducts(category, btn) {
    document.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
    btn.classList.add('active');
    
    const cards = document.querySelectorAll('.product-pixel-card');
    
    cards.forEach(card => {
        if (category === 'all' || card.getAttribute('data-category') === category) {
            card.style.display = 'block';
        } else {
            card.style.display = 'none';
        }
    });
}

function sortProducts(sortType) {
    const container = document.getElementById('productsContainer');
    const cards = Array.from(container.querySelectorAll('.product-pixel-card'));
    
    cards.sort((a, b) => {
        const priceA = parseFloat(a.getAttribute('data-price'));
        const priceB = parseFloat(b.getAttribute('data-price'));
        
        switch(sortType) {
            case 'price-low': return priceA - priceB;
            case 'price-high': return priceB - priceA;
            case 'popular': return Math.random() - 0.5;
            default: return 0;
        }
    });
    
    cards.forEach(card => container.appendChild(card));
}

async function addProductToCart(variantId, name, price, emoji) {
    try {
        const response = await fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: variantId, quantity: 1 })
        });
        
        if (!response.ok) throw new Error('Failed to add');
        
        animateCartIcon();
        
        if (typeof openCartDrawer === 'function') {
            openCartDrawer();
        }
        
        const cart = await fetch('/cart.js').then(r => r.json());
        if (typeof updateAllCartBadges === 'function') {
            updateAllCartBadges(cart.item_count);
        }
        
    } catch (error) {
        alert('Failed to add to cart. Please try again.');
    }
}

function animateCartIcon() {
    const badges = document.querySelectorAll('.navbar-cart');
    badges.forEach(icon => {
        icon.style.animation = 'cartShake 0.5s ease';
        setTimeout(() => icon.style.animation = '', 500);
    });
}

function openQuickView(name, emoji, price, description) {
    currentModalProduct = { name, emoji, price };
    document.getElementById('modalTitle').textContent = name;
    document.getElementById('modalImage').textContent = emoji;
    document.getElementById('modalPrice').textContent = price;
    document.getElementById('quickViewModal').classList.add('active');
}

function closeQuickView() {
    document.getElementById('quickViewModal').classList.remove('active');
}

function addToCartFromModal() {
    closeQuickView();
    animateCartIcon();
}

function toggleWishlist(btn) {
    btn.classList.toggle('active');
    btn.textContent = btn.classList.contains('active') ? '♥' : '♡';
}

function loadMoreProducts() {
    const btn = event.target;
    btn.textContent = '📦 LOADING...';
    btn.disabled = true;
    
    setTimeout(() => {
        btn.textContent = '📦 NO MORE LOOT';
        btn.disabled = true;
    }, 1000);
}

function openCart() {
    if (typeof openCartDrawer === 'function') {
        openCartDrawer();
    } else {
        window.location.href = '/cart';
    }
}

window.openCart = openCart;
</script>
