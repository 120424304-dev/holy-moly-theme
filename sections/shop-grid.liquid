<style>
/* ========== 完整CSS样式 ========== */
@import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

* { box-sizing: border-box; }

.shop-page { 
    background: #0a0a0f; 
    min-height: 100vh; 
    padding: 120px 20px 80px;
    font-family: 'Inter', sans-serif;
}

/* 导航栏 */
.shop-navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 16px 40px;
    background: rgba(10, 10, 15, 0.95);
    backdrop-filter: blur(10px);
    border-bottom: 4px solid #FFE600;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
}

.navbar-container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
}

.navbar-logo {
    font-family: 'Press Start 2P', cursive;
    font-size: 18px;
    color: #FFE600;
    text-decoration: none;
    text-shadow: 3px 3px 0px rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    gap: 10px;
    transition: all 0.3s;
}

.navbar-logo:hover {
    color: #FF2D7D;
    transform: scale(1.05);
}

.navbar-logo-icon {
    font-size: 24px;
    animation: logoBounce 2s ease-in-out infinite;
}

@keyframes logoBounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
}

.navbar-menu {
    display: flex;
    align-items: center;
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
}

.navbar-link {
    font-family: 'Press Start 2P', cursive;
    font-size: 10px;
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    padding: 12px 16px;
    position: relative;
    transition: all 0.3s;
}

.navbar-link::before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 0;
    height: 3px;
    background: #FFE600;
    transition: width 0.3s;
    box-shadow: 0 0 10px #FFE600;
}

.navbar-link:hover, .navbar-link.active {
    color: #FFE600;
}

.navbar-link:hover::before, .navbar-link.active::before {
    width: 80%;
}

.navbar-cart {
    position: relative;
    width: 50px;
    height: 50px;
    background: #FFE600;
    border: 4px solid #000;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    cursor: pointer;
    box-shadow: 4px 4px 0px #000;
    transition: all 0.2s;
}

.navbar-cart:hover {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0px #000;
    background: #FF2D7D;
}

.cart-badge {
    position: absolute;
    top: -10px;
    right: -10px;
    width: 26px;
    height: 26px;
    background: #FF2D7D;
    border: 3px solid #000;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Press Start 2P', cursive;
    font-size: 10px;
    color: white;
    animation: badgePulse 2s infinite;
}

.cart-badge.hidden { display: none; }

@keyframes badgePulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.1); }
}

.hamburger {
    display: none;
    flex-direction: column;
    gap: 6px;
    padding: 10px;
    cursor: pointer;
    background: transparent;
    border: none;
}

.hamburger-line {
    width: 30px;
    height: 4px;
    background: #FFE600;
    border-radius: 2px;
    box-shadow: 2px 2px 0px rgba(0, 0, 0, 0.5);
}

.mobile-menu {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(10, 10, 15, 0.98);
    z-index: 999;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 30px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s;
}

.mobile-menu.active {
    opacity: 1;
    pointer-events: all;
    display: flex;
}

/* 页面标题 */
.shop-header {
    text-align: center;
    margin-bottom: 60px;
    margin-top: 40px;
}

.shop-title {
    font-family: 'Press Start 2P', cursive;
    font-size: clamp(28px, 5vw, 48px);
    color: #FFE600;
    text-shadow: 4px 4px 0 #FF2D7D, 8px 8px 0 #00D9FF;
    margin-bottom: 16px;
    animation: titleFloat 3s ease-in-out infinite;
}

@keyframes titleFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
}

.shop-subtitle {
    font-family: 'Press Start 2P', cursive;
    font-size: 12px;
    color: rgba(255,255,255,0.5);
}

/* 控制面板 */
.control-panel {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    justify-content: center;
    align-items: center;
    margin-bottom: 40px;
    padding: 30px;
    background: rgba(255,255,255,0.03);
    border: 3px solid rgba(255,230,0,0.2);
    border-radius: 20px;
    max-width: 1400px;
    margin-left: auto;
    margin-right: auto;
}

/* 搜索框 */
.pixel-search {
    position: relative;
    display: flex;
    align-items: center;
    background: #1a1a2e;
    border: 4px solid #FFE600;
    border-radius: 12px;
    padding: 12px 16px;
    min-width: 280px;
    transition: all 0.3s;
}

.pixel-search:focus-within {
    box-shadow: 0 0 20px rgba(255,230,0,0.3);
    transform: translateY(-2px);
}

.pixel-search .search-icon {
    font-size: 18px;
    margin-right: 12px;
    animation: searchPulse 2s infinite;
}

@keyframes searchPulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.1); }
}

.pixel-search input {
    background: transparent;
    border: none;
    color: #FFE600;
    font-family: 'Press Start 2P', cursive;
    font-size: 10px;
    outline: none;
    width: 100%;
    text-transform: uppercase;
}

/* 筛选芯片 */
.filter-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
}

.chip {
    font-family: 'Press Start 2P', cursive;
    font-size: 9px;
    padding: 12px 20px;
    background: transparent;
    border: 3px solid rgba(255,255,255,0.2);
    border-radius: 8px;
    color: rgba(255,255,255,0.6);
    cursor: pointer;
    transition: all 0.3s;
    text-transform: uppercase;
}

.chip:hover, .chip.active {
    background: #FFE600;
    border-color: #000;
    color: #000;
    box-shadow: 4px 4px 0 #000;
    transform: translate(-2px, -2px);
}

/* 下拉菜单 */
.pixel-dropdown {
    position: relative;
    z-index: 100;
}

.pixel-dropdown-btn {
    font-family: 'Press Start 2P', cursive;
    font-size: 9px;
    padding: 14px 20px;
    background: #FF2D7D;
    border: 4px solid #000;
    border-radius: 8px;
    color: white;
    cursor: pointer;
    box-shadow: 4px 4px 0 #000;
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 220px;
    transition: all 0.2s;
}

.pixel-dropdown-btn:hover {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 #000;
    background: #ff4d8f;
}

.dropdown-arrow {
    margin-left: auto;
    transition: transform 0.3s;
}

.pixel-dropdown.open .dropdown-arrow {
    transform: rotate(180deg);
}

.pixel-dropdown-menu {
    position: absolute;
    top: calc(100% + 12px);
    left: 0;
    right: 0;
    background: #1a1a2e;
    border: 4px solid #FFE600;
    border-radius: 12px;
    box-shadow: 6px 6px 0 #000;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px) scale(0.95);
    transition: all 0.3s;
    overflow: hidden;
}

.pixel-dropdown.open .pixel-dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0) scale(1);
}

.dropdown-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 20px;
    font-family: 'Press Start 2P', cursive;
    font-size: 9px;
    color: rgba(255,255,255,0.8);
    cursor: pointer;
    transition: all 0.2s;
    border-bottom: 2px solid rgba(255,230,0,0.1);
}

.dropdown-item:hover {
    background: #FFE600;
    color: #000;
    padding-left: 28px;
}

.dropdown-item.active {
    background: rgba(255,230,0,0.2);
    color: #FFE600;
}

.dropdown-item.active::after {
    content: '✓';
    margin-left: auto;
    color: #00D9FF;
}

/* 产品网格 */
.products-container {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 30px;
    max-width: 1400px;
    margin: 0 auto;
    perspective: 1000px;
}

/* 产品卡片 */
.product-pixel-card {
    position: relative;
    cursor: pointer;
    transform-style: preserve-3d;
    transition: transform 0.3s;
    opacity: 0;
    transform: translateY(30px);
}

.product-pixel-card.visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.6s, transform 0.6s;
}

.card-inner {
    background: #1a1a2e;
    border: 4px solid rgba(255,255,255,0.1);
    border-radius: 20px;
    overflow: hidden;
    position: relative;
    transition: all 0.3s;
}

.product-pixel-card:hover .card-inner {
    border-color: #FFE600;
    box-shadow: 0 20px 60px rgba(255,230,0,0.2);
    transform: translateY(-5px);
}

/* 像素角 */
.pixel-corners .corner {
    position: absolute;
    width: 12px;
    height: 12px;
    border: 3px solid #FFE600;
    opacity: 0;
    transition: opacity 0.3s;
    z-index: 10;
}

.corner.tl { top: -2px; left: -2px; border-right: none; border-bottom: none; }
.corner.tr { top: -2px; right: -2px; border-left: none; border-bottom: none; }
.corner.bl { bottom: -2px; left: -2px; border-right: none; border-top: none; }
.corner.br { bottom: -2px; right: -2px; border-left: none; border-top: none; }

.product-pixel-card:hover .corner {
    opacity: 1;
}

/* 收藏按钮 */
.wishlist-btn {
    position: absolute;
    top: 16px;
    right: 16px;
    z-index: 10;
    width: 44px;
    height: 44px;
    background: rgba(0,0,0,0.5);
    border: 3px solid rgba(255,255,255,0.3);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    cursor: pointer;
    transition: all 0.3s;
}

.wishlist-btn:hover, .wishlist-btn.active {
    background: #FF2D7D;
    border-color: #000;
    box-shadow: 3px 3px 0 #000;
    transform: scale(1.1);
}

/* 快速操作 */
.quick-actions {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    gap: 12px;
    opacity: 0;
    z-index: 5;
    transition: opacity 0.3s;
    pointer-events: none;
}

.product-pixel-card:hover .quick-actions {
    opacity: 1;
    pointer-events: all;
}

.quick-btn {
    font-family: 'Press Start 2P', cursive;
    font-size: 9px;
    padding: 14px 24px;
    border: 3px solid #000;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
    box-shadow: 4px 4px 0 #000;
}

.quick-btn:hover {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 #000;
}

.quick-view { background: #FFE600; color: #000; }
.add-cart { background: #00D9FF; color: #000; }

/* 图片区 */
.card-image-wrapper {
    position: relative;
    height: 260px;
    overflow: hidden;
}

.card-image {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    transition: transform 0.4s;
}

.product-pixel-card:hover .card-image {
    transform: scale(1.05);
}

/* 图片占位符 */
.product-img-placeholder {
    font-size: 100px;
    animation: placeholderFloat 3s ease-in-out infinite;
    filter: drop-shadow(0 10px 20px rgba(0,0,0,0.3));
}

@keyframes placeholderFloat {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-10px) rotate(5deg); }
}

.product-pixel-card:hover .product-img-placeholder {
    animation: shake 0.5s ease;
}

@keyframes shake {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(-10deg); }
    75% { transform: rotate(10deg); }
}

/* 产品图片（替换后使用） */
.product-img {
    width: 80%;
    height: 80%;
    object-fit: contain;
    transition: transform 0.4s;
}

.product-pixel-card:hover .product-img {
    transform: scale(1.1);
}

/* 徽章 */
.card-badge {
    position: absolute;
    top: 16px;
    left: 16px;
    font-family: 'Press Start 2P', cursive;
    font-size: 9px;
    padding: 8px 14px;
    border: 3px solid #000;
    border-radius: 6px;
    box-shadow: 3px 3px 0 rgba(0,0,0,0.3);
    animation: badgeGlow 2s infinite;
    z-index: 5;
}

@keyframes badgeGlow {
    0%, 100% { box-shadow: 3px 3px 0 rgba(0,0,0,0.3); }
    50% { box-shadow: 3px 3px 0 rgba(0,0,0,0.3), 0 0 15px currentColor; }
}

.card-badge.sale { background: #FF2D7D; color: white; }
.card-badge.new { background: #00D9FF; color: #000; }
.card-badge.hot { background: #FFE600; color: #000; }

/* 信息区 */
.card-info {
    padding: 24px;
    background: white;
}

.card-meta {
    display: flex;
    justify-content: space-between;
    margin-bottom: 12px;
    align-items: center;
}

.card-type {
    font-family: 'Press Start 2P', cursive;
    font-size: 8px;
    color: #9D4EDD;
    background: rgba(157,78,221,0.1);
    padding: 4px 8px;
    border-radius: 4px;
}

.card-stock {
    font-family: 'Press Start 2P', cursive;
    font-size: 8px;
}

.card-stock.in { color: #00D9FF; }
.card-stock.out { color: #FF2D7D; }

.card-title {
    font-family: 'Press Start 2P', cursive;
    font-size: 11px;
    color: #000;
    line-height: 1.6;
    margin-bottom: 16px;
    min-height: 36px;
}

.card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.current-price {
    font-size: 22px;
    font-weight: 800;
    color: #FF2D7D;
}

.old-price {
    font-size: 14px;
    color: #999;
    text-decoration: line-through;
    margin-right: 8px;
}

.card-rating {
    font-size: 14px;
    color: #FFB800;
    background: rgba(255,184,0,0.1);
    padding: 4px 8px;
    border-radius: 4px;
}

/* 加载更多 */
.load-more-container {
    text-align: center;
    margin-top: 60px;
}

.load-more-btn {
    position: relative;
    background: #FFE600;
    color: #000;
    border: 5px solid #000;
    padding: 24px 48px;
    font-family: 'Press Start 2P', cursive;
    font-size: 14px;
    cursor: pointer;
    box-shadow: 8px 8px 0 #000;
    transition: all 0.2s;
}

.load-more-btn:hover:not(:disabled) {
    transform: translate(4px, 4px);
    box-shadow: 4px 4px 0 #000;
}

.load-more-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

/* 模态框 */
.quick-view-modal {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s;
}

.quick-view-modal.active {
    opacity: 1;
    pointer-events: all;
}

.modal-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.9);
}

.modal-content {
    position: relative;
    background: #1a1a2e;
    border: 5px solid #FFE600;
    border-radius: 24px;
    max-width: 500px;
    width: 90%;
    box-shadow: 0 0 60px rgba(255,230,0,0.3);
    transform: scale(0.9);
    transition: transform 0.3s;
    overflow: hidden;
}

.quick-view-modal.active .modal-content {
    transform: scale(1);
}

.modal-close {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 48px;
    height: 48px;
    background: #FF2D7D;
    border: 4px solid #000;
    border-radius: 12px;
    font-size: 24px;
    color: white;
    cursor: pointer;
    z-index: 10;
    box-shadow: 3px 3px 0 #000;
    font-family: 'Press Start 2P', cursive;
    display: flex;
    align-items: center;
    justify-content: center;
}

.modal-body {
    padding: 40px;
    text-align: center;
}

.modal-image {
    font-size: 120px;
    margin-bottom: 20px;
    animation: modalFloat 3s ease-in-out infinite;
}

@keyframes modalFloat {
    0%, 100% { transform: translateY(0) rotate(0deg); }
    50% { transform: translateY(-15px) rotate(5deg); }
}

.modal-title {
    font-family: 'Press Start 2P', cursive;
    font-size: 16px;
    color: #FFE600;
    margin-bottom: 16px;
    line-height: 1.5;
}

.modal-price {
    font-family: 'Press Start 2P', cursive;
    font-size: 28px;
    color: #FF2D7D;
    margin-bottom: 20px;
}

.modal-desc {
    color: rgba(255,255,255,0.7);
    font-size: 14px;
    line-height: 1.8;
    margin-bottom: 30px;
}

.modal-add-btn {
    font-family: 'Press Start 2P', cursive;
    font-size: 14px;
    padding: 20px 40px;
    background: #FFE600;
    border: 4px solid #000;
    border-radius: 12px;
    cursor: pointer;
    box-shadow: 6px 6px 0 #000;
    transition: all 0.2s;
}

.modal-add-btn:hover {
    transform: translate(3px, 3px);
    box-shadow: 3px 3px 0 #000;
    background: #00D9FF;
}

/* ========== 手机端优化 ========== */
@media (max-width: 768px) {
    /* 页面整体 */
    .shop-page {
        padding: 80px 12px 40px;
    }
    
    /* 标题缩小 */
    .shop-title {
        font-size: 24px;
        text-shadow: 2px 2px 0 #FF2D7D, 4px 4px 0 #00D9FF;
        margin-bottom: 8px;
    }
    
    .shop-subtitle {
        font-size: 10px;
    }
    
    /* 控制面板紧凑 */
    .control-panel {
        padding: 16px;
        gap: 12px;
    }
    
    /* 搜索框缩小 */
    .pixel-search {
        min-width: 100%;
        padding: 10px 12px;
    }
    
    .pixel-search input {
        font-size: 9px;
    }
    
    /* 筛选按钮一行显示，缩小 */
    .filter-chips {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 6px;
        width: 100%;
    }
    
    .chip {
        padding: 8px 4px;
        font-size: 8px;
        text-align: center;
    }
    
    /* 下拉菜单缩小 */
    .pixel-dropdown-btn {
        min-width: 100%;
        padding: 12px 16px;
        font-size: 8px;
    }
    
    /* 产品网格 - 手机端一行2个 */
    .products-container {
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
    }
    
    /* 产品卡片缩小 */
    .card-image-wrapper {
        height: 140px;
    }
    
    .product-img-placeholder {
        font-size: 50px;
    }
    
    .product-pixel-card:hover {
        transform: none;
    }
    
    .card-info {
        padding: 12px;
    }
    
    .card-title {
        font-size: 9px;
        min-height: 28px;
        margin-bottom: 8px;
    }
    
    .card-type, .card-stock {
        font-size: 7px;
    }
    
    .current-price {
        font-size: 14px;
    }
    
    .card-rating {
        font-size: 11px;
        padding: 2px 6px;
    }
    
    /* 徽章缩小 */
    .card-badge {
        font-size: 7px;
        padding: 4px 8px;
    }
    
    /* 快速操作按钮隐藏 */
    .quick-actions {
        display: none;
    }
    
    /* 收藏按钮缩小 */
    .wishlist-btn {
        width: 32px;
        height: 32px;
        font-size: 14px;
    }
    
    /* 加载更多按钮 */
    .load-more-btn {
        padding: 16px 32px;
        font-size: 11px;
        box-shadow: 4px 4px 0 #000;
    }
    
    /* 导航栏适配 */
    .shop-navbar {
        padding: 12px 16px;
    }
    
    .navbar-logo {
        font-size: 14px;
    }
    
    .navbar-logo-icon {
        font-size: 18px;
    }
    
    .navbar-cart {
        width: 40px;
        height: 40px;
        font-size: 16px;
    }
    
    /* 模态框适配 */
    .modal-content {
        max-width: 90%;
        border-width: 4px;
    }
    
    .modal-body {
        padding: 24px;
    }
    
    .modal-image {
        font-size: 80px;
    }
    
    .modal-title {
        font-size: 12px;
    }
    
    .modal-price {
        font-size: 20px;
