<style>
/* ===== HOME CAROUSEL ===== */
.carousel-container { position:relative; max-width:1400px; margin:0 auto; padding:0 20px; display:flex; align-items:center; gap:16px; }
.carousel-viewport { flex:1; overflow:hidden; position:relative; cursor:grab; user-select:none; border-radius:20px; }
.carousel-viewport:active { cursor:grabbing; }
.carousel-track { display:flex; gap:20px; transition:transform 0.5s cubic-bezier(0.4,0,0.2,1); will-change:transform; }
.carousel-card { flex:0 0 calc(25% - 15px); min-width:280px; max-width:320px; background:#1a1a2e; border:4px solid rgba(255,255,255,0.1); border-radius:20px; overflow:hidden; position:relative; transition:all 0.3s; }
.carousel-card:hover { border-color:var(--pixel-yellow); transform:translateY(-10px); box-shadow:0 20px 40px rgba(255,230,0,0.2); }
.carousel-card-inner { position:relative; cursor:pointer; }
.carousel-badge { position:absolute; top:12px; left:12px; font-family:var(--font-pixel); font-size:8px; padding:6px 12px; background:var(--pixel-pink); border:3px solid #000; border-radius:6px; color:white; box-shadow:3px 3px 0 rgba(0,0,0,0.3); z-index:5; animation:badgePulse 2s infinite; }
.carousel-image { height:200px; display:flex; align-items:center; justify-content:center; position:relative; overflow:hidden; }
.carousel-emoji { font-size:90px; animation:floatEmoji 3s ease-in-out infinite; filter:drop-shadow(0 10px 20px rgba(0,0,0,0.3)); }
@keyframes floatEmoji { 0%,100%{transform:translateY(0) rotate(0deg);} 50%{transform:translateY(-15px) rotate(5deg);} }
.carousel-card:hover .carousel-emoji { animation:shake 0.5s ease; }
@keyframes shake { 0%,100%{transform:rotate(0deg);} 25%{transform:rotate(-10deg);} 75%{transform:rotate(10deg);} }
.carousel-info { padding:20px; background:white; }
.carousel-meta { display:flex; justify-content:space-between; margin-bottom:10px; align-items:center; }
.carousel-type { font-family:var(--font-pixel); font-size:8px; color:var(--pixel-purple); background:rgba(157,78,221,0.1); padding:4px 8px; border-radius:4px; }
.carousel-price { font-family:var(--font-pixel); font-size:14px; color:var(--pixel-pink); }
.carousel-name { font-family:var(--font-pixel); font-size:10px; color:#000; line-height:1.6; margin-bottom:12px; min-height:32px; }
.carousel-add-btn { width:calc(100% - 40px); margin:0 20px 20px; padding:14px; background:var(--pixel-yellow); border:4px solid #000; border-radius:var(--radius-md); font-family:var(--font-pixel); font-size:10px; color:#000; cursor:pointer; box-shadow:4px 4px 0 #000; transition:all 0.2s; display:flex; align-items:center; justify-content:center; gap:8px; }
.carousel-add-btn:hover { transform:translate(2px,2px); box-shadow:2px 2px 0 #000; background:var(--pixel-cyan); }
.carousel-nav { width:50px; height:50px; background:var(--pixel-yellow); border:4px solid #000; border-radius:50%; font-family:var(--font-pixel); font-size:16px; color:#000; cursor:pointer; display:flex; align-items:center; justify-content:center; box-shadow:4px 4px 0 #000; transition:all 0.2s; flex-shrink:0; z-index:10; }
.carousel-nav:hover { transform:scale(1.1); background:var(--pixel-pink); color:white; }
.go-to-shop-container { text-align:center; margin-top:50px; }
.go-to-shop-btn { display:inline-flex; align-items:center; gap:16px; font-family:var(--font-pixel); font-size:14px; padding:28px 48px; background:linear-gradient(135deg,var(--pixel-yellow),#FFD000); border:6px solid #000; border-radius:20px; color:#000; text-decoration:none; box-shadow:8px 8px 0 #000, 0 0 40px rgba(255,230,0,0.3); transition:all 0.3s; }
.go-to-shop-btn:hover { transform:translate(4px,4px); box-shadow:4px 4px 0 #000; background:linear-gradient(135deg,var(--pixel-pink),#FF6B9D); color:white; }
.go-to-shop-btn span:first-child { font-size:24px; }
.go-to-shop-btn span:last-child { font-size:20px; transition:transform 0.3s; }
.go-to-shop-btn:hover span:last-child { transform:translateX(8px); }

/* ===== CTA Section ===== */
.home-cta-section { background:linear-gradient(135deg,#16213e,#0a0a0f); padding:100px 20px; text-align:center; position:relative; overflow:hidden; }
.cta-particles .cparticle { position:absolute; width:6px; height:6px; background:var(--pixel-yellow); border-radius:50%; animation:cFloat 8s infinite; }
.cta-particles .cparticle:nth-child(1) { left:10%; top:20%; animation-delay:0s; }
.cta-particles .cparticle:nth-child(2) { left:30%; top:60%; animation-delay:2s; background:var(--pixel-pink); }
.cta-particles .cparticle:nth-child(3) { left:70%; top:30%; animation-delay:4s; background:var(--pixel-cyan); }
.cta-particles .cparticle:nth-child(4) { left:90%; top:70%; animation-delay:1s; }
@keyframes cFloat { 0%,100%{transform:translateY(0);opacity:0.5;} 50%{transform:translateY(-30px);opacity:1;} }
.cta-title { font-family:var(--font-pixel); font-size:clamp(24px,5vw,42px); color:var(--pixel-yellow); margin-bottom:20px; text-shadow:3px 3px 0 var(--pixel-pink),6px 6px 0 var(--pixel-cyan); }
.cta-desc { color:rgba(255,255,255,0.7); font-size:16px; margin-bottom:40px; max-width:600px; margin-left:auto; margin-right:auto; }
.cta-btn-large { display:inline-block; padding:24px 48px; background:var(--pixel-yellow); border:5px solid #000; border-radius:var(--radius-lg); font-family:var(--font-pixel); font-size:14px; color:#000; box-shadow:var(--shadow-pixel-lg); cursor:pointer; transition:all 0.3s; text-decoration:none; }
.cta-btn-large:hover { transform:translate(4px,4px); box-shadow:4px 4px 0 #000; background:var(--pixel-pink); color:white; }

@media (max-width:1200px) { .carousel-card { flex:0 0 calc(33.333% - 14px); min-width:260px; } }
@media (max-width:900px) { .carousel-card { flex:0 0 calc(50% - 10px); min-width:220px; } .carousel-image { height:170px; } .carousel-emoji { font-size:70px; } }
@media (max-width:600px) { .carousel-container { padding:0 10px; gap:10px; } .carousel-card { flex:0 0 calc(50% - 8px); min-width:160px; } .carousel-nav { width:40px; height:40px; font-size:12px; } .carousel-image { height:140px; } .carousel-emoji { font-size:50px; } .carousel-name { font-size:8px; min-height:26px; } .carousel-add-btn { font-size:8px; padding:10px; margin:0 10px 10px; width:calc(100% - 20px); } .carousel-info { padding:12px; } .go-to-shop-btn { font-size:11px; padding:20px 28px; } }
</style>

<script>
// ===== LOADING ANIMATION =====
function initLoader() {
  var grid = document.getElementById('loaderGrid');
  if (!grid) return;
  var pattern = [0,1,2,3,4,5,10,11,12,13,14,15,20,21,22,23,24,25,30,31,32,33,34,35,6,7,8,9,16,17,18,19,26,27,28,29,36,37,38,39,46,47,48,49,56,57,58,59,66,67,68,69,40,41,42,43,44,45,50,51,52,53,54,55,60,61,62,63,64,65,70,71,72,73,74,75,76,77,78,79,86,87,88,89,96,97,98,99];
  for (var i = 0; i < 100; i++) {
    var pixel = document.createElement('div');
    pixel.className = 'loader-pixel' + (pattern.indexOf(i) !== -1 ? ' active' : '');
    pixel.style.animationDelay = (Math.random() * 1.5) + 's';
    grid.appendChild(pixel);
  }
  setTimeout(function() {
    var loader = document.getElementById('holy-loader');
    if (loader) loader.classList.add('hidden');
  }, 1500);
}

// ===== CUSTOM CURSOR =====
function initCustomCursor() {
  var cursor = document.getElementById('customCursor');
  if (!cursor || window.matchMedia('(pointer: coarse)').matches) return;
  var mouseX=0, mouseY=0, cursorX=0, cursorY=0;
  document.addEventListener('mousemove', function(e) { mouseX=e.clientX; mouseY=e.clientY; }, {passive:true});
  function animate() { cursorX+=(mouseX-cursorX)*0.15; cursorY+=(mouseY-cursorY)*0.15; cursor.style.left=cursorX+'px'; cursor.style.top=cursorY+'px'; requestAnimationFrame(animate); }
  animate();
  document.querySelectorAll('a,button,.carousel-card,.feature-item').forEach(function(el) {
    el.addEventListener('mouseenter',function(){cursor.classList.add('hover');});
    el.addEventListener('mouseleave',function(){cursor.classList.remove('hover');});
  });
}

// ===== MASCOT TILT =====
function initMascotTilt() {
  var container = document.getElementById('mascotContainer');
  var mascot = document.getElementById('mascot3d');
  if (!container||!mascot) return;
  container.addEventListener('mousemove', function(e) {
    var r=container.getBoundingClientRect(); var x=(e.clientX-r.left-r.width/2)/15; var y=(e.clientY-r.top-r.height/2)/15;
    mascot.style.transform='rotateY('+x+'deg) rotateX('+-y+'deg)'; mascot.style.animation='none';
  });
  container.addEventListener('mouseleave', function() { mascot.style.transform=''; mascot.style.animation='mascotIdle 5s ease-in-out infinite'; });
}

// ===== HERO PARTICLES =====
function initParticles() {
  var c = document.getElementById('heroParticles'); if (!c) return;
  for (var i=0; i<20; i++) { var p=document.createElement('span'); p.style.left=Math.random()*100+'%'; p.style.animationDelay=Math.random()*10+'s'; p.style.animationDuration=(8+Math.random()*6)+'s'; c.appendChild(p); }
}

// ===== HOME CAROUSEL =====
var hcIdx=0, hcTotal=6, hcAutoPlay;
function moveHomeCarousel(d) { hcIdx=(hcIdx+d+hcTotal)%hcTotal; goHC(hcIdx); }
function goHC(i) { var t=document.getElementById('homeCarouselTrack'); if(!t) return; var w=t.children[0].offsetWidth+20; t.style.transform='translateX('+(-(i*w))+'px)'; }
function startHCA() { stopHCA(); hcAutoPlay=setInterval(function(){moveHomeCarousel(1);},4000); }
function stopHCA() { if(hcAutoPlay) clearInterval(hcAutoPlay); }

function initHomeCarousel() {
  var vp=document.querySelector('.carousel-viewport'), tr=document.getElementById('homeCarouselTrack'); if(!vp||!tr) return;
  var drag=false, sx=0;
  vp.addEventListener('mousedown',function(e){drag=true;sx=e.pageX;vp.style.cursor='grabbing';tr.style.transition='none';stopHCA();});
  vp.addEventListener('mousemove',function(e){if(!drag)return;var d=e.pageX-sx,w=tr.children[0].offsetWidth+20;tr.style.transform='translateX('+(-(hcIdx*w)+d)+'px)';});
  vp.addEventListener('mouseup',function(e){if(!drag)return;drag=false;vp.style.cursor='grab';tr.style.transition='transform 0.5s cubic-bezier(0.4,0,0.2,1)';var d=e.pageX-sx;if(d<-50)moveHomeCarousel(1);else if(d>50)moveHomeCarousel(-1);else goHC(hcIdx);startHCA();});
  vp.addEventListener('mouseleave',function(){if(drag){drag=false;vp.style.cursor='grab';tr.style.transition='transform 0.5s cubic-bezier(0.4,0,0.2,1)';goHC(hcIdx);startHCA();}});
  vp.addEventListener('touchstart',function(e){sx=e.touches[0].clientX;tr.style.transition='none';stopHCA();},{passive:true});
  vp.addEventListener('touchmove',function(e){var d=e.touches[0].clientX-sx,w=tr.children[0].offsetWidth+20;tr.style.transform='translateX('+(-(hcIdx*w)+d)+'px)';},{passive:true});
  vp.addEventListener('touchend',function(e){var d=e.changedTouches[0].clientX-sx;tr.style.transition='transform 0.5s cubic-bezier(0.4,0,0.2,1)';if(d<-50)moveHomeCarousel(1);else if(d>50)moveHomeCarousel(-1);else goHC(hcIdx);startHCA();});
  vp.addEventListener('selectstart',function(e){e.preventDefault();});
  vp.addEventListener('mouseenter',stopHCA); vp.addEventListener('mouseleave',startHCA);
  startHCA();
}

function addHomeCarouselToCart() {
  var btn=event.target.closest('.carousel-add-btn'); if(!btn) return;
  var orig=btn.innerHTML; btn.innerHTML='✓ ADDED!'; btn.style.background='#00FF00';
  if(typeof animateCartIcon==='function') animateCartIcon();
  setTimeout(function(){btn.innerHTML=orig;btn.style.background='';},1500);
}

// ===== TESTIMONIALS =====
var curTest=0;
function goToTestimonial(i) {
  document.querySelectorAll('.testimonial-card').forEach(function(t,idx){t.classList.toggle('active',idx===i);});
  document.querySelectorAll('.testimonial-dot').forEach(function(d,idx){d.classList.toggle('active',idx===i);});
  curTest=i;
}
function initTestimonials() { setInterval(function(){curTest=(curTest+1)%3;goToTestimonial(curTest);},6000); }

// ===== MARQUEE =====
function initMarquee() {
  var track=document.getElementById('marqueeTrack'); if(!track) return;
  track.addEventListener('mouseenter',function(){track.style.animationPlayState='paused';});
  track.addEventListener('mouseleave',function(){track.style.animationPlayState='running';});
}

// ===== NEWSLETTER =====
function handleNewsletterSubscribe(e) {
  e.preventDefault();
  var btn=e.target.querySelector('button'), inp=e.target.querySelector('input');
  btn.textContent='SUBSCRIBED! ✓'; btn.style.background='#00C853'; inp.value='';
  setTimeout(function(){btn.textContent='SUBSCRIBE →';btn.style.background='';},3000);
}

// ===== INIT =====
document.addEventListener('DOMContentLoaded', function() {
  initLoader(); initCustomCursor(); initMascotTilt(); initParticles();
  initHomeCarousel(); initTestimonials(); initMarquee();
});
</script>
