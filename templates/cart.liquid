{% layout 'theme' %}

<style>
@import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

.cart-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #0a0a0f 0%, #1a1a2e 50%, #252542 100%);
  padding: 120px 20px 40px;
  position: relative;
}

.cart-container {
  max-width: 1200px;
  margin: 0 auto;
}

/* 标题 */
.cart-header {
  text-align: center;
  margin-bottom: 40px;
}

.cart-title {
  font-family: 'Press Start 2P', monospace;
  font-size: 24px;
  color: #FFE600;
  text-shadow: 4px 4px 0 #FF2D7D;
  margin-bottom: 10px;
}

.cart-subtitle {
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  color: rgba(255,255,255,0.5);
}

/* 游戏机外壳 */
.game-console {
  background: #2d2d44;
  border: 6px solid #000;
  border-radius: 30px;
  padding: 40px;
  box-shadow: 
    0 0 0 4px #00D9FF,
    0 20px 60px rgba(0,0,0,0.5);
}

/* 空购物车 */
.empty-cart {
  text-align: center;
  padding: 80px 20px;
}

.empty-icon {
  font-size: 100px;
  margin-bottom: 30px;
  opacity: 0.5;
  animation: float 3s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20px); }
}

.empty-text {
  font-family: 'Press Start 2P', monospace;
  font-size: 16px;
  color: rgba(255,255,255,0.6);
  margin-bottom: 30px;
}

.continue-btn {
  display: inline-block;
  padding: 20px 40px;
  background: #FFE600;
  border: 5px solid #000;
  border-radius: 16px;
  font-family: 'Press Start 2P', monospace;
  font-size: 12px;
  color: #000;
  text-decoration: none;
  box-shadow: 6px 6px 0 #000;
  transition: all 0.2s;
}

.continue-btn:hover {
  transform: translate(3px, 3px);
  box-shadow: 3px 3px 0 #000;
  background: #00D9FF;
}

/* 商品列表 */
.cart-items {
  margin-bottom: 30px;
}

.cart-item {
  display: grid;
  grid-template-columns: 100px 1fr auto auto;
  gap: 20px;
  align-items: center;
  background: #1a1a2e;
  border: 4px solid #000;
  border-radius: 16px;
  padding: 20px;
  margin-bottom: 16px;
  box-shadow: 4px 4px 0 #000;
  transition: all 0.2s;
}

.cart-item:hover {
  transform: translate(2px, 2px);
  box-shadow: 2px 2px 0 #000;
  border-color: #FFE600;
}

.item-image {
  width: 80px;
  height: 80px;
  background: linear-gradient(145deg, #FFE600, #FFD000);
  border: 3px solid #000;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40px;
}

.item-details h3 {
  font-family: 'Press Start 2P', monospace;
  font-size: 12px;
  color: #fff;
  margin-bottom: 8px;
}

.item-variant {
  font-family: 'Press Start 2P', monospace;
  font-size: 9px;
  color: rgba(255,255,255,0.5);
}

/* 数量控制 */
.quantity-control {
  display: flex;
  align-items: center;
  gap: 10px;
}

.qty-btn {
  width: 36px;
  height: 36px;
  background: #2d2d44;
  border: 3px solid #000;
  border-radius: 8px;
  font-family: 'Press Start 2P', monospace;
  font-size: 14px;
  color: #fff;
  cursor: pointer;
  box-shadow: 2px 2px 0 #000;
}

.qty-btn:hover {
  background: #FFE600;
  color: #000;
}

.qty-input {
  width: 50px;
  height: 36px;
  background: #1a1a2e;
  border: 3px solid #000;
  border-radius: 8px;
  font-family: 'Press Start 2P', monospace;
  font-size: 12px;
  color: #FFE600;
  text-align: center;
}

/* 价格和删除 */
.item-price {
  font-family: 'Press Start 2P', monospace;
  font-size: 14px;
  color: #00FF00;
  text-align: right;
}

.remove-btn {
  background: #FF2D7D;
  border: 3px solid #000;
  border-radius: 8px;
  padding: 10px 16px;
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  color: #fff;
  cursor: pointer;
  box-shadow: 2px 2px 0 #000;
  margin-left: 20px;
}

.remove-btn:hover {
  transform: translate(2px, 2px);
  box-shadow: 0 0 0 #000;
}

/* 结算区域 */
.cart-footer {
  display: grid;
  grid-template-columns: 1fr 350px;
  gap: 30px;
  margin-top: 30px;
}

/* 优惠券 */
.coupon-section {
  background: #1a1a2e;
  border: 4px solid #000;
  border-radius: 16px;
  padding: 24px;
  height: fit-content;
}

.coupon-title {
  font-family: 'Press Start 2P', monospace;
  font-size: 11px;
  color: #FFE600;
  margin-bottom: 16px;
}

.coupon-input-group {
  display: flex;
  gap: 10px;
}

.coupon-input {
  flex: 1;
  padding: 14px;
  background: #2d2d44;
  border: 3px solid #000;
  border-radius: 10px;
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  color: #fff;
}

.coupon-btn {
  padding: 14px 20px;
  background: #9D4EDD;
  border: 3px solid #000;
  border-radius: 10px;
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  color: #fff;
  cursor: pointer;
  box-shadow: 2px 2px 0 #000;
}

/* 结算卡片 */
.summary-card {
  background: #1a1a2e;
  border: 4px solid #000;
  border-radius: 16px;
  padding: 24px;
}

.summary-title {
  font-family: 'Press Start 2P', monospace;
  font-size: 14px;
  color: #FFE600;
  margin-bottom: 20px;
  padding-bottom: 16px;
  border-bottom: 3px dashed rgba(255,255,255,0.2);
}

.summary-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16px;
  font-family: 'Press Start 2P', monospace;
  font-size: 11px;
}

.summary-label {
  color: rgba(255,255,255,0.7);
}

.summary-value {
  color: #fff;
}

.summary-value.discount {
  color: #00FF00;
}

.summary-row.total {
  margin-top: 20px;
  padding-top: 20px;
  border-top: 3px solid #000;
  font-size: 14px;
}

.total-value {
  color: #FFE600;
  font-size: 18px;
}

/* 结算按钮 */
.checkout-btn {
  width: 100%;
  padding: 24px;
  background: linear-gradient(180deg, #00FF00, #00cc00);
  border: 5px solid #000;
  border-radius: 16px;
  font-family: 'Press Start 2P', monospace;
  font-size: 14px;
  color: #000;
  cursor: pointer;
  box-shadow: 0 8px 0 #000;
  margin-top: 20px;
  transition: all 0.1s;
}

.checkout-btn:hover {
  transform: translateY(4px);
  box-shadow: 0 4px 0 #000;
}

.checkout-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* 继续购物 */
.continue-shopping {
  text-align: center;
  margin-top: 20px;
}

.continue-link {
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  color: rgba(255,255,255,0.6);
  text-decoration: none;
}

.continue-link:hover {
  color: #FFE600;
}

/* 信任徽章 */
.trust-badges {
  display: flex;
  justify-content: center;
  gap: 20px;
  margin-top: 30px;
  flex-wrap: wrap;
}

.trust-badge {
  font-family: 'Press Start 2P', monospace;
  font-size: 8px;
  color: rgba(255,255,255,0.5);
  display: flex;
  align-items: center;
  gap: 6px;
}

/* 响应式 */
@media (max-width: 900px) {
  .cart-footer {
    grid-template-columns: 1fr;
  }
  
  .cart-item {
    grid-template-columns: 80px 1fr;
    grid-template-rows: auto auto;
  }
  
  .item-price, .remove-btn {
    grid-column: 2;
  }
}

@media (max-width: 600px) {
  .game-console {
    padding: 20px;
  }
  
  .cart-title {
    font-size: 16px;
  }
}
</style>

<div class="cart-page">
  <div class="cart-container">
    <div class="cart-header">
      <h1 class="cart-title">🛒 YOUR LOOT BOX</h1>
      <p class="cart-subtitle">REVIEW YOUR ITEMS BEFORE CHECKOUT</p>
    </div>

    <div class="game-console">
      {% if cart.item_count > 0 %}
        <!-- 商品列表 -->
        <div class="cart-items">
          {% for item in cart.items %}
            <div class="cart-item">
              <div class="item-image">
                {{ item.product.title | slice: 0 | replace: 'M', '🍄' | replace: 'P', '⚡' | replace: 'R', '🎮' | replace: 'S', '⭐' | replace: 'L', '🎨' | replace: 'K', '⚔️' | default: '📦' }}
              </div>
              
              <div class="item-details">
                <h3>{{ item.product.title }}</h3>
                <div class="item-variant">{{ item.variant.title }}</div>
              </div>
              
              <div class="quantity-control">
                <button class="qty-btn" onclick="updateQty({{ forloop.index }}, -1)">-</button>
                <input type="text" class="qty-input" value="{{ item.quantity }}" readonly>
                <button class="qty-btn" onclick="updateQty({{ forloop.index }}, 1)">+</button>
              </div>
              
              <div style="display: flex; align-items: center;">
                <div class="item-price">{{ item.line_price | money }}</div>
                <a href="/cart/change?line={{ forloop.index }}&quantity=0" class="remove-btn">✕</a>
              </div>
            </div>
          {% endfor %}
        </div>

        <!-- 结算区域 -->
        <div class="cart-footer">
          <!-- 优惠券 -->
          <div class="coupon-section">
            <div class="coupon-title">🎟️ SECRET CODE (COUPON)</div>
            <div class="coupon-input-group">
              <input type="text" class="coupon-input" placeholder="ENTER CODE">
              <button class="coupon-btn">APPLY</button>
            </div>
          </div>

          <!-- 金额结算 -->
          <div class="summary-card">
            <div class="summary-title">💰 ORDER SUMMARY</div>
            
            <div class="summary-row">
              <span class="summary-label">Subtotal</span>
              <span class="summary-value">{{ cart.total_price | money }}</span>
            </div>
            
            <div class="summary-row">
              <span class="summary-label">Shipping</span>
              <span class="summary-value">Calculated at checkout</span>
            </div>
            
            {% if cart.total_discounts > 0 %}
              <div class="summary-row">
                <span class="summary-label">Discount</span>
                <span class="summary-value discount">-{{ cart.total_discounts | money }}</span>
              </div>
            {% endif %}
            
            <div class="summary-row total">
              <span class="summary-label">TOTAL</span>
              <span class="summary-value total-value">{{ cart.total_price | money }}</span>
            </div>

            <form action="/cart" method="post" novalidate>
              <button type="submit" name="checkout" class="checkout-btn">
                ▶ PROCEED TO CHECKOUT
              </button>
            </form>

            <div class="continue-shopping">
              <a href="/pages/shop" class="continue-link">← CONTINUE SHOPPING</a>
            </div>
          </div>
        </div>

        <!-- 信任徽章 -->
        <div class="trust-badges">
          <div class="trust-badge">🔒 Secure Checkout</div>
          <div class="trust-badge">🚚 Free Shipping over $72</div>
          <div class="trust-badge">✨ Handmade with Love</div>
        </div>

      {% else %}
        <!-- 空购物车 -->
        <div class="empty-cart">
          <div class="empty-icon">📭</div>
          <div class="empty-text">YOUR LOOT BOX IS EMPTY!</div>
          <a href="/pages/shop" class="continue-btn">GO SHOPPING →</a>
        </div>
      {% endif %}
    </div>
  </div>
</div>

<script>
function updateQty(line, change) {
  // 这里可以添加 AJAX 更新数量的逻辑
  // 暂时用表单提交
  var currentQty = parseInt(event.target.parentElement.querySelector('.qty-input').value);
  var newQty = currentQty + change;
  if (newQty < 1) newQty = 1;
  
  // 刷新页面更新数量
  window.location.href = '/cart/change?line=' + line + '&quantity=' + newQty;
}
</script>
