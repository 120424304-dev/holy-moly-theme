<style>
@import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

.cart-page { background: #0a0a0f; min-height: 100vh; padding: 100px 20px 60px; font-family: 'Inter', sans-serif; }

.navbar { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; padding: 16px 40px; background: rgba(10,10,15,0.95); backdrop-filter: blur(10px); border-bottom: 4px solid #FFE600; box-shadow: 0 10px 40px rgba(0,0,0,0.5); }
.navbar-container { max-width: 1400px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; }
.navbar-logo { font-family: 'Press Start 2P'; font-size: 18px; color: #FFE600; text-decoration: none; display: flex; align-items: center; gap: 10px; }
.navbar-cart { position: relative; width: 50px; height: 50px; background: #FFE600; border: 4px solid #000; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; cursor: pointer; box-shadow: 4px 4px 0 #000; }
.cart-badge { position: absolute; top: -10px; right: -10px; width: 26px; height: 26px; background: #FF2D7D; border: 3px solid #000; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-family: 'Press Start 2P'; font-size: 10px; color: white; }

.cart-container { max-width: 1200px; margin: 40px auto; }
.cart-title { font-family: 'Press Start 2P'; font-size: clamp(24px, 5vw, 36px); color: #FFE600; text-align: center; margin-bottom: 40px; text-shadow: 3px 3px 0 #FF2D7D; }

.cart-empty { text-align: center; padding: 80px 20px; }
.empty-icon { font-size: 120px; margin-bottom: 32px; animation: float 3s ease-in-out infinite; }
@keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-20px); } }
.empty-text { font-family: 'Press Start 2P'; font-size: 18px; color: rgba(255,255,255,0.6); margin-bottom: 16px; }
.empty-subtext { color: rgba(255,255,255,0.4); margin-bottom: 40px; }
.continue-shopping-btn { display: inline-block; padding: 20px 40px; background: #FFE600; border: 4px solid #000; border-radius: 12px; font-family: 'Press Start 2P'; font-size: 12px; color: #000; text-decoration: none; box-shadow: 6px 6px 0 #000; transition: all 0.3s; }
.continue-shopping-btn:hover { transform: translate(3px,3px); box-shadow: 3px 3px 0 #000; }

.cart-content { display: grid; grid-template-columns: 1fr 380px; gap: 40px; }
@media (max-width: 1024px) { .cart-content { grid-template-columns: 1fr; } }

.cart-items-section { background: rgba(255,255,255,0.03); border: 4px solid rgba(255,230,0,0.2); border-radius: 24px; padding: 32px; }
.cart-header { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr 40px; gap: 16px; padding-bottom: 20px; border-bottom: 2px solid rgba(255,255,255,0.1); margin-bottom: 24px; }
@media (max-width: 768px) { .cart-header { display: none; } }
.header-cell { font-family: 'Press Start 2P'; font-size: 10px; color: rgba(255,255,255,0.5); }

.cart-item { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr 40px; gap: 16px; align-items: center; padding: 24px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
@media (max-width: 768px) { 
  .cart-item { grid-template-columns: 80px 1fr; gap: 16px; padding: 20px; background: rgba(255,255,255,0.03); border-radius: 16px; margin-bottom: 16px; border: none; } 
}

.item-product { display: flex; gap: 20px; align-items: center; }
@media (max-width: 768px) { .item-product { grid-column: 1 / -1; } }
.item-image { width: 100px; height: 100px; background: linear-gradient(145deg, #FFE600, #FF2D7D); border: 4px solid #000; border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 48px; flex-shrink: 0; overflow: hidden; }
.item-image img { width: 100%; height: 100%; object-fit: cover; }
@media (max-width: 768px) { .item-image { width: 80px; height: 80px; font-size: 36px; } }
.item-details h3 { font-family: 'Press Start 2P'; font-size: 12px; color: white; margin-bottom: 8px; line-height: 1.5; }
.item-variant { font-size: 13px; color: rgba(255,255,255,0.5); }

.item-quantity { display: flex; justify-content: center; }
@media (max-width: 768px) { .item-quantity { justify-content: flex-start; grid-column: 2; } }
.qty-control { display: flex; border: 3px solid #000; border-radius: 8px; overflow: hidden; box-shadow: 3px 3px 0 #000; }
.qty-btn { width: 36px; height: 40px; background: #FFE600; border: none; font-family: 'Press Start 2P'; font-size: 12px; cursor: pointer; }
.qty-btn:hover { background: #FF2D7D; color: white; }
.qty-btn:disabled { background: #666; cursor: not-allowed; }
.qty-input { width: 50px; height: 40px; background: white; border: none; font-family: 'Press Start 2P'; font-size: 11px; text-align: center; }

.item-price, .item-total { font-family: 'Press Start 2P'; font-size: 12px; color: white; text-align: center; }
@media (max-width: 768px) { .item-price { display: none; } .item-total { grid-column: 2; text-align: left; color: #FF2D7D; font-size: 14px; } }
.item-total { color: #FF2D7D; }

.item-remove { width: 36px; height: 36px; background: rgba(255,45,125,0.1); border: 2px solid rgba(255,45,125,0.3); border-radius: 8px; color: #FF2D7D; cursor: pointer; font-size: 18px; display: flex; align-items: center; justify-content: center; transition: all 0.3s; }
@media (max-width: 768px) { .item-remove { position: absolute; top: 20px; right: 20px; } }
.item-remove:hover { background: #FF2D7D; color: white; border-color: #000; }

.cart-summary { background: rgba(255,255,255,0.03); border: 4px solid #FFE600; border-radius: 24px; padding: 32px; position: sticky; top: 100px; height: fit-content; }
@media (max-width: 1024px) { .cart-summary { position: relative; top: 0; } }
.summary-title { font-family: 'Press Start 2P'; font-size: 16px; color: #FFE600; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 2px solid rgba(255,255,255,0.1); }

.summary-row { display: flex; justify-content: space-between; margin-bottom: 16px; font-size: 14px; color: rgba(255,255,255,0.7); }
.summary-row.discount { color: #00D9FF; }
.summary-row.total { font-family: 'Press Start 2P'; font-size: 14px; color: #FFE600; padding-top: 16px; border-top: 2px solid rgba(255,255,255,0.1); margin-top: 16px; }

.shipping-bar { margin: 24px 0; padding: 16px; background: rgba(0,217,255,0.1); border: 2px dashed #00D9FF; border-radius: 12px; text-align: center; }
.shipping-text { font-family: 'Press Start 2P'; font-size: 9px; color: #00D9FF; line-height: 1.6; }
.shipping-highlight { color: #FFE600; }

.checkout-btn { width: 100%; padding: 24px; background: #00D9FF; border: 5px solid #000; border-radius: 16px; font-family: 'Press Start 2P'; font-size: 14px; color: #000; cursor: pointer; box-shadow: 8px 8px 0 #000; margin: 24px 0; text-decoration: none; display: block; text-align: center; transition: all 0.3s; }
.checkout-btn:hover { transform: translate(4px,4px); box-shadow: 4px 4px 0 #000; background: #FFE600; }
.checkout-btn:disabled { background: #666; cursor: not-allowed; transform: none; box-shadow: 8px 8px 0 #000; }

.paypal-btn { width: 100%; padding: 16px; background: #FFB800; border: 4px solid #000; border-radius: 12px; font-family: 'Press Start 2P'; font-size: 12px; color: #000; cursor: pointer; box-shadow: 6px 6px 0 #000; margin-bottom: 12px; display: flex; align-items: center; justify-content: center; gap: 12px; }
.paypal-btn:hover { transform: translate(3px,3px); box-shadow: 3px 3px 0 #000; }

.continue-link { display: block; text-align: center; color: rgba(255,255,255,0.5); text-decoration: none; font-size: 12px; margin-top: 16px; transition: color 0.3s; }
.continue-link:hover { color: #FFE600; }

.trust-badges { display: flex; justify-content: center; gap: 20px; margin-top: 24px; flex-wrap: wrap; }
.trust-badge { display: flex; align-items: center; gap: 8px; font-size: 12px; color: rgba(255,255,255,0.5); }
</style>

<div class="cart-page">
  <div class="cart-container">
    <h1 class="cart-title">🛒 YOUR CART</h1>

    {%- if cart.item_count == 0 -%}
    <div class="cart-empty">
      <div class="empty-icon">📦</div>
      <div class="empty-text">YOUR CART IS EMPTY!</div>
      <p class="empty-subtext">Time to fill it up with some awesome pixel art!</p>
      <a href="/pages/shop" class="continue-shopping-btn">🎮 START SHOPPING</a>
    </div>
    {%- else -%}
    <div class="cart-content">
      <div class="cart-items-section">
        <div class="cart-header">
          <div class="header-cell">PRODUCT</div>
          <div class="header-cell" style="text-align: center;">PRICE</div>
          <div class="header-cell" style="text-align: center;">QTY</div>
          <div class="header-cell" style="text-align: center;">TOTAL</div>
          <div></div>
        </div>
        
        <div id="cartItems">
          {%- for item in cart.items -%}
          <div class="cart-item" data-line="{{ forloop.index }}">
            <div class="item-product">
              <div class="item-image">
                {%- if item.image -%}
                  <img src="{{ item.image | img_url: '200x200', crop: 'center' }}" alt="{{ item.title | escape }}">
                {%- else -%}
                  🎮
                {%- endif -%}
              </div>
              <div class="item-details">
                <h3>{{ item.product.title }}</h3>
                {%- if item.variant.title != 'Default Title' -%}
                  <div class="item-variant">{{ item.variant.title }}</div>
                {%- endif -%}
              </div>
            </div>
            <div class="item-price">{{ item.original_price | money }}</div>
            <div class="item-quantity">
              <div class="qty-control">
                <button class="qty-btn" onclick="updateQty({{ forloop.index }}, {{ item.quantity | minus: 1 }})" {% if item.quantity <= 1 %}disabled{% endif %}>−</button>
                <input type="text" class="qty-input" value="{{ item.quantity }}" readonly>
                <button class="qty-btn" onclick="updateQty({{ forloop.index }}, {{ item.quantity | plus: 1 }})">+</button>
              </div>
            </div>
            <div class="item-total">{{ item.final_line_price | money }}</div>
            <button class="item-remove" onclick="removeItem({{ forloop.index }})">×</button>
          </div>
          {%- endfor -%}
        </div>
      </div>

      <div class="cart-summary">
        <div class="summary-title">💰 ORDER SUMMARY</div>
        
        <div class="summary-row">
          <span>Subtotal ({{ cart.item_count }} items)</span>
          <span id="cartSubtotal">{{ cart.original_total_price | money }}</span>
        </div>
        
        {%- if cart.total_discount > 0 -%}
        <div class="summary-row discount">
          <span>Discount</span>
          <span>-{{ cart.total_discount | money }}</span>
        </div>
        {%- endif -%}
        
        <div class="summary-row">
          <span>Shipping</span>
          <span>Calculated at checkout</span>
        </div>
        
        <div class="summary-row total">
          <span>TOTAL</span>
          <span id="cartTotal">{{ cart.total_price | money }}</span>
        </div>

        {%- assign free_shipping_threshold = 7200 -%}
        {%- assign remaining = free_shipping_threshold | minus: cart.total_price -%}
        <div class="shipping-bar" id="shippingBar" {% if remaining <= 0 %}style="background: rgba(0,255,100,0.1); border-color: #00FF64;"{% endif %}>
          <div class="shipping-text" id="shippingText">
            {%- if remaining > 0 -%}
              🚚 Add <span class="shipping-highlight">{{ remaining | money }}</span> more for FREE shipping!
            {%- else -%}
              ✅ You got FREE shipping!
            {%- endif -%}
          </div>
        </div>

        <a href="/checkout" class="checkout-btn">💳 CHECKOUT NOW</a>
        
        <div class="trust-badges">
          <span class="trust-badge">🔒 Secure</span>
          <span class="trust-badge">🚚 Fast Ship</span>
          <span class="trust-badge">💝 Handmade</span>
        </div>
        
        <a href="/pages/shop" class="continue-link">← Continue Shopping</a>
      </div>
    </div>
    {%- endif -%}
  </div>
</div>

<script>
async function updateQty(line, qty) {
  if (qty < 1) return;
  
  try {
    const response = await fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ line: line, quantity: qty })
    });
    
    if (response.ok) {
      window.location.reload();
    }
  } catch (error) {
    console.error('Failed to update quantity:', error);
  }
}

async function removeItem(line) {
  if (!confirm('Remove this item from your cart?')) return;
  
  try {
    const response = await fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ line: line, quantity: 0 })
    });
    
    if (response.ok) {
      window.location.reload();
    }
  } catch (error) {
    console.error('Failed to remove item:', error);
  }
}

document.addEventListener('DOMContentLoaded', async () => {
  try {
    const response = await fetch('/cart.js');
    const cart = await response.json();
    
    const badge = document.getElementById('cartBadge');
    if (badge) {
      badge.textContent = cart.item_count;
    }
  } catch (e) {
    console.error('Failed to sync cart:', e);
  }
});
</script>
