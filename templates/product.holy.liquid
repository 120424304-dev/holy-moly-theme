{% comment %}
  HOLY MOLY Product Detail Page Template - 真实Shopify集成版本
{% endcomment %}

{{ 'holy-product.css' | asset_url | stylesheet_tag }}

{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign featured_image = current_variant.featured_image | default: product.featured_image -%}

<div id="holy-product-detail" data-product-handle="{{ product.handle }}" data-variant-id="{{ current_variant.id }}">
  
  <!-- ==================== 第1屏：产品信息区 ==================== -->
  <section class="pd-hero">
    <div class="pd-hero-grid">
      
      <!-- 左侧：产品图 -->
      <div class="pd-gallery">
        <div class="pd-main-image">
          {%- if featured_image -%}
            <img src="{{ featured_image | img_url: '800x800' }}" 
                 alt="{{ product.title | escape }}"
                 class="pixel-float"
                 id="mainProductImage">
          {%- else -%}
            <div class="product-img-placeholder" style="font-size: 150px;">{{ product.metafields.custom.emoji | default: '🎮' }}</div>
          {%- endif -%}
          
          <div class="pixel-particles" id="pixelParticles"></div>
        </div>
        
        <!-- 缩略图列表 -->
        {%- if product.images.size > 1 -%}
        <div class="pd-thumbnails">
          {%- for image in product.images limit: 4 -%}
            <div class="pd-thumb {% if forloop.first %}active{% endif %}" 
                 data-image="{{ image | img_url: '800x800' }}"
                 onclick="changeMainImage('{{ image | img_url: '800x800' }}', this)">
              <img src="{{ image | img_url: '150x150', crop: 'center' }}" alt="{{ product.title }} view {{ forloop.index }}">
            </div>
          {%- endfor -%}
        </div>
        {%- endif -%}
      </div>
      
      <!-- 右侧：产品信息 -->
      <div class="pd-info">
        <!-- 标签徽章 -->
        <div class="pd-badges">
          {%- if product.tags contains 'new' -%}
            <span class="badge badge-new">🆕 NEW</span>
          {%- endif -%}
          {%- if product.tags contains 'hot' or product.tags contains 'bestseller' -%}
            <span class="badge badge-hot">🔥 HOT</span>
          {%- endif -%}
          {%- if product.tags contains 'limited' -%}
            <span class="badge badge-limited">💎 LIMITED</span>
          {%- endif -%}
          {%- if product.compare_at_price_max > product.price -%}
            <span class="badge badge-sale">📉 SALE</span>
          {%- endif -%}
        </div>
        
        <!-- 产品名称 -->
        <h1 class="pd-title glitch-text" data-text="{{ product.title | escape }}">
          {{ product.title }}
        </h1>
        
        <!-- 评分 -->
        <div class="pd-rating">
          <span class="stars">⭐⭐⭐⭐⭐</span>
          <span class="rating-score">{{ product.metafields.reviews.rating | default: '4.9' }}</span>
          <span class="rating-count">({{ product.metafields.reviews.count | default: '127' }} reviews)</span>
        </div>
        
        <!-- 价格 -->
        <div class="pd-price">
          {%- if product.compare_at_price > product.price -%}
            <span class="price-compare">{{ product.compare_at_price | money }}</span>
          {%- endif -%}
          <span class="price-current" id="productPrice">{{ current_variant.price | money }}</span>
        </div>
        
        <!-- 简短描述 -->
        <p class="pd-short-desc">{{ product.description | strip_html | truncate: 150 }}</p>
        
        <!-- 变体选择器 -->
        {%- if product.variants.size > 1 -%}
          {%- for option in product.options_with_values -%}
            <div class="pd-variants">
              <label>{{ option.name }}：</label>
              <div class="variant-options" data-option-index="{{ forloop.index0 }}">
                {%- for value in option.values -%}
                  <button class="variant-btn {% if option.selected_value == value %}selected{% endif %}"
                          data-value="{{ value | escape }}"
                          onclick="selectVariant(this)">
                    {{ value }}
                  </button>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
        
        <!-- 数量选择 -->
        <div class="pd-quantity">
          <label>数量：</label>
          <div class="quantity-selector">
            <button class="qty-btn" onclick="updateProductQty(-1)">−</button>
            <input type="number" value="1" min="1" max="{{ current_variant.inventory_quantity | default: 10 }}" id="productQuantity" readonly>
            <button class="qty-btn" onclick="updateProductQty(1)">+</button>
          </div>
        </div>
        
        <!-- CTA 按钮 -->
        <div class="pd-actions">
          <button class="pixel-btn btn-primary" id="addToCartBtn" onclick="addProductToCart()" {% unless current_variant.available %}disabled{% endunless %}>
            <span class="btn-icon">🛒</span>
            <span class="btn-text" id="btnText">{% if current_variant.available %}ADD TO CART{% else %}SOLD OUT{% endif %}</span>
            <span class="btn-price" id="btnPrice">{{ current_variant.price | money }}</span>
          </button>
          
          <button class="pixel-btn btn-wishlist" onclick="addToWishlist()">
            <span class="btn-icon">❤️</span>
          </button>
        </div>
        
        <!-- 免邮提示 -->
        <div class="pd-shipping-note">
          <div class="shipping-progress">
            <div class="progress-bar" id="shippingProgress" style="width: 0%"></div>
          </div>
          <p id="shippingText">🚚 再买 <span class="highlight">$72.00</span> 即享全球包邮！</p>
        </div>
        
        <!-- 信任图标 -->
        <div class="pd-trust-badges">
          <span>🔒 安全支付</span>
          <span>🔄 30天退换</span>
          <span>✈️ 全球配送</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== 第2屏：产品描述区 ==================== -->
  <section class="pd-description">
    <div class="description-content">
      {{ product.description }}
    </div>
  </section>

  <!-- ==================== 第3屏：产品参数区 ==================== -->
  <section class="pd-specs">
    <h2 class="section-title">📊 产品参数</h2>
    
    <div class="specs-grid">
      {%- if product.metafields.custom.size -%}
      <div class="spec-item">
        <span class="spec-label">📐 尺寸</span>
        <span class="spec-value">{{ product.metafields.custom.size }}</span>
      </div>
      {%- endif -%}
      
      {%- if product.weight -%}
      <div class="spec-item">
        <span class="spec-label">⚖️ 重量</span>
        <span class="spec-value">{{ product.weight | weight_with_unit }}</span>
      </div>
      {%- endif -%}
      
      <div class="spec-item">
        <span class="spec-label">🎨 材质</span>
        <span class="spec-value">环保塑料拼豆 + 金属配件</span>
      </div>
      
      <div class="spec-item">
        <span class="spec-label">🔧 工艺</span>
        <span class="spec-value">手工热熔拼贴</span>
      </div>
      
      <div class="spec-item">
        <span class="spec-label">🏷️ 产地</span>
        <span class="spec-value">Made with 💖 in China</span>
      </div>
      
      <div class="spec-item">
        <span class="spec-label">🎁 包装</span>
        <span class="spec-value">品牌盒 + 感谢卡 + 像素贴纸</span>
      </div>
    </div>
  </section>

  <!-- ==================== 第4屏：关联推荐区 ==================== -->
  {%- if product.collections.first.products.size > 1 -%}
  <section class="pd-related">
    <h2 class="section-title">🎯 你可能也喜欢</h2>
    
    <div class="related-grid">
      {%- for related_product in product.collections.first.products limit: 4 -%}
        {%- unless related_product.id == product.id -%}
          <a href="{{ related_product.url }}" class="related-card">
            {%- if related_product.featured_image -%}
              <img src="{{ related_product.featured_image | img_url: '300x300', crop: 'center' }}" alt="{{ related_product.title }}">
            {%- else -%}
              <div class="related-emoji">🎮</div>
            {%- endif -%}
            <span class="related-name">{{ related_product.title }}</span>
            <span class="related-price">{{ related_product.price | money }}</span>
          </a>
        {%- endunless -%}
      {%- endfor -%}
    </div>
  </section>
  {%- endif -%}

  <!-- 悬浮购买栏（移动端显示） -->
  <div class="sticky-buy-bar" id="stickyBar">
    <div class="sticky-info">
      {%- if featured_image -%}
        <img src="{{ featured_image | img_url: '100x100', crop: 'center' }}" class="sticky-img" alt="{{ product.title }}">
      {%- else -%}
        <div class="sticky-img" style="display: flex; align-items: center; justify-content: center; font-size: 30px;">🎮</div>
      {%- endif -%}
      <div class="sticky-text">
        <span class="sticky-name">{{ product.title | truncate: 20 }}</span>
        <span class="sticky-price" id="stickyPrice">{{ current_variant.price | money }}</span>
      </div>
    </div>
    <button class="pixel-btn" onclick="addProductToCart()" {% unless current_variant.available %}disabled{% endunless %}>
      {%- if current_variant.available -%}立即购买{%- else -%}售罄{%- endif -%}
    </button>
  </div>

</div>

<script>
// 产品变体数据
const productVariants = {{ product.variants | json }};
const productOptions = {{ product.options | json }};
let currentVariant = {{ current_variant | json }};

// 数量选择
function updateProductQty(change) {
  const input = document.getElementById('productQuantity');
  const maxQty = parseInt(input.getAttribute('max')) || 10;
  let val = parseInt(input.value) + change;
  if (val >= 1 && val <= maxQty) {
    input.value = val;
  }
}

// 切换主图
function changeMainImage(src, thumb) {
  document.getElementById('mainProductImage').src = src;
  document.querySelectorAll('.pd-thumb').forEach(t => t.classList.remove('active'));
  thumb.classList.add('active');
}

// 选择变体
function selectVariant(btn) {
  const optionContainer = btn.closest('.variant-options');
  const optionIndex = optionContainer.getAttribute('data-option-index');
  
  // 更新选中状态
  optionContainer.querySelectorAll('.variant-btn').forEach(b => b.classList.remove('selected'));
  btn.classList.add('selected');
  
  // 获取所有选中的选项值
  const selectedOptions = [];
  document.querySelectorAll('.variant-options').forEach((container, idx) => {
    const selected = container.querySelector('.variant-btn.selected');
    if (selected) {
      selectedOptions[idx] = selected.getAttribute('data-value');
    }
  });
  
  // 查找匹配的变体
  const matchedVariant = productVariants.find(variant => {
    return variant.options.every((opt, idx) => opt === selectedOptions[idx]);
  });
  
  if (matchedVariant) {
    currentVariant = matchedVariant;
    updateVariantUI(matchedVariant);
  }
}

// 更新变体UI
function updateVariantUI(variant) {
  // 更新价格
  const priceEl = document.getElementById('productPrice');
  const btnPriceEl = document.getElementById('btnPrice');
  const stickyPriceEl = document.getElementById('stickyPrice');
  
  const formattedPrice = formatMoney(variant.price);
  if (priceEl) priceEl.textContent = formattedPrice;
  if (btnPriceEl) btnPriceEl.textContent = formattedPrice;
  if (stickyPriceEl) stickyPriceEl.textContent = formattedPrice;
  
  // 更新按钮状态
  const addBtn = document.getElementById('addToCartBtn');
  const btnText = document.getElementById('btnText');
  
  if (variant.available) {
    addBtn.disabled = false;
    if (btnText) btnText.textContent = 'ADD TO CART';
  } else {
    addBtn.disabled = true;
    if (btnText) btnText.textContent = 'SOLD OUT';
  }
  
  // 更新主图（如果变体有专属图片）
  if (variant.featured_image) {
    document.getElementById('mainProductImage').src = variant.featured_image.src;
  }
}

// 格式化金额
function formatMoney(cents) {
  return '$' + (cents / 100).toFixed(2);
}

// 添加到购物车
async function addProductToCart() {
  if (!currentVariant || !currentVariant.available) {
    showNotification('This item is sold out!', 'error');
    return;
  }
  
  const quantity = parseInt(document.getElementById('productQuantity').value) || 1;
  const btn = document.getElementById('addToCartBtn');
  const originalText = btn.innerHTML;
  
  // 按钮加载状态
  btn.disabled = true;
  btn.innerHTML = '<span class="btn-icon">⏳</span><span>ADDING...</span>';
  
  try {
    const response = await fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        id: currentVariant.id,
        quantity: quantity
      })
    });
    
    if (!response.ok) {
      const error = await response.json();
      throw new Error(error.description || 'Failed to add to cart');
    }
    
    const result = await response.json();
    
    // 成功状态
    btn.innerHTML = '<span class="btn-icon">✅</span><span>ADDED!</span>';
    btn.classList.add('added');
    
    // 打开购物车抽屉
    if (typeof openCartDrawer === 'function') {
      openCartDrawer();
    }
    
    // 更新购物车角标
    const cart = await fetch('/cart.js').then(r => r.json());
    if (typeof updateAllCartBadges === 'function') {
      updateAllCartBadges(cart.item_count);
    }
    
    // 播放音效（如果支持）
    playPixelSound();
    
    // 恢复按钮
    setTimeout(() => {
      btn.disabled = false;
      btn.classList.remove('added');
      btn.innerHTML = originalText;
    }, 2000);
    
  } catch (error) {
    btn.disabled = false;
    btn.innerHTML = originalText;
    showNotification(error.message || 'Failed to add to cart', 'error');
  }
}

// 添加到愿望单
function addToWishlist() {
  showNotification('Added to wishlist! ❤️', 'success');
}

// 显示通知
function showNotification(message, type = 'info') {
  const notification = document.createElement('div');
  notification.className = `holy-notification ${type}`;
  notification.innerHTML = `
    <div class="notification-content">
      <span class="notification-icon">${type === 'success' ? '✅' : type === 'error' ? '❌' : 'ℹ️'}</span>
      <span class="notification-text">${message}</span>
    </div>
  `;
  
  document.body.appendChild(notification);
  
  setTimeout(() => notification.classList.add('show'), 100);
  setTimeout(() => {
    notification.classList.remove('show');
    setTimeout(() => notification.remove(), 300);
  }, 3000);
}

// 像素音效
function playPixelSound() {
  // 简单的 8-bit 音效
  try {
    const audioContext = new (window.AudioContext || window.webkitAudioContext)();
    const oscillator = audioContext.createOscillator();
    const gainNode = audioContext.createGain();
    
    oscillator.connect(gainNode);
    gainNode.connect(audioContext.destination);
    
    oscillator.type = 'square';
    oscillator.frequency.setValueAtTime(880, audioContext.currentTime);
    oscillator.frequency.exponentialRampToValueAtTime(440, audioContext.currentTime + 0.1);
    
    gainNode.gain.setValueAtTime(0.1, audioContext.currentTime);
    gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.1);
    
    oscillator.start(audioContext.currentTime);
    oscillator.stop(audioContext.currentTime + 0.1);
  } catch (e) {
    console.log('Audio not supported');
  }
}

// 更新免邮进度
function updateShippingProgress() {
  const threshold = 7200; // $72 in cents
  const currentTotal = {{ cart.total_price }};
  const progress = Math.min((currentTotal / threshold) * 100, 100);
  const remaining = Math.max((threshold - currentTotal) / 100, 0);
  
  const progressBar = document.getElementById('shippingProgress');
  const shippingText = document.getElementById('shippingText');
  
  if (progressBar) progressBar.style.width = progress + '%';
  
  if (shippingText) {
    if (remaining > 0) {
      shippingText.innerHTML = `🚚 再买 <span class="highlight">$${remaining.toFixed(2)}</span> 即享全球包邮！`;
    } else {
      shippingText.innerHTML = '🎉 恭喜！你已享受全球包邮！';
    }
  }
}

// 悬浮栏显示/隐藏
let lastScroll = 0;
window.addEventListener('scroll', () => {
  const stickyBar = document.getElementById('stickyBar');
  const currentScroll = window.pageYOffset;
  
  if (currentScroll > 800) {
    stickyBar.classList.add('show');
  } else {
    stickyBar.classList.remove('show');
  }
  
  lastScroll = currentScroll;
});

// 像素粒子效果
document.addEventListener('DOMContentLoaded', () => {
  const particlesContainer = document.getElementById('pixelParticles');
  if (particlesContainer) {
    for (let i = 0; i < 20; i++) {
      const particle = document.createElement('div');
      particle.className = 'pixel-particle';
      particle.style.left = Math.random() * 100 + '%';
      particle.style.animationDelay = Math.random() * 2 + 's';
      particle.style.backgroundColor = ['#FF6B6B', '#4ECDC4', '#FFE66D', '#95E1D3'][Math.floor(Math.random() * 4)];
      particlesContainer.appendChild(particle);
    }
  }
  
  // 初始化免邮进度
  updateShippingProgress();
});
</script>

<style>
/* 通知样式 */
.holy-notification {
  position: fixed;
  top: 100px;
  right: 20px;
  background: #1a1a2e;
  border: 3px solid #FFE600;
  border-radius: 12px;
  padding: 16px 24px;
  z-index: 10000;
  transform: translateX(400px);
  transition: transform 0.3s ease;
  box-shadow: 4px 4px 0 #000;
}

.holy-notification.show {
  transform: translateX(0);
}

.holy-notification.success {
  border-color: #00FF00;
}

.holy-notification.error {
  border-color: #FF2D7D;
}

.notification-content {
  display: flex;
  align-items: center;
  gap: 12px;
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  color: #fff;
}

/* 变体按钮样式 */
.variant-btn.selected {
  background: #FFE600;
  color: #000;
  border-color: #000;
  box-shadow: 3px 3px 0 #000;
}

/* 按钮禁用状态 */
.pixel-btn:disabled {
  background: #666;
  cursor: not-allowed;
  box-shadow: none;
}

/* 按钮成功状态 */
.pixel-btn.added {
  background: #00FF00;
}
</style>

{% schema %}
{
  "name": "Holy Moly Product Detail",
  "settings": [
    {
      "type": "header",
      "content": "Product Detail Page Settings"
    },
    {
      "type": "checkbox",
      "id": "show_related_products",
      "label": "Show related products",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Holy Product Detail"
    }
  ]
}
{% endschema %}
