{% comment %}
  Product Detail Page - DIY Kit
{% endcomment %}

{{ 'holy-home.css' | asset_url | stylesheet_tag }}
{{ 'mobile-optimize.css' | asset_url | stylesheet_tag }}

<div id="holy-product">
  <nav class="top-nav">
    <a href="/" class="nav-logo">HOLY MOLY</a>
    <div class="nav-menu">
      <a href="/collections/all" class="nav-link">SHOP</a>
    </div>
    <button class="nav-cart-btn" onclick="window.location.href='/cart'">🛒 <span id="cartCount">0</span></button>
  </nav>

  <section class="product-detail">
    <div class="product-container">
      <div class="product-gallery">
        <div class="main-image" style="--bg:linear-gradient(135deg,#9D4EDD,#7B2CBF)">
          <span class="emoji-large">🎁</span>
          <span class="product-tag tag-new">NEW</span>
        </div>
      </div>

      <div class="product-info-panel">
        <div class="breadcrumb">
          <a href="/">Home</a> / <a href="/collections/all">Shop</a> / <span>DIY Kits</span>
        </div>
        <h1 class="product-name">DIY Starter Kit</h1>
        <div class="product-rating">
          <span class="stars">⭐⭐⭐⭐⭐</span>
          <span class="reviews">4.9 (156 reviews)</span>
        </div>
        <div class="product-price-large">
          <span class="current-price">$45.00</span>
        </div>
        
        <p class="product-description">
          包含制作像素拼豆所需的一切！
          多种颜色拼豆、模板、熨斗纸和详细教程。
          适合 beginners 和手工艺爱好者。
        </p>
        
        <div class="action-buttons">
          <button class="btn-add-cart" onclick="addToCart()">🛒 ADD TO CART</button>
          <button class="btn-buy-now" onclick="buyNow()">⚡ BUY NOW</button>
        </div>
      </div>
    </div>
  </section>
</div>

<style>
#holy-product {
  font-family: 'Inter', sans-serif;
  background: #0a0a0f;
  color: white;
  min-height: 100vh;
  padding-top: 80px;
}
.product-detail {
  padding: 40px 5%;
  max-width: 1200px;
  margin: 0 auto;
}
.product-container {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
}
.main-image {
  width: 100%;
  aspect-ratio: 1;
  background: var(--bg);
  border-radius: 28px;
  border: 5px solid #000;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: 12px 12px 0 rgba(0,0,0,0.3);
}
.emoji-large { font-size: 200px; }
.breadcrumb { font-size: 14px; color: #888; margin-bottom: 20px; }
.breadcrumb a { color: #00D9FF; text-decoration: none; }
.product-name {
  font-family: 'Press Start 2P', cursive;
  font-size: 28px;
  line-height: 1.5;
  margin-bottom: 15px;
}
.product-rating { display: flex; align-items: center; gap: 10px; margin-bottom: 20px; }
.stars { font-size: 20px; }
.reviews { color: #888; }
.current-price { font-size: 48px; font-weight: 800; color: #FF2D7D; }
.product-description { font-size: 16px; line-height: 1.8; color: #ccc; margin-bottom: 30px; }
.action-buttons { display: flex; gap: 15px; }
.btn-add-cart, .btn-buy-now {
  flex: 1;
  padding: 18px 30px;
  border: 4px solid #000;
  border-radius: 16px;
  font-family: 'Press Start 2P', cursive;
  font-size: 12px;
  cursor: pointer;
  box-shadow: 5px 5px 0 #000;
}
.btn-add-cart { background: #FFE600; color: #000; }
.btn-buy-now { background: #FF2D7D; color: white; }
@media (max-width: 900px) {
  .product-container { grid-template-columns: 1fr; }
}
</style>

<script>
function addToCart() { alert('Added to cart! (Demo)'); }
function buyNow() { alert('Redirecting to checkout... (Demo)'); }
</script>