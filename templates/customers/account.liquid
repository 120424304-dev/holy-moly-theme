{% layout 'theme' %}

<style>
@import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

.account-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #0a0a0f 0%, #1a1a2e 50%, #252542 100%);
  padding: 120px 20px 40px;
  position: relative;
  overflow: hidden;
}

.account-page::before {
  content: '';
  position: absolute;
  width: 200%;
  height: 200%;
  background-image: 
    radial-gradient(circle at 50% 50%, rgba(255, 230, 0, 0.08) 0%, transparent 40%);
  animation: bgRotate 30s linear infinite;
}

@keyframes bgRotate {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.account-container {
  max-width: 1000px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}

.welcome-text {
  font-family: 'Press Start 2P', monospace;
  font-size: 12px;
  color: #00D9FF;
  text-align: center;
  margin-bottom: 10px;
}

.player-name {
  font-family: 'Press Start 2P', monospace;
  font-size: 24px;
  color: #FFE600;
  text-align: center;
  text-shadow: 4px 4px 0 #FF2D7D;
  margin-bottom: 20px;
}

.player-stats {
  display: flex;
  justify-content: center;
  gap: 30px;
  flex-wrap: wrap;
  margin-bottom: 30px;
}

.stat-box {
  background: #2d2d44;
  border: 4px solid #000;
  border-radius: 16px;
  padding: 20px 30px;
  text-align: center;
  box-shadow: 4px 4px 0 #000;
  min-width: 140px;
}

.stat-icon {
  font-size: 30px;
  margin-bottom: 10px;
}

.stat-value {
  font-family: 'Press Start 2P', monospace;
  font-size: 20px;
  color: #FFE600;
  margin-bottom: 6px;
}

.stat-label {
  font-family: 'Press Start 2P', monospace;
  font-size: 8px;
  color: rgba(255,255,255,0.6);
}

.game-console {
  background: #2d2d44;
  border: 6px solid #000;
  border-radius: 30px;
  padding: 40px;
  box-shadow: 
    0 0 0 4px #00D9FF,
    0 20px 60px rgba(0,0,0,0.5);
  margin-bottom: 30px;
}

.console-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30px;
  padding-bottom: 20px;
  border-bottom: 3px dashed rgba(255,255,255,0.2);
}

.console-title {
  font-family: 'Press Start 2P', monospace;
  font-size: 14px;
  color: #00D9FF;
}

.level-badge {
  background: #FFE600;
  border: 3px solid #000;
  border-radius: 20px;
  padding: 8px 16px;
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  color: #000;
  box-shadow: 3px 3px 0 #000;
}

.character-selector {
  display: flex;
  align-items: center;
  gap: 30px;
  margin-bottom: 30px;
  padding: 30px;
  background: rgba(0,0,0,0.2);
  border-radius: 20px;
  border: 3px dashed rgba(255,255,255,0.1);
}

.current-avatar {
  text-align: center;
}

.avatar-display {
  width: 120px;
  height: 120px;
  background: linear-gradient(145deg, #FFE600, #FFD000);
  border: 5px solid #000;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 70px;
  box-shadow: 6px 6px 0 #000;
  margin-bottom: 15px;
}

.avatar-label {
  font-family: 'Press Start 2P', monospace;
  font-size: 9px;
  color: rgba(255,255,255,0.6);
}

.avatar-title {
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  color: #FF2D7D;
  margin-bottom: 15px;
}

.avatar-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12px;
}

.avatar-option {
  width: 50px;
  height: 50px;
  background: #1a1a2e;
  border: 4px solid #000;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  cursor: pointer;
  box-shadow: 3px 3px 0 #000;
}

.avatar-option:hover {
  transform: translate(-2px, -2px);
  box-shadow: 5px 5px 0 #000;
}

.avatar-option.selected {
  background: #FFE600;
  transform: scale(1.1);
}

.xp-section {
  margin-bottom: 30px;
}

.xp-header {
  display: flex;
  justify-content: space-between;
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  color: #00FF00;
  margin-bottom: 12px;
}

.xp-bar-container {
  height: 24px;
  background: #1a1a2e;
  border: 4px solid #000;
  border-radius: 12px;
  overflow: hidden;
}

.xp-bar {
  height: 100%;
  width: 30%;
  background: linear-gradient(90deg, #00FF00, #00D9FF);
  border-radius: 8px;
}

.section-title {
  font-family: 'Press Start 2P', monospace;
  font-size: 12px;
  color: #FFE600;
  margin-bottom: 20px;
}

.empty-orders {
  text-align: center;
  padding: 60px 20px;
  background: rgba(0,0,0,0.2);
  border-radius: 20px;
  border: 3px dashed rgba(255,255,255,0.2);
}

.empty-icon {
  font-size: 60px;
  margin-bottom: 20px;
}

.empty-text {
  font-family: 'Press Start 2P', monospace;
  font-size: 12px;
  color: rgba(255,255,255,0.5);
  margin-bottom: 20px;
}

.shop-btn {
  display: inline-block;
  padding: 16px 32px;
  background: #FFE600;
  border: 4px solid #000;
  border-radius: 12px;
  font-family: 'Press Start 2P', monospace;
  font-size: 11px;
  color: #000;
  text-decoration: none;
  box-shadow: 4px 4px 0 #000;
}

.info-section {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 20px;
  margin-bottom: 30px;
}

.info-card {
  background: #1a1a2e;
  border: 4px solid #000;
  border-radius: 16px;
  padding: 20px;
  box-shadow: 4px 4px 0 #000;
}

.info-label {
  font-family: 'Press Start 2P', monospace;
  font-size: 8px;
  color: rgba(255,255,255,0.5);
  margin-bottom: 10px;
}

.info-value {
  font-family: 'Press Start 2P', monospace;
  font-size: 11px;
  color: #fff;
}

.action-buttons {
  display: flex;
  gap: 20px;
  flex-wrap: wrap;
}

.action-btn {
  flex: 1;
  min-width: 200px;
  padding: 20px;
  border: 4px solid #000;
  border-radius: 16px;
  font-family: 'Press Start 2P', monospace;
  font-size: 11px;
  text-align: center;
  text-decoration: none;
  box-shadow: 4px 4px 0 #000;
}

.action-btn.edit {
  background: #FFE600;
  color: #000;
}

.action-btn.logout {
  background: #FF2D7D;
  color: #fff;
}
</style>

<div class="account-page">
  <div class="account-container">
    <div class="welcome-text">★ WELCOME BACK ★</div>
    <h1 class="player-name">PLAYER {{ customer.first_name | upcase }}</h1>
    
    <div class="player-stats">
      <div class="stat-box">
        <div class="stat-icon">🏆</div>
        <div class="stat-value">Lv.{{ customer.orders_count | plus: 1 }}</div>
        <div class="stat-label">LEVEL</div>
      </div>
      <div class="stat-box">
        <div class="stat-icon">🎮</div>
        <div class="stat-value">{{ customer.orders_count }}</div>
        <div class="stat-label">QUESTS</div>
      </div>
      <div class="stat-box">
        <div class="stat-icon">💰</div>
        <div class="stat-value">${{ customer.total_spent | money_without_currency }}</div>
        <div class="stat-label">LOOT SPENT</div>
      </div>
    </div>

    <div class="game-console">
      <div class="console-header">
        <div class="console-title">📟 PLAYER PROFILE</div>
        <div class="level-badge">RANK: PIXEL MASTER</div>
      </div>

      <div class="character-selector">
        <div class="current-avatar">
          <div class="avatar-display">👾</div>
          <div class="avatar-label">CURRENT AVATAR</div>
        </div>
        <div>
          <div class="avatar-title">🎨 CHOOSE YOUR CHARACTER:</div>
          <div class="avatar-grid">
            <div class="avatar-option selected">👾</div>
            <div class="avatar-option">🤖</div>
            <div class="avatar-option">👻</div>
            <div class="avatar-option">🦄</div>
            <div class="avatar-option">🐱</div>
          </div>
        </div>
      </div>

      <div class="xp-section">
        <div class="xp-header">
          <div>📊 XP PROGRESS</div>
          <div>150 / 500 XP</div>
        </div>
        <div class="xp-bar-container">
          <div class="xp-bar"></div>
        </div>
      </div>
    </div>

    <div class="game-console">
      <div class="section-title">📜 QUEST LOG (ORDER HISTORY)</div>
      <div class="empty-orders">
        <div class="empty-icon">📭</div>
        <div class="empty-text">NO QUESTS COMPLETED YET</div>
        <a href="/pages/shop" class="shop-btn">START SHOPPING →</a>
      </div>
    </div>

    <div class="game-console">
      <div class="section-title">📝 PLAYER INFO</div>
      <div class="info-section">
        <div class="info-card">
          <div class="info-label">Player Name</div>
          <div class="info-value">{{ customer.first_name }} {{ customer.last_name }}</div>
        </div>
        <div class="info-card">
          <div class="info-label">Player ID (Email)</div>
          <div class="info-value">{{ customer.email }}</div>
        </div>
      </div>
      <div class="action-buttons">
        <a href="/account/addresses" class="action-btn edit">📍 MANAGE ADDRESSES</a>
        <a href="/account/logout" class="action-btn logout">🚪 EXIT GAME</a>
      </div>
    </div>
  </div>
</div>
