{% layout 'theme' %}

<style>
@import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

.account-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #0a0a0f 0%, #1a1a2e 50%, #252542 100%);
  padding: 120px 20px 40px;
  position: relative;
  overflow: hidden;
}

.account-page::before {
  content: '';
  position: absolute;
  width: 200%;
  height: 200%;
  background-image: 
    radial-gradient(circle at 50% 50%, rgba(255, 230, 0, 0.08) 0%, transparent 40%),
    radial-gradient(circle at 20% 80%, rgba(0, 217, 255, 0.08) 0%, transparent 40%);
  animation: bgRotate 30s linear infinite;
}

@keyframes bgRotate {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 主容器 */
.account-container {
  max-width: 1000px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}

/* 标题区域 */
.account-header {
  text-align: center;
  margin-bottom: 40px;
}

.welcome-text {
  font-family: 'Press Start 2P', monospace;
  font-size: 12px;
  color: #00D9FF;
  margin-bottom: 10px;
}

.player-name {
  font-family: 'Press Start 2P', monospace;
  font-size: 24px;
  color: #FFE600;
  text-shadow: 4px 4px 0 #FF2D7D;
  margin-bottom: 20px;
}

/* 玩家状态栏 */
.player-stats {
  display: flex;
  justify-content: center;
  gap: 30px;
  flex-wrap: wrap;
  margin-bottom: 30px;
}

.stat-box {
  background: #2d2d44;
  border: 4px solid #000;
  border-radius: 16px;
  padding: 20px 30px;
  text-align: center;
  box-shadow: 4px 4px 0 #000;
  min-width: 140px;
}

.stat-icon {
  font-size: 30px;
  margin-bottom: 10px;
}

.stat-value {
  font-family: 'Press Start 2P', monospace;
  font-size: 20px;
  color: #FFE600;
  margin-bottom: 6px;
}

.stat-label {
  font-family: 'Press Start 2P', monospace;
  font-size: 8px;
  color: rgba(255,255,255,0.6);
}

/* 游戏机外壳 - 主要内容区 */
.game-console {
  background: #2d2d44;
  border: 6px solid #000;
  border-radius: 30px;
  padding: 40px;
  box-shadow: 
    0 0 0 4px #00D9FF,
    0 20px 60px rgba(0,0,0,0.5),
    inset 0 2px 0 rgba(255,255,255,0.1);
  margin-bottom: 30px;
}

.console-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30px;
  padding-bottom: 20px;
  border-bottom: 3px dashed rgba(255,255,255,0.2);
}

.console-title {
  font-family: 'Press Start 2P', monospace;
  font-size: 14px;
  color: #00D9FF;
  display: flex;
  align-items: center;
  gap: 12px;
}

.level-badge {
  background: #FFE600;
  border: 3px solid #000;
  border-radius: 20px;
  padding: 8px 16px;
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  color: #000;
  box-shadow: 3px 3px 0 #000;
}

/* 角色选择器 */
.character-selector {
  display: flex;
  align-items: center;
  gap: 30px;
  margin-bottom: 30px;
  padding: 30px;
  background: rgba(0,0,0,0.2);
  border-radius: 20px;
  border: 3px dashed rgba(255,255,255,0.1);
}

.current-avatar {
  text-align: center;
}

.avatar-display {
  width: 120px;
  height: 120px;
  background: linear-gradient(145deg, #FFE600, #FFD000);
  border: 5px solid #000;
  border-radius: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 70px;
  box-shadow: 6px 6px 0 #000;
  margin-bottom: 15px;
  animation: avatarFloat 3s ease-in-out infinite;
}

@keyframes avatarFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}

.avatar-label {
  font-family: 'Press Start 2P', monospace;
  font-size: 9px;
  color: rgba(255,255,255,0.6);
}

.avatar-options {
  flex: 1;
}

.avatar-title {
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  color: #FF2D7D;
  margin-bottom: 15px;
}

.avatar-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12px;
}

.avatar-option {
  width: 50px;
  height: 50px;
  background: #1a1a2e;
  border: 4px solid #000;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  cursor: pointer;
  transition: all 0.2s;
  box-shadow: 3px 3px 0 #000;
}

.avatar-option:hover {
  transform: translate(-2px, -2px);
  box-shadow: 5px 5px 0 #000;
  background: #2d2d44;
}

.avatar-option.selected {
  background: #FFE600;
  border-color: #000;
  transform: scale(1.1);
  box-shadow: 0 0 20px rgba(255, 230, 0, 0.5);
}

/* 经验值条 */
.xp-section {
  margin-bottom: 30px;
}

.xp-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.xp-title {
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  color: #00FF00;
}

.xp-values {
  font-family: 'Press Start 2P', monospace;
  font-size: 9px;
  color: rgba(255,255,255,0.6);
}

.xp-bar-container {
  height: 24px;
  background: #1a1a2e;
  border: 4px solid #000;
  border-radius: 12px;
  overflow: hidden;
  position: relative;
  box-shadow: inset 0 4px 0 rgba(0,0,0,0.3);
}

.xp-bar {
  height: 100%;
  background: linear-gradient(90deg, #00FF00, #00D9FF);
  border-radius: 8px;
  transition: width 0.5s ease;
  position: relative;
  overflow: hidden;
}

.xp-bar::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: repeating-linear-gradient(
    90deg,
    transparent,
    transparent 10px,
    rgba(255,255,255,0.2) 10px,
    rgba(255,255,255,0.2) 20px
  );
  animation: xpShine 1s linear infinite;
}

@keyframes xpShine {
  0% { transform: translateX(0); }
  100% { transform: translateX(20px); }
}

/* 订单历史 - 关卡记录 */
.orders-section {
  margin-bottom: 30px;
}

.section-title {
  font-family: 'Press Start 2P', monospace;
  font-size: 12px;
  color: #FFE600;
  margin-bottom: 20px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.order-card {
  background: #1a1a2e;
  border: 4px solid #000;
  border-radius: 16px;
  padding: 20px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 4px 4px 0 #000;
  transition: all 0.2s;
}

.order-card:hover {
  transform: translate(2px, 2px);
  box-shadow: 2px 2px 0 #000;
  border-color: #FFE600;
}

.order-info {
  display: flex;
  align-items: center;
  gap: 20px;
}

.order-icon {
  width: 50px;
  height: 50px;
  background: linear-gradient(145deg, #FF2D7D, #e62d6f);
  border: 3px solid #000;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
}

.order-details h4 {
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  color: #fff;
  margin-bottom: 8px;
}

.order-meta {
  font-family: 'Press Start 2P', monospace;
  font-size: 8px;
  color: rgba(255,255,255,0.5);
  display: flex;
  gap: 15px;
}

.order-status {
  font-family: 'Press Start 2P', monospace;
  font-size: 9px;
  padding: 10px 20px;
  border: 3px solid #000;
  border-radius: 10px;
  box-shadow: 3px 3px 0 #000;
}

.order-status.completed {
  background: #00FF00;
  color: #000;
}

.order-status.shipping {
  background: #FFE600;
  color: #000;
}

.order-status.processing {
  background: #00D9FF;
  color: #000;
}

.order-xp {
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  color: #00FF00;
  margin-top: 8px;
}

/* 空订单状态 */
.empty-orders {
  text-align: center;
  padding: 60px 20px;
  background: rgba(0,0,0,0.2);
  border-radius: 20px;
  border: 3px dashed rgba(255,255,255,0.2);
}

.empty-icon {
  font-size: 60px;
  margin-bottom: 20px;
  opacity: 0.5;
}

.empty-text {
  font-family: 'Press Start 2P', monospace;
  font-size: 12px;
  color: rgba(255,255,255,0.5);
  margin-bottom: 20px;
}

.shop-btn {
  display: inline-block;
  padding: 16px 32px;
  background: #FFE600;
  border: 4px solid #000;
  border-radius: 12px;
  font-family: 'Press Start 2P', monospace;
  font-size: 11px;
  color: #000;
  text-decoration: none;
  box-shadow: 4px 4px 0 #000;
  transition: all 0.2s;
}

.shop-btn:hover {
  transform: translate(2px, 2px);
  box-shadow: 2px 2px 0 #000;
  background: #00D9FF;
}

/* 个人信息 */
.info-section {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 20px;
  margin-bottom: 30px;
}

.info-card {
  background: #1a1a2e;
  border: 4px solid #000;
  border-radius: 16px;
  padding: 20px;
  box-shadow: 4px 4px 0 #000;
}

.info-label {
  font-family: 'Press Start 2P', monospace;
  font-size: 8px;
  color: rgba(255,255,255,0.5);
  margin-bottom: 10px;
  text-transform: uppercase;
}

.info-value {
  font-family: 'Press Start 2P', monospace;
  font-size: 11px;
  color: #fff;
  word-break: break-all;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20px;
  flex-wrap: wrap;
}

.action-btn {
  flex: 1;
  min-width: 200px;
  padding: 20px;
  border: 4px solid #000;
  border-radius: 16px;
  font-family: 'Press Start 2P', monospace;
  font-size: 11px;
  cursor: pointer;
  box-shadow: 4px 4px 0 #000;
  transition: all 0.2s;
  text-align: center;
  text-decoration: none;
}

.action-btn.edit {
  background: #FFE600;
  color: #000;
}

.action-btn.logout {
  background: #FF2D7D;
  color: #fff;
}

.action-btn:hover {
  transform: translate(2px, 2px);
  box-shadow: 2px 2px 0 #000;
}

/* 响应式 */
@media (max-width: 768px) {
  .character-selector {
    flex-direction: column;
    text-align: center;
  }
  
  .avatar-grid {
    grid-template-columns: repeat(5, 1fr);
  }
  
  .order-card {
    flex-direction: column;
    gap: 15px;
    text-align: center;
  }
  
  .order-info {
    flex-direction: column;
  }
  
  .player-stats {
    gap: 15px;
  }
  
  .stat-box {
    min-width: 100px;
    padding: 15px 20px;
  }
}

@media (max-width: 480px) {
  .game-console {
    padding: 25px 20px;
  }
  
  .player-name {
    font-size: 16px;
  }
  
  .avatar-grid {
    grid-template-columns: repeat(4, 1fr);
  }
  
  .avatar-option {
    width: 40px;
    height: 40px;
    font-size: 22px;
  }
}
</style>

<div class="account-page">
  <div class="account-container">
    <!-- 头部欢迎 -->
    <div class="account-header">
      <div class="welcome-text">★ WELCOME BACK ★</div>
      <h1 class="player-name">PLAYER {{ customer.first_name | upcase }}</h1>
      
      <!-- 状态统计 -->
      <div class="player-stats">
        <div class="stat-box">
          <div class="stat-icon">🏆</div>
          <div class="stat-value" id="levelNum">Lv.{{ customer.orders_count | plus: 1 }}</div>
          <div class="stat-label">LEVEL</div>
        </div>
        <div class="stat-box">
          <div class="stat-icon">🎮</div>
          <div class="stat-value">{{ customer.orders_count }}</div>
          <div class="stat-label">QUESTS</div>
        </div>
        <div class="stat-box">
          <div class="stat-icon">💰</div>
          <div class="stat-value">${{ customer.total_spent | money_without_currency | default: '0' }}</div>
          <div class="stat-label">LOOT SPENT</div>
        </div>
        <div class="stat-box">
          <div class="stat-icon">⭐</div>
          <div class="stat-value" id="xpTotal">{{ customer.orders_count | times: 100 | plus: 50 }}</div>
          <div class="stat-label">TOTAL XP</div>
        </div>
      </div>
    </div>

    <!-- 主控制台 -->
    <div class="game-console">
      <div class="console-header">
        <div class="console-title">
          <span>📟</span> PLAYER PROFILE
        </div>
        <div class="level-badge">RANK: PIXEL MASTER</div>
      </div>

      <!-- 角色选择器 -->
      <div class="character-selector">
        <div class="current-avatar">
          <div class="avatar-display" id="currentAvatar">👾</div>
          <div class="avatar-label">CURRENT AVATAR</div>
        </div>
        <div class="avatar-options">
          <div class="avatar-title">🎨 CHOOSE YOUR CHARACTER:</div>
          <div class="avatar-grid" id="avatarGrid">
            <div class="avatar-option selected" onclick="selectAvatar('👾', this)">👾</div>
            <div class="avatar-option" onclick="selectAvatar('🤖', this)">🤖</div>
            <div class="avatar-option" onclick="selectAvatar('👻', this)">👻</div>
            <div class="avatar-option" onclick="selectAvatar('🦄', this)">🦄</div>
            <div class="avatar-option" onclick="selectAvatar('🐱', this)">🐱</div>
            <div class="avatar-option" onclick="selectAvatar('🦊', this)">🦊</div>
            <div class="avatar-option" onclick="selectAvatar('🐼', this)">🐼</div>
            <div class="avatar-option" onclick="selectAvatar('🐸', this)">🐸</div>
            <div class="avatar-option" onclick="selectAvatar('🌟', this)">🌟</div>
            <div class="avatar-option" onclick="selectAvatar('⚡', this)">⚡</div>
          </div>
        </div>
      </div>

      <!-- 经验值条 -->
      <div class="xp-section">
        <div class="xp-header">
          <div class="xp-title">📊 XP PROGRESS</div>
          <div class="xp-values"><span id="currentXp">150</span> / <span id="nextLevel">500</span> XP</div>
        </div>
        <div class="xp-bar-container">
          <div class="xp-bar" id="xpBar" style="width: 30%;"></div>
        </div>
      </div>
    </div>

    <!-- 订单历史 - 任务记录 -->
    <div class="game-console">
      <div class="section-title">
        <span>📜</span> QUEST LOG (ORDER HISTORY)
      </div>
      
      {% if customer.orders.size > 0 %}
        <div class="order-list">
          {% for order in customer.orders limit: 5 %}
            <div class="order-card">
              <div class="order-info">
                <div class="order-icon">
                  {% if order.fulfillment_status == 'fulfilled' %}🏆
                  {% elsif order.fulfillment_status == 'partial' %}📦
                  {% else %}⚔️{% endif %}
                </div>
                <div class="order-details">
                  <h4>QUEST #{{ order.order_number }}</h4>
                  <div class="order-meta">
                    <span>📅 {{ order.created_at | date: "%Y-%m-%d" }}</span>
                    <span>💰 {{ order.total_price | money }}</span>
                  </div>
                  <div class="order-xp">+{{ order.line_items.size | times: 50 }} XP EARNED</div>
                </div>
              </div>
              <div class="order-status {% if order.fulfillment_status == 'fulfilled' %}completed{% elsif order.fulfillment_status == 'partial' %}shipping{% else %}processing{% endif %}">
                {% if order.fulfillment_status == 'fulfilled' %}COMPLETED{% elsif order.fulfillment_status == 'partial' %}SHIPPING{% else %}PROCESSING{% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      {% else %}
        <div class="empty-orders">
          <div class="empty-icon">📭</div>
          <div class="empty-text">NO QUESTS COMPLETED YET</div>
          <a href="/pages/shop" class="shop-btn">START SHOPPING →</a>
        </div>
      {% endif %}
    </div>

    <!-- 个人信息 -->
    <div class="game-console">
      <div class="section-title">
        <span>📝</span> PLAYER INFO
      </div>
      
      <div class="info-section">
        <div class="info-card">
          <div class="info-label">Player Name</div>
          <div class="info-value">{{ customer.first_name }} {{ customer.last_name }}</div>
        </div>
        <div class="info-card">
          <div class="info-label">Player ID (Email)</div>
          <div class="info-value">{{ customer.email }}</div>
        </div>
        <div class="info-card">
          <div class="info-label">Member Since</div>
          <div class="info-value">{{ customer.created_at | date: "%Y-%m-%d" }}</div>
        </div>
        <div class="info-card">
          <div class="info-label">Default Address</div>
          <div class="info-value">
            {% if customer.default_address %}
              {{ customer.default_address.city }}, {{ customer.default_address.country }}
            {% else %}
              NOT SET
            {% endif %}
          </div>
        </div>
      </div>

      <!-- 操作按钮 -->
      <div class="action-buttons">
        <a href="/account/addresses" class="action-btn edit">📍 MANAGE ADDRESSES</a>
        <a href="/account/logout" class="action-btn logout">🚪 EXIT GAME (LOGOUT)</a>
      </div>
    </div>
  </div>
</div>

<script>
// 头像选择
function selectAvatar(emoji, element) {
  // 更新选中状态
  document.querySelectorAll('.avatar-option').forEach(function(el) {
    el.classList.remove('selected');
  });
  element.classList.add('selected');
  
  // 更新显示
  var display = document.getElementById('currentAvatar');
  display.textContent = emoji;
  display.style.animation = 'none';
  setTimeout(function() {
    display.style.animation = 'avatarFloat 3s ease-in-out infinite';
  }, 10);
  
  // 保存到本地存储
  localStorage.setItem('holyMolyAvatar', emoji);
}

// 页面加载时恢复头像
document.addEventListener('DOMContentLoaded', function() {
  var savedAvatar = localStorage.getItem('holyMolyAvatar');
  if (savedAvatar) {
    document.getElementById('currentAvatar').textContent = savedAvatar;
    document.querySelectorAll('.avatar-option').forEach(function(el) {
      if (el.textContent === savedAvatar) {
        el.classList.add('selected');
      } else {
        el.classList.remove('selected');
      }
    });
  }
  
  // 动画数字
  animateValue('xpTotal', 0, parseInt(document.getElementById('xpTotal').textContent), 1000);
});

// 数字动画
function animateValue(id, start, end, duration) {
  var obj = document.getElementById(id);
  var range = end - start;
  var minTimer = 50;
  var stepTime = Math.abs(Math.floor(duration / range));
  stepTime = Math.max(stepTime, minTimer);
  var startTime = new Date().getTime();
  var endTime = startTime + duration;
  var timer;
  
  function run() {
    var now = new Date().getTime();
    var remaining = Math.max((endTime - now) / duration, 0);
    var value = Math.round(end - (remaining * range));
    obj.textContent = value;
    if (value == end) {
      clearInterval(timer);
    }
  }
  
  timer = setInterval(run, stepTime);
  run();
}

// XP 进度条动画
window.addEventListener('load', function() {
  var xpBar = document.getElementById('xpBar');
  setTimeout(function() {
    xpBar.style.width = '30%';
  }, 500);
});
</script>
