{% layout 'theme' %}

<style>
@import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

.login-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #0a0a0f 0%, #1a1a2e 50%, #252542 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120px 20px 40px;
  position: relative;
  overflow: hidden;
}

/* 背景装饰 */
.login-page::before {
  content: '';
  position: absolute;
  width: 200%;
  height: 200%;
  background-image: 
    radial-gradient(circle at 20% 50%, rgba(255, 230, 0, 0.1) 0%, transparent 50%),
    radial-gradient(circle at 80% 50%, rgba(255, 45, 125, 0.1) 0%, transparent 50%);
  animation: bgFloat 20s ease-in-out infinite;
}

@keyframes bgFloat {
  0%, 100% { transform: translate(0, 0); }
  50% { transform: translate(-5%, -5%); }
}

/* 游戏机外框 */
.game-console {
  background: #2d2d44;
  border: 6px solid #000;
  border-radius: 30px;
  padding: 50px 40px;
  max-width: 480px;
  width: 100%;
  box-shadow: 
    0 0 0 4px #FFE600,
    0 20px 60px rgba(0,0,0,0.5),
    inset 0 2px 0 rgba(255,255,255,0.1);
  position: relative;
  z-index: 1;
}

/* 屏幕反光效果 */
.game-console::before {
  content: '';
  position: absolute;
  top: 20px; left: 20px; right: 20px;
  height: 100px;
  background: linear-gradient(180deg, rgba(255,255,255,0.1), transparent);
  border-radius: 20px;
  pointer-events: none;
}

/* 标题 */
.login-title {
  font-family: 'Press Start 2P', monospace;
  font-size: 24px;
  color: #FFE600;
  text-align: center;
  margin-bottom: 10px;
  text-shadow: 3px 3px 0 #FF2D7D;
  animation: titleBlink 2s infinite;
}

@keyframes titleBlink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.8; }
}

.login-subtitle {
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  color: rgba(255,255,255,0.5);
  text-align: center;
  margin-bottom: 40px;
}

/* 表单 */
.pixel-form {
  display: flex;
  flex-direction: column;
  gap: 24px;
}

.form-group {
  position: relative;
}

.form-label {
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  color: #00D9FF;
  display: block;
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.form-input {
  width: 100%;
  padding: 18px 20px;
  background: #1a1a2e;
  border: 4px solid #000;
  border-radius: 12px;
  font-family: 'Press Start 2P', monospace;
  font-size: 12px;
  color: #FFE600;
  box-shadow: inset 0 4px 0 rgba(0,0,0,0.3);
  transition: all 0.3s;
}

.form-input::placeholder {
  color: rgba(255,255,255,0.3);
}

.form-input:focus {
  outline: none;
  border-color: #FFE600;
  box-shadow: inset 0 4px 0 rgba(0,0,0,0.3), 0 0 20px rgba(255,230,0,0.3);
}

/* 密码显示切换 */
.password-wrapper {
  position: relative;
}

.toggle-password {
  position: absolute;
  right: 15px;
  top: 50%;
  transform: translateY(-50%);
  background: #FF2D7D;
  border: 3px solid #000;
  border-radius: 8px;
  padding: 8px 12px;
  font-family: 'Press Start 2P', monospace;
  font-size: 8px;
  color: white;
  cursor: pointer;
  box-shadow: 2px 2px 0 #000;
}

.toggle-password:hover {
  transform: translateY(-50%) scale(1.05);
}

/* 记住我 - 像素风复选框 */
.remember-me {
  display: flex;
  align-items: center;
  gap: 12px;
  cursor: pointer;
}

.pixel-checkbox {
  width: 24px;
  height: 24px;
  background: #1a1a2e;
  border: 3px solid #000;
  border-radius: 6px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  box-shadow: inset 0 2px 0 rgba(0,0,0,0.3);
  transition: all 0.2s;
}

.remember-me:hover .pixel-checkbox {
  border-color: #FFE600;
}

.remember-me input:checked + .pixel-checkbox {
  background: #FFE600;
  border-color: #000;
}

.remember-me input { display: none; }

.remember-text {
  font-family: 'Press Start 2P', monospace;
  font-size: 9px;
  color: rgba(255,255,255,0.7);
}

/* 登录按钮 - 游戏手柄风格 */
.login-btn {
  width: 100%;
  padding: 24px;
  background: linear-gradient(180deg, #FFE600, #FFD000);
  border: 5px solid #000;
  border-radius: 16px;
  font-family: 'Press Start 2P', monospace;
  font-size: 14px;
  color: #000;
  cursor: pointer;
  box-shadow: 
    0 8px 0 #000,
    0 10px 20px rgba(0,0,0,0.3),
    inset 0 -4px 0 rgba(0,0,0,0.1);
  transition: all 0.1s;
  position: relative;
  overflow: hidden;
}

.login-btn::before {
  content: '▶';
  margin-right: 12px;
}

.login-btn:hover {
  transform: translateY(-2px);
  box-shadow: 
    0 10px 0 #000,
    0 12px 25px rgba(0,0,0,0.3),
    inset 0 -4px 0 rgba(0,0,0,0.1);
  background: linear-gradient(180deg, #00D9FF, #00b4d8);
}

.login-btn:active {
  transform: translateY(4px);
  box-shadow: 
    0 4px 0 #000,
    inset 0 -4px 0 rgba(0,0,0,0.1);
}

/* 链接 */
.login-links {
  display: flex;
  justify-content: space-between;
  margin-top: 30px;
  padding-top: 30px;
  border-top: 3px dashed rgba(255,255,255,0.2);
}

.pixel-link {
  font-family: 'Press Start 2P', monospace;
  font-size: 9px;
  color: rgba(255,255,255,0.6);
  text-decoration: none;
  transition: all 0.3s;
  position: relative;
}

.pixel-link:hover {
  color: #FFE600;
}

.pixel-link::after {
  content: '';
  position: absolute;
  bottom: -4px; left: 0;
  width: 0; height: 3px;
  background: #FFE600;
  transition: width 0.3s;
}

.pixel-link:hover::after {
  width: 100%;
}

/* 社交登录 */
.social-login {
  margin-top: 30px;
  text-align: center;
}

.social-divider {
  font-family: 'Press Start 2P', monospace;
  font-size: 8px;
  color: rgba(255,255,255,0.4);
  position: relative;
  margin-bottom: 20px;
}

.social-divider::before,
.social-divider::after {
  content: '────────';
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  opacity: 0.3;
}

.social-divider::before { right: calc(50% + 60px); }
.social-divider::after { left: calc(50% + 60px); }

.social-buttons {
  display: flex;
  gap: 16px;
  justify-content: center;
}

.social-btn {
  flex: 1;
  padding: 16px;
  background: #2d2d44;
  border: 4px solid #000;
  border-radius: 12px;
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  color: white;
  cursor: pointer;
  box-shadow: 4px 4px 0 #000;
  transition: all 0.2s;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

.social-btn.discord {
  background: #5865F2;
}

.social-btn.discord:hover {
  background: #4752C4;
  transform: translate(2px, 2px);
  box-shadow: 2px 2px 0 #000;
}

/* 注册提示 */
.register-prompt {
  text-align: center;
  margin-top: 30px;
  padding: 24px;
  background: rgba(255,255,255,0.05);
  border: 3px dashed rgba(255,255,255,0.2);
  border-radius: 16px;
}

.register-text {
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  color: rgba(255,255,255,0.6);
  margin-bottom: 16px;
  line-height: 1.8;
}

.register-btn {
  display: inline-block;
  padding: 16px 32px;
  background: #FF2D7D;
  border: 4px solid #000;
  border-radius: 12px;
  font-family: 'Press Start 2P', monospace;
  font-size: 11px;
  color: white;
  text-decoration: none;
  box-shadow: 4px 4px 0 #000;
  transition: all 0.2s;
}

.register-btn:hover {
  transform: translate(2px, 2px);
  box-shadow: 2px 2px 0 #000;
  background: #ff4d8f;
}

/* 错误提示 */
.error-message {
  background: #FF2D7D;
  border: 4px solid #000;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 24px;
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  color: white;
  text-align: center;
  box-shadow: 4px 4px 0 #000;
  animation: errorShake 0.5s;
}

@keyframes errorShake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-10px); }
  75% { transform: translateX(10px); }
}

/* 加载动画 */
.loading-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.9);
  display: none;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loading-overlay.active {
  display: flex;
}

.loading-text {
  font-family: 'Press Start 2P', monospace;
  font-size: 20px;
  color: #FFE600;
  animation: loadingPulse 1s infinite;
}

@keyframes loadingPulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(1.1); }
}

/* 响应式 */
@media (max-width: 600px) {
  .game-console {
    padding: 30px 20px;
  }
  .login-title {
    font-size: 18px;
  }
  .form-input {
    font-size: 11px;
    padding: 16px;
  }
  .social-buttons {
    flex-direction: column;
  }
  .login-links {
    flex-direction: column;
    gap: 16px;
    text-align: center;
  }
}
</style>

<div class="login-page">
  <div class="game-console">
    <h1 class="login-title">{{ 'login.title' | t }}</h1>
    <p class="login-subtitle">{{ 'login.subtitle' | t }}</p>
    
    {% form 'customer_login' %}
      {% if form.errors %}
        <div class="error-message">
          {{ 'login.error_title' | t }} {{ form.errors | default_errors }}
        </div>
      {% endif %}
      
      <div class="pixel-form">
        <div class="form-group">
          <label class="form-label">{{ 'login.email_label' | t }}</label>
          <input 
            type="email" 
            name="customer[email]" 
            class="form-input" 
            placeholder="{{ 'login.email_placeholder' | t }}"
            required
            autocorrect="off"
            autocapitalize="off"
          >
        </div>
        
        <div class="form-group">
          <label class="form-label">{{ 'login.password_label' | t }}</label>
          <div class="password-wrapper">
            <input 
              type="password" 
              name="customer[password]" 
              id="password"
              class="form-input" 
              placeholder="{{ 'login.password_placeholder' | t }}"
              required
            >
            <button type="button" class="toggle-password" onclick="togglePassword()">👁️</button>
          </div>
        </div>
        
        <label class="remember-me">
          <input type="checkbox" name="customer[remember]" checked>
          <span class="pixel-checkbox">✓</span>
          <span class="remember-text">{{ 'login.remember_me' | t }}</span>
        </label>
        
        <button type="submit" class="login-btn" onclick="showLoading()">
          {{ 'login.submit' | t }}
        </button>
      </div>
    {% endform %}
    
    <div class="login-links">
      <a href="/account/register" class="pixel-link">{{ 'login.new_player' | t }}</a>
      <a href="#recover" onclick="showRecover()" class="pixel-link">{{ 'login.forgot_password' | t }}</a>
    </div>
    
    <!-- 社交登录 -->
    <div class="social-login">
      <div class="social-divider">{{ 'login.social_divider' | t }}</div>
      <div class="social-buttons">
        <button class="social-btn discord" onclick="socialLogin('discord')">
          {{ 'login.social_discord' }}
        </button>
      </div>
    </div>
    
    <!-- 注册提示 -->
    <div class="register-prompt">
      <p class="register-text">{{ 'login.register_prompt' | t }}</p>
      <a href="/account/register" class="register-btn">{{ 'login.register_button' | t }}</a>
    </div>
  </div>
</div>

<!-- 加载遮罩 -->
<div class="loading-overlay" id="loadingOverlay">
  <div class="loading-text">{{ 'general.loading' | t }}</div>
</div>

<script>
function togglePassword() {
  var input = document.getElementById('password');
  var btn = event.target;
  if (input.type === 'password') {
    input.type = 'text';
    btn.textContent = '🙈';
  } else {
    input.type = 'password';
    btn.textContent = '👁️';
  }
}

function showLoading() {
  document.getElementById('loadingOverlay').classList.add('active');
}

function socialLogin(provider) {
  if (provider === 'discord') {
    window.location.href = '/apps/discord/login';
  }
}

function showRecover() {
  window.location.href = '/account/login#recover';
}

// 输入框焦点效果
document.querySelectorAll('.form-input').forEach(function(input) {
  input.addEventListener('focus', function() {
    this.style.transform = 'scale(1.02)';
  });
  input.addEventListener('blur', function() {
    this.style.transform = 'scale(1)';
  });
});
</script>
