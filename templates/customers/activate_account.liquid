{% layout 'theme' %}

<style>
@import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

.activate-page {
  min-height: 100vh;
  background: linear-gradient(135deg, #0a0a0f 0%, #1a1a2e 50%, #252542 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120px 20px 40px;
}

.game-console {
  background: #2d2d44;
  border: 6px solid #000;
  border-radius: 30px;
  padding: 50px 40px;
  max-width: 480px;
  width: 100%;
  text-align: center;
  box-shadow: 
    0 0 0 4px #00FF00,
    0 20px 60px rgba(0,0,0,0.5);
}

.success-icon {
  font-size: 80px;
  margin-bottom: 20px;
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20px); }
}

.title {
  font-family: 'Press Start 2P', monospace;
  font-size: 18px;
  color: #00FF00;
  margin-bottom: 20px;
  text-shadow: 3px 3px 0 #000;
}

.message {
  font-family: 'Press Start 2P', monospace;
  font-size: 10px;
  color: rgba(255,255,255,0.7);
  line-height: 2;
  margin-bottom: 30px;
}

.activate-btn {
  display: inline-block;
  padding: 20px 40px;
  background: #00FF00;
  border: 5px solid #000;
  border-radius: 16px;
  font-family: 'Press Start 2P', monospace;
  font-size: 12px;
  color: #000;
  text-decoration: none;
  box-shadow: 0 8px 0 #000;
  transition: all 0.2s;
}

.activate-btn:hover {
  transform: translateY(4px);
  box-shadow: 0 4px 0 #000;
}
</style>

<div class="activate-page">
  <div class="game-console">
    <div class="success-icon">{{ 'activate_account.icon' | t }}</div>
    <h1 class="title">{{ 'activate_account.title' | t }}</h1>
    <p class="message">
      {{ 'activate_account.message' | t }}
    </p>
    <a href="/" class="activate-btn">{{ 'activate_account.button' | t }}</a>
  </div>
</div>
